# ============================================================
# Variables d'environnement — PRODUCTION
# Copier vers /opt/playalama/prod/.env et compléter les valeurs
# Ce fichier ne doit JAMAIS être commité avec de vraies valeurs
# ============================================================

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production

# Sécurité serveur de jeu
LAMA_SERVER_ALLOW_SHUTDOWN=false
LAMA_RUNTIME_MODE=online

# URL interne entre le WebApp et le serveur de jeu (réseau Docker interne)
LAMA_SERVER_URL=http://lama-server-prod:5201

# Logging
LOG_LEVEL=Information

# ─── PostgreSQL ───────────────────────────────────────────
# Ces valeurs sont utilisées à la fois par postgres-lama-prod
# et par la chaîne de connexion de lama-server-prod.
POSTGRES_USER=lama_prod
POSTGRES_PASSWORD=changeme_prod_strong_password
POSTGRES_DB=lama_prod

# Chaîne de connexion complète pour lama-server-prod
# (host = nom du service Docker postgres-lama-prod)
ConnectionStrings__LamaServerDb=Host=postgres-lama-prod;Port=5432;Database=lama_prod;Username=lama_prod;Password=changeme_prod_strong_password;Ssl Mode=Disable;Application Name=LamaServer;

# ─── JWT / Auth ───────────────────────────────────────────
# Clé secrète min. 32 caractères, jamais la même qu'en dev
JWT_SECRET=changeme_jwt_secret_min32chars_must_be_unique_prod

# ─── Dashboard admin ──────────────────────────────────────
# Secret partagé pour accéder au tableau de bord /status
LAMA_ADMIN_SECRET=changeme_admin_secret_min16chars
