# Configuration du serveur LAMA
# Copier ce fichier en .env et adapter les valeurs

# ═══════════════════════════════════════════════════════════
# OPTION A: Local Debug (Recommended for Development)
# ═══════════════════════════════════════════════════════════

# Mode ASP.NET Core (Development for Option A)
ASPNETCORE_ENVIRONMENT=Development

# Server & WebApp Listening (Option A: ports 5201 & 5202)
# ASPNETCORE_URLS=http://127.0.0.1:5201  # Uncomment for Server
# ASPNETCORE_URLS=http://127.0.0.1:5202  # Uncomment for WebApp

# WebApp points to Server on 5201
LAMA_SERVER_URL=http://127.0.0.1:5201

# PostgreSQL on Docker (Option A: port 5200)
POSTGRES_USER=lama_dev
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=lama_dev

# ═══════════════════════════════════════════════════════════
# PRODUCTION Configuration
# ═══════════════════════════════════════════════════════════

# Mode ASP.NET Core (Production)
# ASPNETCORE_ENVIRONMENT=Production
# ASPNETCORE_URLS=http://+:5000;https://+:5001

# Configuration du serveur Lama
LAMA_SERVER_ALLOW_SHUTDOWN=false

# Configuration nginx
NGINX_DOMAIN=playalama.online
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=4096

# Let's Encrypt / Certbot
CERTBOT_EMAIL=admin@playalama.online
CERTBOT_DOMAIN=playalama.online
CERTBOT_STAGING=false

# Logging
LOG_LEVEL=Information
LAMA_LOG_PATH=/app/logs

