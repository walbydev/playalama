@page "/license"
@layout MainLayout
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["License.PageTitle"]</PageTitle>

<div class="page-hero">
    <div class="eyebrow">@L["Footer.Project"]</div>
    <h1>⚖️ @L["License.Title"]</h1>
    <p class="text-muted mt-2">
        @L["License.Subtitle"]
    </p>
</div>

<div class="section">
    <div class="container" style="max-width:1000px">
        <div class="card mb-4">
            <h2 class="mb-2">@L["License.ProjectLicense"]</h2>
            <p>
                @L["License.SourceCodePrefix"] <strong>Playalama</strong> @L["License.SourceCodeInfix"]
                <strong>GNU Affero General Public License v3.0 or later (AGPL-3.0-or-later)</strong>.
            </p>
            <p class="text-muted mt-2">
                @L["License.ReferenceFilePrefix"] <code>LICENSE</code> @L["License.ReferenceFileSuffix"]
            </p>
            <p class="text-muted mt-2">
                @L["License.Summary"]
            </p>
        </div>

        <div class="card mb-4">
            <h2 class="mb-2">@L["License.Donations"]</h2>
            <p>
                @L["License.DonationsDesc"]
            </p>
        </div>

        <div class="card mb-4">
            <h2 class="mb-2">@L["License.DevTools"]</h2>
            <p>
                @L["License.DevToolsDescPrefix"] <strong>JetBrains Rider Community</strong> @L["License.DevToolsDescSuffix"]
            </p>
        </div>

        <div class="card mb-4">
            <h2 class="mb-2">@L["License.LexicalCredits"]</h2>
            <p>
                @L["License.LexicalCreditsDescPrefix"]
                <strong>Kaikki.org</strong> @L["License.LexicalCreditsDescSuffix"]
            </p>
            <p class="text-muted mt-2">
                @L["License.SourceProject"]
                <a href="https://kaikki.org/" target="_blank" rel="noopener">https://kaikki.org/</a>
            </p>
        </div>

        <div class="card">
            <h2 class="mb-3">@L["License.Dependencies"]</h2>
            <p class="text-muted mb-3">
                @L["License.InventoryNote"]
            </p>

            <div style="overflow-x:auto">
                <table class="lb-table" aria-label="@L["License.DependenciesAria"]">
                    <thead>
                        <tr>
                            <th scope="col">@L["License.Dependency"]</th>
                            <th scope="col">@L["License.License"]</th>
                            <th scope="col">@L["License.Usage"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>.NET / ASP.NET Core / Extensions (Microsoft.*)</td><td>MIT</td><td>@L["License.Usage.DotNet"]</td></tr>
                        <tr><td>Entity Framework Core</td><td>MIT</td><td>@L["License.Usage.EFCore"]</td></tr>
                        <tr><td>Npgsql.EntityFrameworkCore.PostgreSQL</td><td>PostgreSQL License</td><td>@L["License.Usage.Npgsql"]</td></tr>
                        <tr><td>System.IdentityModel.Tokens.Jwt / Microsoft.IdentityModel.Tokens</td><td>MIT</td><td>@L["License.Usage.Jwt"]</td></tr>
                        <tr><td>Serilog.*</td><td>Apache-2.0</td><td>@L["License.Usage.Serilog"]</td></tr>
                        <tr><td>Spectre.Console</td><td>MIT</td><td>@L["License.Usage.Spectre"]</td></tr>
                        <tr><td>xUnit</td><td>Apache-2.0</td><td>@L["License.Usage.Xunit"]</td></tr>
                        <tr><td>xunit.runner.visualstudio</td><td>MIT</td><td>@L["License.Usage.XunitRunner"]</td></tr>
                        <tr><td>FluentAssertions</td><td>Apache-2.0</td><td>@L["License.Usage.FluentAssertions"]</td></tr>
                        <tr><td>Moq</td><td>BSD-3-Clause</td><td>@L["License.Usage.Moq"]</td></tr>
                        <tr><td>coverlet.collector</td><td>MIT</td><td>@L["License.Usage.Coverlet"]</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
