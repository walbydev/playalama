@page "/admin"
@page "/status"
@layout MainLayout
@inject LamaApiClient Api
@inject AuthService Auth
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["Admin.PageTitle"]</PageTitle>

@if (!Auth.IsInitialized)
{
    <div class="section"><div class="container">
        <div class="card" style="max-width:480px; margin:0 auto; text-align:center">
            <span style="font-size:3rem">⏳</span>
            <h3 style="margin:1rem 0 .5rem">@L["Common.Loading"]</h3>
        </div>
    </div></div>
}
else if (!Auth.IsLoggedIn)
{
    <div class="section"><div class="container">
        <div class="card" style="max-width:480px; margin:0 auto; text-align:center">
            <span style="font-size:3rem">🔐</span>
            <h3 style="margin:1rem 0 .5rem">@L["Status.LoginRequired"]</h3>
            <p class="text-muted" style="margin-bottom:1.5rem">@L["Status.LoginText"]</p>
            <a class="btn btn-primary" href="/login">@L["Login.Submit"]</a>
        </div>
    </div></div>
}
else if (!Auth.IsAdmin)
{
    <div class="section"><div class="container">
        <div class="card" style="max-width:480px; margin:0 auto; text-align:center">
            <span style="font-size:3rem">🚫</span>
            <h3 style="margin:1rem 0 .5rem">@L["Status.AccessDenied"]</h3>
            <p class="text-muted" style="margin-bottom:.5rem">@L["Status.AccessDeniedText"]</p>
        </div>
    </div></div>
}
else
{
    <div class="page-hero">
        <div class="eyebrow">@L["Admin.Eyebrow"]</div>
        <h1>🔧 @L["Admin.Title"]</h1>
        <p class="text-muted mt-2">@L["Admin.Subtitle"]</p>
    </div>

    <div class="section">
        <div class="container">

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="form-error" role="alert" style="margin-bottom:1rem">@_error</p>
            }
            @if (!string.IsNullOrEmpty(_success))
            {
                <p class="form-success" role="status" style="margin-bottom:1rem">✅ @_success</p>
            }

            @* ── Onglets ── *@
            <div class="admin-tabs">
                <button class="btn @(_activeTab == "dashboard" ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => SetTab("dashboard"))">
                    📊 @L["Admin.TabDashboard"]
                </button>
                <button class="btn @(_activeTab == "users" ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => SetTab("users"))">
                    👥 @L["Admin.TabUsers"]
                </button>
                <button class="btn @(_activeTab == "games" ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => SetTab("games"))">
                    🎮 @L["Admin.TabGames"]
                </button>
            </div>

            @* ── Section 1: Dashboard ── *@
            @if (_activeTab == "dashboard" && _status is { } s)
            {
                <div class="status-grid">
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🖥️</span>
                            <h3>@L["Status.Server"]</h3>
                            <span class="chip chip-success">@L["Status.Ok"]</span>
                        </div>
                        <div class="status-metrics">
                            <div class="metric"><span class="metric-label">Version</span><span class="metric-value">@s.Server.Version</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.Environment"]</span><span class="metric-value">@s.Server.Environment</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.Uptime"]</span><span class="metric-value">@s.Server.Uptime</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.Memory"]</span><span class="metric-value">@s.Server.MemoryMb MB</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.Threads"]</span><span class="metric-value">@s.Server.ThreadCount</span></div>
                        </div>
                    </div>

                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🎮</span>
                            <h3>@L["Nav.Games"]</h3>
                        </div>
                        <div class="status-metrics">
                            <div class="metric highlight"><span class="metric-label">@L["Admin.ActiveGames"]</span><span class="metric-value big">@s.Games.ActiveCount</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.ActivePlayers"]</span><span class="metric-value">@s.Games.ActivePlayers</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.TotalSessions"]</span><span class="metric-value">@s.History.TotalSessions</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.SessionsToday"]</span><span class="metric-value">@s.History.SessionsToday</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.CompletedTotal"]</span><span class="metric-value">@s.History.TotalCompleted</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.CompletedToday"]</span><span class="metric-value">@s.History.CompletedToday</span></div>
                        </div>
                    </div>

                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">👥</span>
                            <h3>@L["Status.Players"]</h3>
                        </div>
                        <div class="status-metrics">
                            <div class="metric highlight"><span class="metric-label">@L["Admin.TotalRegistered"]</span><span class="metric-value big">@s.Players.TotalRegistered</span></div>
                            <div class="metric"><span class="metric-label">@L["Admin.RegisteredToday"]</span><span class="metric-value">@s.Players.RegisteredToday</span></div>
                        </div>
                    </div>

                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🗄️</span>
                            <h3>@L["Status.Database"]</h3>
                            <span class="chip @DbStatusClass(s.Database.Status)">@s.Database.Status</span>
                        </div>
                        <div class="status-metrics">
                            <div class="metric"><span class="metric-label">@L["Admin.Provider"]</span><span class="metric-value">@s.Database.Provider</span></div>
                            <div class="metric"><span class="metric-label">@L["Status.PendingMigrations"]</span>
                                <span class="metric-value @(s.Database.MigrationPending ? "text-error" : "")">
                                    @(s.Database.MigrationPending ? "⚠️ " + @L["Admin.Yes"] : "✅ " + @L["Admin.No"])
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🤖</span>
                            <h3>@L["Status.AiServer"]</h3>
                            <span class="chip @AiStatusClass(s.AiServer.Status)">@s.AiServer.Status</span>
                        </div>
                        <div class="status-metrics">
                            @if (s.AiServer.Url is not null)
                            {
                                <div class="metric"><span class="metric-label">URL</span><span class="metric-value" style="font-size:.8rem;word-break:break-all">@s.AiServer.Url</span></div>
                            }
                            @if (s.AiServer.ResponseTimeMs.HasValue)
                            {
                                <div class="metric"><span class="metric-label">@L["Admin.Latency"]</span><span class="metric-value">@s.AiServer.ResponseTimeMs ms</span></div>
                            }
                        </div>
                    </div>

                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">⚙️</span>
                            <h3>@L["Status.AdminActions"]</h3>
                        </div>
                        <div class="status-metrics" style="gap:1rem">
                            <div style="display:flex; flex-direction:column; gap:.5rem">
                                <p class="text-muted" style="font-size:.85rem">@L["Admin.TerminateAllDesc"]</p>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="TerminateAllGamesAsync"
                                        disabled="@(_isTerminating || s.Games.ActiveCount == 0)">
                                    @if (_isTerminating)
                                    {
                                        <span>⏳ @L["Status.Terminating"]</span>
                                    }
                                    else
                                    {
                                        <span>🛑 @L["Admin.TerminateAll"] (@s.Games.ActiveCount)</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ── Section 2: Users ── *@
            @if (_activeTab == "users")
            {
                <div class="admin-filters">
                    <button class="btn @(_userFilter is null ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => LoadUsersAsync(null))">@L["Admin.AllUsers"]</button>
                    <button class="btn @(_userFilter == "connected" ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => LoadUsersAsync("connected"))">@L["Admin.ConnectedUsers"]</button>
                    <button class="btn @(_userFilter == "daily" ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => LoadUsersAsync("daily"))">@L["Admin.DailyUsers"]</button>
                    <button class="btn @(_userFilter == "inactive" ? "btn-primary" : "btn-ghost") btn-sm" @onclick="@(() => LoadUsersAsync("inactive"))">@L["Admin.InactiveUsers"]</button>
                    <button class="btn btn-ghost btn-sm" @onclick="LoadUsersAsync" disabled="@_usersLoading">🔄 @L["Game.Refresh"]</button>
                </div>

                @if (_usersLoading)
                {
                    <p class="text-muted text-center" style="padding:2rem">⏳ @L["Common.Loading"]</p>
                }
                else if (_users.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>@L["Admin.Username"]</th>
                                    <th>Email</th>
                                    <th>@L["Admin.Elo"]</th>
                                    <th>@L["Admin.GamesPlayed"]</th>
                                    <th>@L["Admin.Created"]</th>
                                    <th>@L["Admin.LastLogin"]</th>
                                    <th>@L["Admin.Status"]</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in _users)
                                {
                                    <tr>
                                        <td><strong>@u.Username</strong></td>
                                        <td class="text-muted">@(u.Email ?? "—")</td>
                                        <td>@u.EloRating</td>
                                        <td>@u.GamesPlayed</td>
                                        <td>@u.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy")</td>
                                        <td>@(u.LastLoginAt.HasValue ? u.LastLoginAt.Value.LocalDateTime.ToString("dd/MM/yyyy HH:mm") : "—")</td>
                                        <td>
                                            @if (u.IsConnected)
                                            {
                                                <span class="chip chip-success">@L["Admin.Online"]</span>
                                            }
                                            else
                                            {
                                                <span class="chip chip-muted">@L["Admin.Offline"]</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-danger btn-sm"
                                                    @onclick="@(() => DeleteUserAsync(u))"
                                                    disabled="@_usersLoading">
                                                🗑️
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted" style="margin-top:.5rem;font-size:.85rem">@L["Admin.TotalUsers"]: @_users.Count</p>
                }
                else
                {
                    <p class="text-muted text-center" style="padding:2rem">@L["Admin.NoUsers"]</p>
                }
            }

            @* ── Section 3: Games ── *@
            @if (_activeTab == "games")
            {
                <div class="admin-filters">
                    <button class="btn btn-ghost btn-sm" @onclick="LoadGamesAsync" disabled="@_gamesLoading">🔄 @L["Game.Refresh"]</button>
                </div>

                @if (_gamesLoading)
                {
                    <p class="text-muted text-center" style="padding:2rem">⏳ @L["Common.Loading"]</p>
                }
                else if (_games.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>@L["Admin.GameId"]</th>
                                    <th>@L["Admin.Level"]</th>
                                    <th>@L["Admin.Queue"]</th>
                                    <th>@L["Admin.Status"]</th>
                                    <th>@L["Admin.Players"]</th>
                                    <th>@L["Admin.Moves"]</th>
                                    <th>@L["Admin.CreatedGame"]</th>
                                    <th>@L["Admin.Source"]</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in _games)
                                {
                                    <tr>
                                        <td><code style="font-size:.8rem">@g.GameId[..Math.Min(8, g.GameId.Length)]…</code></td>
                                        <td>@g.GameLevel</td>
                                        <td>@g.Queue</td>
                                        <td>
                                            <span class="chip @GameStatusClass(g.Status)">@g.Status</span>
                                        </td>
                                        <td>
                                            @if (g.Players.Count > 0)
                                            {
                                                <div style="display:flex; flex-wrap:wrap; gap:.2rem">
                                                    @foreach (var p in g.Players)
                                                    {
                                                        <span class="chip @(p.IsBot ? "chip-muted" : "chip-accent")" style="font-size:.75rem">
                                                            @(p.IsBot ? "🤖 " : "👤 ")@p.PlayerName
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-dim">—</span>
                                            }
                                        </td>
                                        <td>@g.MoveCount</td>
                                        <td>@g.CreatedAt.LocalDateTime.ToString("dd/MM HH:mm")</td>
                                        <td>
                                            <span class="chip chip-muted">@g.Source</span>
                                        </td>
                                        <td>
                                            <div style="display:flex; gap:.25rem">
                                                @if (g.Source == "memory" && g.Status is "active" or "lobby")
                                                {
                                                    <button class="btn btn-outline btn-sm"
                                                            @onclick="@(() => CloseGameAsync(g))"
                                                            disabled="@_gamesLoading"
                                                            title="@L["Admin.CloseGame"]">
                                                        🛑
                                                    </button>
                                                }
                                                <button class="btn btn-danger btn-sm"
                                                        @onclick="@(() => DeleteGameAsync(g))"
                                                        disabled="@_gamesLoading">
                                                    🗑️
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted" style="margin-top:.5rem;font-size:.85rem">@L["Admin.TotalGames"]: @_games.Count</p>
                }
                else
                {
                    <p class="text-muted text-center" style="padding:2rem">@L["Admin.NoGames"]</p>
                }
            }

        </div>
    </div>
}

@code {
    private string _activeTab = "dashboard";
    private string? _error;
    private string? _success;
    private ServerStatusDto? _status;
    private bool _isTerminating;

    private readonly List<AdminUserDto> _users = [];
    private string? _userFilter;
    private bool _usersLoading;

    private readonly List<AdminGameDto> _games = [];
    private bool _gamesLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Auth.OnAuthStateChanged += OnAuthChanged;
            await LoadDashboardAsync();
            StateHasChanged();
        }
    }

    private async void OnAuthChanged()
    {
        if (Auth.IsAdmin)
            await LoadDashboardAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void SetTab(string tab)
    {
        _activeTab = tab;
        _error = null;
        _success = null;
        if (tab == "users" && _users.Count == 0)
            _ = LoadUsersAsync();
        if (tab == "games" && _games.Count == 0)
            _ = LoadGamesAsync();
        StateHasChanged();
    }

    private async Task LoadDashboardAsync()
    {
        if (!Auth.IsAdmin) return;
        var token = await Auth.GetTokenAsync();
        _status = await Api.GetStatusAsync(token);
        StateHasChanged();
    }

    private async Task LoadUsersAsync(string? filter = null)
    {
        _userFilter = filter;
        _usersLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var token = await Auth.GetTokenAsync();
            var result = await Api.GetAdminUsersAsync(token, filter);
            _users.Clear();
            if (result is not null)
                _users.AddRange(result.Users);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _usersLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadUsersAsync()
    {
        await LoadUsersAsync(_userFilter);
    }

    private async Task DeleteUserAsync(AdminUserDto user)
    {
        _error = null;
        _success = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            var ok = await Api.DeleteAdminUserAsync(token, user.PlayerId);
            if (ok)
            {
                _users.Remove(user);
                _success = $"{user.Username} supprimé.";
            }
            else
            {
                _error = "Échec de la suppression.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task LoadGamesAsync()
    {
        _gamesLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var token = await Auth.GetTokenAsync();
            var result = await Api.GetAdminGamesAsync(token);
            _games.Clear();
            if (result is not null)
                _games.AddRange(result.Games);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _gamesLoading = false;
            StateHasChanged();
        }
    }

    private async Task CloseGameAsync(AdminGameDto game)
    {
        _error = null;
        _success = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            var ok = await Api.CloseAdminGameAsync(token, game.GameId);
            if (ok)
            {
                game = game with { Status = "closed" };
                _success = "Partie fermée.";
            }
            else
            {
                _error = "Échec de la fermeture.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task DeleteGameAsync(AdminGameDto game)
    {
        _error = null;
        _success = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            var ok = await Api.DeleteAdminGameAsync(token, game.GameId);
            if (ok)
            {
                _games.Remove(game);
                _success = "Partie supprimée.";
            }
            else
            {
                _error = "Échec de la suppression.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task TerminateAllGamesAsync()
    {
        _isTerminating = true;
        _error = null;
        StateHasChanged();
        try
        {
            var token = await Auth.GetTokenAsync();
            var count = await Api.TerminateAllGamesAsync(token);
            _success = $"{count} partie(s) terminée(s).";
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isTerminating = false;
            StateHasChanged();
        }
    }

    private static string DbStatusClass(string status) => status switch
    {
        "ok" => "chip-success",
        _ => "chip-muted"
    };

    private static string AiStatusClass(string status) => status switch
    {
        "ok" => "chip-success",
        _ => "chip-muted"
    };

    private static string GameStatusClass(string status) => status switch
    {
        "active" or "lobby" => "chip-success",
        "ended" or "finished_normal" => "chip-muted",
        "abandoned" => "chip-danger",
        "closed" => "chip-muted",
        _ => "chip-muted"
    };

    public async ValueTask DisposeAsync()
    {
        Auth.OnAuthStateChanged -= OnAuthChanged;
        await ValueTask.CompletedTask;
    }
}
