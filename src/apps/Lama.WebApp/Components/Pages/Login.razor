@page "/login"
@layout MainLayout
@inject AuthService Auth
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Login.PageTitle"]</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="text-center mb-3">
            <span style="font-size:2.5rem" aria-hidden="true">🦙</span>
            <h1 class="mt-1">@L["Login.Title"]</h1>
            <p class="text-muted mt-1">@L["Login.Subtitle"]</p>
        </div>

        <EditForm Model="form" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <div class="form-field">
                <label for="username">@L["Auth.Username"]</label>
                <InputText id="username" class="form-field input" @bind-Value="form.Username"
                           autocomplete="username" placeholder="@L["Auth.UsernamePlaceholder"]" />
                <ValidationMessage For="() => form.Username" class="form-error" />
            </div>

            <div class="form-field">
                <label for="password">@L["Auth.Password"]</label>
                <InputText id="password" type="password" @bind-Value="form.Password"
                           autocomplete="current-password" placeholder="••••••" />
                <ValidationMessage For="() => form.Password" class="form-error" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="form-error mb-2" role="alert">@_error</p>
            }

            <button class="btn btn-primary" type="submit" style="width:100%" disabled="@_busy">
                @(_busy ? L["Login.Busy"] : L["Login.Submit"])
            </button>
        </EditForm>

        <p class="text-center text-muted mt-3" style="font-size:.9rem">
            @L["Login.NoAccount"] <a href="/register">@L["Login.Register"]</a>
        </p>

    </div>
</div>

@code {
    private readonly LoginForm form = new();
    private bool _busy;
    private string? _error;
    private string _returnUrl = "/games";

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("returnUrl", out var returnUrlValue) &&
            !string.IsNullOrWhiteSpace(returnUrlValue))
        {
            var candidate = returnUrlValue.ToString();
            if (candidate.StartsWith("/", StringComparison.Ordinal))
                _returnUrl = candidate;
        }

        if (Auth.IsLoggedIn)
            Navigation.NavigateTo(_returnUrl);
    }

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;

        var (success, err) = await Auth.LoginAsync(form.Username, form.Password);

        if (success)
            Navigation.NavigateTo(_returnUrl);
        else
            _error = err ?? L["Login.Failed"];

        _busy = false;
    }
}
