@page "/login"
@layout MainLayout
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Connexion — Playalama</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="text-center mb-3">
            <span style="font-size:2.5rem" aria-hidden="true">🦙</span>
            <h1 class="mt-1">Connexion</h1>
            <p class="text-muted mt-1">Retrouvez vos parties et votre classement.</p>
        </div>

        <EditForm Model="form" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <div class="form-field">
                <label for="username">Pseudo</label>
                <InputText id="username" class="form-field input" @bind-Value="form.Username"
                           autocomplete="username" placeholder="VotreAlias" />
                <ValidationMessage For="() => form.Username" class="form-error" />
            </div>

            <div class="form-field">
                <label for="password">Mot de passe</label>
                <InputText id="password" type="password" @bind-Value="form.Password"
                           autocomplete="current-password" placeholder="••••••" />
                <ValidationMessage For="() => form.Password" class="form-error" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="form-error mb-2" role="alert">@_error</p>
            }

            <button class="btn btn-primary" type="submit" style="width:100%" disabled="@_busy">
                @(_busy ? "Connexion…" : "Se connecter")
            </button>
        </EditForm>

        <p class="text-center text-muted mt-3" style="font-size:.9rem">
            Pas encore de compte ? <a href="/register">S'inscrire</a>
        </p>

        <div style="margin-top:1.5rem; border-top:1px solid var(--border); padding-top:1.25rem">
            <p class="text-center text-dim mb-2" style="font-size:.8rem">Mode test — aucun compte requis</p>
            <button class="btn btn-ghost" style="width:100%; border-color:var(--gold); color:var(--gold)"
                    @onclick="DevLoginAsync" disabled="@_busy">
                ⚡ Connexion rapide (DevJoueur)
            </button>
            @if (!string.IsNullOrWhiteSpace(_devError))
            {
                <p class="form-error mt-1 text-center" role="alert" style="font-size:.8rem">@_devError</p>
            }
        </div>
    </div>
</div>

@code {
    private readonly LoginForm form = new();
    private bool _busy;
    private string? _error;
    private string? _devError;

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Navigation.NavigateTo("/games");
    }

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;

        var (success, err) = await Auth.LoginAsync(form.Username, form.Password);

        if (success)
            Navigation.NavigateTo("/games");
        else
            _error = err ?? "Connexion échouée.";

        _busy = false;
    }

    private async Task DevLoginAsync()
    {
        _busy = true;
        _devError = null;

        var (success, err) = await Auth.DevLoginAsync("DevJoueur");

        if (success)
            Navigation.NavigateTo("/games");
        else
            _devError = err ?? "Connexion dev échouée.";

        _busy = false;
    }
}
