@page "/leaderboard"
@layout MainLayout
@inject LeaderboardViewModel VM
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Leaderboard.PageTitle"]</PageTitle>

<div class="page-hero">
    <div class="eyebrow">@L["Leaderboard.Eyebrow"]</div>
    <h1>🏆 @L["Leaderboard.Title"]</h1>
    <p class="text-muted mt-2">@L["Leaderboard.Subtitle"]</p>
</div>

<div class="section">
    <div class="container">

        <!-- Filtres -->
        <div class="lb-filter" role="group" aria-label="@L["Leaderboard.FiltersAria"]">
            <div class="lb-tabs" role="tablist" aria-label="@L["Leaderboard.ModeAria"]">
                @foreach (var modeEntry in LeaderboardViewModel.Modes)
                {
                    <button class="lb-tab @(VM.SelectedMode == modeEntry.Mode ? "active" : "")"
                            role="tab"
                            aria-selected="@(VM.SelectedMode == modeEntry.Mode)"
                            @onclick="() => SwitchModeAsync(modeEntry.Mode)">
                        @modeEntry.Label
                    </button>
                }
            </div>

            <label class="sr-only" for="country-filter">@L["Leaderboard.FilterCountry"]</label>
            <select id="country-filter"
                    @onchange="OnCountryChangeAsync"
                    aria-label="@L["Leaderboard.FilterCountry"]">
                @foreach (var countryEntry in LeaderboardViewModel.Countries)
                {
                    <option value="@countryEntry.Code" selected="@(VM.SelectedCountry == countryEntry.Code)">@countryEntry.Label</option>
                }
            </select>
        </div>

        @if (VM.IsLoading)
        {
            <p class="text-muted text-center" aria-live="polite" style="padding:3rem">@L["Common.Loading"]</p>
        }
        else if (!string.IsNullOrEmpty(VM.Error))
        {
            <p class="form-error text-center" role="alert">@VM.Error</p>
        }
        else
        {
            <LeaderboardTable Entries="VM.Entries" />
        }

        <div class="flex items-center mt-3 gap-2">
            <div class="live-indicator" aria-live="polite">
                <div class="live-dot" aria-hidden="true"></div>
                @L["Common.LiveUpdated"]
            </div>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await VM.LoadAsync();
            StateHasChanged();
        }
    }

    private async Task SwitchModeAsync(string mode)
    {
        await VM.SwitchModeAsync(mode);
        StateHasChanged();
    }

    private async Task OnCountryChangeAsync(ChangeEventArgs e)
    {
        await VM.FilterByCountryAsync(e.Value?.ToString() ?? "");
        StateHasChanged();
    }
}
