@page "/register"
@layout MainLayout
@inject AuthService Auth
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Register.PageTitle"]</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="text-center mb-3">
            <span style="font-size:2.5rem" aria-hidden="true">🦙</span>
            <h1 class="mt-1">@L["Register.Title"]</h1>
            <p class="text-muted mt-1">@L["Register.Subtitle"]</p>
        </div>

        <EditForm Model="form" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <div class="form-field">
                <label for="reg-username">@L["Auth.Username"] <small class="text-dim">@L["Register.UsernameHint"]</small></label>
                <InputText id="reg-username" @bind-Value="form.Username"
                           autocomplete="username" placeholder="@L["Auth.UsernamePlaceholder"]" />
                <ValidationMessage For="() => form.Username" class="form-error" />
            </div>

            <div class="form-field">
                <label for="reg-email">@L["Auth.Email"] <small class="text-dim">@L["Common.Optional"]</small></label>
                <InputText id="reg-email" type="email" @bind-Value="form.Email"
                           autocomplete="email" placeholder="@L["Auth.EmailPlaceholder"]" />
            </div>

            <div class="form-field">
                <label for="reg-country">@L["Auth.Country"] <small class="text-dim">@L["Common.Optional"]</small></label>
                <InputSelect id="reg-country" @bind-Value="form.CountryCode" class="form-select">
                    <option value="">@L["Auth.Country.Unspecified"]</option>
                    @foreach (var (code, name) in _countries)
                    {
                        <option value="@(code)">@(name)</option>
                    }
                </InputSelect>
            </div>

            <div class="form-field">
                <label for="reg-pwd">@L["Auth.Password"] <small class="text-dim">@L["Register.PasswordHint"]</small></label>
                <InputText id="reg-pwd" type="password" @bind-Value="form.Password"
                           autocomplete="new-password" placeholder="••••••" />
                <ValidationMessage For="() => form.Password" class="form-error" />
            </div>

            <div class="form-field">
                <label for="reg-pwd2">@L["Register.ConfirmPassword"]</label>
                <InputText id="reg-pwd2" type="password" @bind-Value="form.PasswordConfirm"
                           autocomplete="new-password" placeholder="••••••" />
                <ValidationMessage For="() => form.PasswordConfirm" class="form-error" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="form-error mb-2" role="alert">@_error</p>
            }

            <button class="btn btn-primary" type="submit" style="width:100%" disabled="@_busy">
                @(_busy ? L["Register.Busy"] : L["Register.Submit"])
            </button>
        </EditForm>

        <p class="text-center text-muted mt-3" style="font-size:.9rem">
            @L["Register.HasAccount"] <a href="/login">@L["Login.Submit"]</a>
        </p>
    </div>
</div>

@code {
    private readonly RegisterForm form = new();
    private bool _busy;
    private string? _error;

    private static readonly (string Code, string Name)[] _countries =
    [
        ("FR", "🇫🇷 France"),
        ("BE", "🇧🇪 Belgique"),
        ("CH", "🇨🇭 Suisse"),
        ("CA", "🇨🇦 Canada"),
        ("LU", "🇱🇺 Luxembourg"),
        ("MC", "🇲🇨 Monaco"),
        ("SN", "🇸🇳 Sénégal"),
        ("MA", "🇲🇦 Maroc"),
        ("TN", "🇹🇳 Tunisie"),
        ("DZ", "🇩🇿 Algérie"),
        ("CI", "🇨🇮 Côte d'Ivoire"),
        ("CM", "🇨🇲 Cameroun"),
        ("US", "🇺🇸 États-Unis"),
        ("GB", "🇬🇧 Royaume-Uni"),
        ("DE", "🇩🇪 Allemagne"),
        ("ES", "🇪🇸 Espagne"),
        ("IT", "🇮🇹 Italie"),
        ("PT", "🇵🇹 Portugal"),
        ("NL", "🇳🇱 Pays-Bas"),
        ("BR", "🇧🇷 Brésil"),
        ("MX", "🇲🇽 Mexique"),
        ("AR", "🇦🇷 Argentine"),
        ("JP", "🇯🇵 Japon"),
        ("KR", "🇰🇷 Corée du Sud"),
        ("CN", "🇨🇳 Chine"),
        ("IN", "🇮🇳 Inde"),
        ("AU", "🇦🇺 Australie"),
        ("PL", "🇵🇱 Pologne"),
        ("RU", "🇷🇺 Russie"),
        ("UA", "🇺🇦 Ukraine"),
    ];

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Navigation.NavigateTo("/games");
    }

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;

        var countryCode = string.IsNullOrWhiteSpace(form.CountryCode) ? null : form.CountryCode;
        var (success, err) = await Auth.RegisterAsync(form.Username, form.Password, form.Email, countryCode);

        if (success)
            Navigation.NavigateTo("/games");
        else
            _error = err ?? L["Register.Failed"];

        _busy = false;
    }
}
