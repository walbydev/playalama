@page "/status"
@layout MainLayout
@inject StatusViewModel VM
@inject AuthService Auth
@implements IAsyncDisposable

<PageTitle>Monitoring — Playalama</PageTitle>

<div class="page-hero">
    <div class="eyebrow">Administration</div>
    <h1>📊 Tableau de bord</h1>
    <p class="text-muted mt-2">Santé et statistiques de la pile Lama en temps réel.</p>
</div>

<div class="section">
    <div class="container">

        @if (!Auth.IsLoggedIn)
        {
            <div class="card" style="max-width:480px; margin:0 auto; text-align:center">
                <span style="font-size:3rem">🔐</span>
                <h3 style="margin:1rem 0 .5rem">Connexion requise</h3>
                <p class="text-muted" style="margin-bottom:1.5rem">
                    Connectez-vous pour accéder au panneau d'administration.
                </p>
                <a class="btn btn-primary" href="/login">Se connecter</a>
            </div>
        }
        else if (VM.IsLoading && VM.Snapshot is null)
        {
            <p class="text-muted text-center" style="padding:3rem">⏳ Chargement…</p>
        }
        else if (!VM.IsAuthenticated)
        {
            <div class="card" style="max-width:480px; margin:0 auto; text-align:center">
                <span style="font-size:3rem">🚫</span>
                <h3 style="margin:1rem 0 .5rem">Accès refusé</h3>
                <p class="text-muted" style="margin-bottom:.5rem">
                    Votre compte ne dispose pas des droits administrateur,
                    ou votre session a expiré.
                </p>
                @if (!string.IsNullOrEmpty(VM.ErrorMessage))
                {
                    <p class="form-error mt-2" role="alert">@VM.ErrorMessage</p>
                }
                <button class="btn btn-ghost btn-sm mt-3" @onclick="RefreshAsync">🔄 Réessayer</button>
            </div>
        }
        else
        {
            <div class="status-toolbar">
                <div class="flex items-center gap-2">
                    @if (VM.LastRefreshed.HasValue)
                    {
                        <span class="text-muted" style="font-size:.85rem">
                            Mis à jour : @VM.LastRefreshed.Value.LocalDateTime.ToString("HH:mm:ss")
                        </span>
                    }
                    <div class="live-indicator">
                        <div class="live-dot"></div>
                        Auto-refresh 30s
                    </div>
                </div>
                <button class="btn btn-ghost btn-sm" @onclick="RefreshAsync" disabled="@VM.IsLoading">
                    @(VM.IsLoading ? "⏳" : "🔄 Actualiser")
                </button>
            </div>

            @if (!string.IsNullOrEmpty(VM.ErrorMessage))
            {
                <p class="form-error" role="alert" style="margin-bottom:1rem">@VM.ErrorMessage</p>
            }
            @if (!string.IsNullOrEmpty(VM.SuccessMessage))
            {
                <p class="form-success" role="status" style="margin-bottom:1rem">✅ @VM.SuccessMessage</p>
            }

            @if (VM.Snapshot is { } s)
            {
                <div class="status-grid">

                    <!-- Serveur -->
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🖥️</span>
                            <h3>Serveur</h3>
                            <span class="chip chip-success">OK</span>
                        </div>
                        <div class="status-metrics">
                            <div class="metric"><span class="metric-label">Version</span><span class="metric-value">@s.Server.Version</span></div>
                            <div class="metric"><span class="metric-label">Environnement</span><span class="metric-value">@s.Server.Environment</span></div>
                            <div class="metric"><span class="metric-label">Uptime</span><span class="metric-value">@s.Server.Uptime</span></div>
                            <div class="metric"><span class="metric-label">Mémoire</span><span class="metric-value">@s.Server.MemoryMb MB</span></div>
                            <div class="metric"><span class="metric-label">Threads</span><span class="metric-value">@s.Server.ThreadCount</span></div>
                        </div>
                    </div>

                    <!-- Parties -->
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🎮</span>
                            <h3>Parties</h3>
                        </div>
                        <div class="status-metrics">
                            <div class="metric highlight"><span class="metric-label">En cours</span><span class="metric-value big">@s.Games.ActiveCount</span></div>
                            <div class="metric"><span class="metric-label">Joueurs en jeu</span><span class="metric-value">@s.Games.ActivePlayers</span></div>
                            <div class="metric"><span class="metric-label">Sessions totales</span><span class="metric-value">@s.History.TotalSessions</span></div>
                            <div class="metric"><span class="metric-label">Sessions aujourd'hui</span><span class="metric-value">@s.History.SessionsToday</span></div>
                            <div class="metric"><span class="metric-label">Terminées (total)</span><span class="metric-value">@s.History.TotalCompleted</span></div>
                            <div class="metric"><span class="metric-label">Terminées aujourd'hui</span><span class="metric-value">@s.History.CompletedToday</span></div>
                        </div>
                    </div>

                    <!-- Joueurs -->
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">👥</span>
                            <h3>Joueurs</h3>
                        </div>
                        <div class="status-metrics">
                            <div class="metric highlight"><span class="metric-label">Inscrits (total)</span><span class="metric-value big">@s.Players.TotalRegistered</span></div>
                            <div class="metric"><span class="metric-label">Inscrits aujourd'hui</span><span class="metric-value">@s.Players.RegisteredToday</span></div>
                        </div>
                    </div>

                    <!-- Base de données -->
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🗄️</span>
                            <h3>Base de données</h3>
                            <span class="chip @DbStatusClass(s.Database.Status)">@s.Database.Status</span>
                        </div>
                        <div class="status-metrics">
                            <div class="metric"><span class="metric-label">Fournisseur</span><span class="metric-value">@s.Database.Provider</span></div>
                            <div class="metric"><span class="metric-label">Migrations en attente</span>
                                <span class="metric-value @(s.Database.MigrationPending ? "text-error" : "")">
                                    @(s.Database.MigrationPending ? "⚠️ Oui" : "✅ Non")
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- AIServer -->
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">🤖</span>
                            <h3>AIServer</h3>
                            <span class="chip @AiStatusClass(s.AiServer.Status)">@s.AiServer.Status</span>
                        </div>
                        <div class="status-metrics">
                            @if (s.AiServer.Url is not null)
                            {
                                <div class="metric"><span class="metric-label">URL</span><span class="metric-value" style="font-size:.8rem;word-break:break-all">@s.AiServer.Url</span></div>
                            }
                            @if (s.AiServer.Language is not null)
                            {
                                <div class="metric"><span class="metric-label">Langue</span><span class="metric-value">@s.AiServer.Language</span></div>
                            }
                            @if (s.AiServer.ResponseTimeMs.HasValue)
                            {
                                <div class="metric"><span class="metric-label">Latence</span><span class="metric-value">@s.AiServer.ResponseTimeMs ms</span></div>
                            }
                            @if (s.AiServer.Status == "not_configured")
                            {
                                <p class="text-muted" style="font-size:.85rem">LAMA_AI_SERVER_URL non configurée.</p>
                            }
                        </div>
                    </div>

                    <!-- Actions admin -->
                    <div class="card status-card">
                        <div class="status-card-header">
                            <span class="status-card-icon">⚙️</span>
                            <h3>Actions admin</h3>
                        </div>
                        <div class="status-metrics" style="gap:1rem">
                            <div style="display:flex; flex-direction:column; gap:.5rem">
                                <p class="text-muted" style="font-size:.85rem">
                                    Termine immédiatement toutes les parties actives en mémoire
                                    (les joueurs reçoivent un événement <code>game.ended</code>).
                                </p>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => VM.TerminateAllAsync()"
                                        disabled="@(VM.IsTerminating || s.Games.ActiveCount == 0)">
                                    @if (VM.IsTerminating)
                                    {
                                        <span>⏳ Terminaison…</span>
                                    }
                                    else
                                    {
                                        <span>🛑 Terminer toutes les parties (@s.Games.ActiveCount)</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            VM.StateChanged   += OnVmStateChanged;
            Auth.OnAuthStateChanged += OnAuthChanged;
            await VM.LoadAsync();
            VM.StartAutoRefresh(30);
            StateHasChanged();
        }
    }

    private async void OnAuthChanged()
    {
        // Quand l'auth change (InitializeAsync termine), recharge le dashboard
        if (Auth.IsLoggedIn && !VM.IsAuthenticated)
            await VM.LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAsync()
    {
        await VM.LoadAsync();
        StateHasChanged();
    }

    private void OnVmStateChanged() => InvokeAsync(StateHasChanged);

    private static string DbStatusClass(string status) => status switch
    {
        "ok"          => "chip-success",
        "unreachable" => "chip-muted",
        _             => "chip-muted"
    };

    private static string AiStatusClass(string status) => status switch
    {
        "ok"             => "chip-success",
        "not_configured" => "chip-muted",
        _                => "chip-muted"
    };

    public async ValueTask DisposeAsync()
    {
        VM.StateChanged         -= OnVmStateChanged;
        Auth.OnAuthStateChanged -= OnAuthChanged;
        VM.StopAutoRefresh();
        await VM.DisposeAsync();
    }
}
