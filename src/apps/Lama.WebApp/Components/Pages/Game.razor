@page "/games/{GameId}"
@layout MainLayout
@implements IAsyncDisposable
@inject LamaApiClient Api
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Partie @GameId — Playalama</PageTitle>

@if (_vm.Snapshot is null && _vm.IsLoading)
{
    <div class="page-hero">
        <p class="text-muted" aria-live="polite">Chargement de la partie…</p>
    </div>
}
else if (_vm.Snapshot is { UsesLobby: true, HasStarted: false })
{
    @* Redirige vers le lobby si la partie n'a pas encore démarré *@
    <div class="page-hero">
        <p class="text-muted">La partie n'a pas encore démarré. Redirection vers la salle d'attente…</p>
    </div>
}
else
{
    <div class="section" style="padding-top: calc(var(--nav-h) + 1rem)">
        <div class="container">

            @if (!string.IsNullOrWhiteSpace(_vm.Error))
            {
                <p class="form-error mb-3" role="alert">@_vm.Error</p>
            }

            @if (_vm.Snapshot is not null)
            {
                @* En-tête partie *@
                <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
                    <div>
                        <div class="eyebrow">Partie @(_vm.Snapshot.GameName ?? GameId[..Math.Min(8, GameId.Length)] + "…")</div>
                        <h2>Tour @_vm.Snapshot.TurnNumber
                            @if (_vm.Snapshot.IsGameOver)
                            {
                                <span class="chip chip-muted" style="margin-left:.5rem">Terminée</span>
                            }
                            else if (_vm.IsMyTurn)
                            {
                                <span class="chip chip-accent" style="margin-left:.5rem">Votre tour !</span>
                            }
                        </h2>
                    </div>
                    <button class="btn btn-ghost btn-sm" @onclick="RefreshAsync" disabled="@_vm.IsLoading">
                        Rafraîchir
                    </button>
                </div>

                <div class="game-layout">

                    @* ── Colonne gauche : plateau ── *@
                    <div>
                        <h3 class="mb-2">Plateau</h3>
                        <BoardDisplay Board="_vm.Snapshot.Board" GetBonus="_vm.GetCellBonus" />
                    </div>

                    @* ── Colonne droite : sidebar ── *@
                    <div style="display:flex; flex-direction:column; gap:1.25rem">

                        @* Scores *@
                        <div class="card">
                            <h3 class="mb-2">Scores</h3>
                            <ScoreBoard Players="_vm.Snapshot.Players"
                                        CurrentPlayerIndex="_vm.Snapshot.CurrentPlayerIndex"
                                        MyPlayerId="@_myPlayerId" />
                        </div>

                        @* Mon rack *@
                        @if (_vm.MyRack.Count > 0)
                        {
                            <div class="card">
                                <h3 class="mb-2">Mes tuiles @(_vm.IsMyTurn ? "— À vous de jouer !" : "")</h3>
                                <RackDisplay Rack="_vm.MyRack" IsMyTurn="_vm.IsMyTurn" />
                            </div>
                        }

                        @* Panneau d'action *@
                        @if (!_vm.Snapshot.IsGameOver && _vm.IsMyTurn)
                        {
                            <div class="card action-panel">
                                <h3 class="mb-2">Mon action</h3>
                                <EditForm Model="_vm" OnValidSubmit="PlayAsync">
                                    <div class="form-field">
                                        <label for="play-cmd">Commande</label>
                                        <InputSelect id="play-cmd" @bind-Value="_vm.Command">
                                            <option value="play.pass">Passer</option>
                                            <option value="play.move">Poser un mot</option>
                                            <option value="play.swap">Échanger des lettres</option>
                                        </InputSelect>
                                    </div>

                                    @if (_vm.Command == "play.move")
                                    {
                                        <div class="form-field">
                                            <label for="play-pos">Position <small class="text-dim">(ex: H8)</small></label>
                                            <InputText id="play-pos" @bind-Value="_vm.Position" placeholder="H8" />
                                        </div>
                                        <div class="form-field">
                                            <label for="play-word">Mot <small class="text-dim">(minuscule = joker)</small></label>
                                            <InputText id="play-word" @bind-Value="_vm.Word" placeholder="BONJOUR" />
                                        </div>
                                        <div class="form-field">
                                            <label for="play-dir">Direction</label>
                                            <InputSelect id="play-dir" @bind-Value="_vm.Direction">
                                                <option value="H">Horizontal →</option>
                                                <option value="V">Vertical ↓</option>
                                            </InputSelect>
                                        </div>
                                    }

                                    @if (_vm.Command == "play.swap")
                                    {
                                        <div class="form-field">
                                            <label for="play-letters">Lettres à échanger</label>
                                            <InputText id="play-letters" @bind-Value="_vm.Word" placeholder="ABC" />
                                        </div>
                                    }

                                    <button class="btn btn-primary" type="submit" disabled="@_vm.IsLoading" style="width:100%">
                                        @(_vm.IsLoading ? "Envoi…" : "Jouer")
                                    </button>
                                </EditForm>
                            </div>
                        }
                        else if (!_vm.Snapshot.IsGameOver)
                        {
                            <div class="card">
                                <p class="text-muted text-center" aria-live="polite">
                                    En attente du tour de @(_vm.Snapshot.Players.ElementAtOrDefault(_vm.Snapshot.CurrentPlayerIndex)?.PlayerName ?? "…")…
                                </p>
                            </div>
                        }
                        else
                        {
                            <div class="card text-center">
                                <h3 class="mb-2">🏆 Partie terminée !</h3>
                                @{
                                    var winner = _vm.Snapshot.Players.MaxBy(p => p.Score);
                                }
                                @if (winner is not null)
                                {
                                    <p class="text-muted">Vainqueur : <strong>@winner.PlayerName</strong> avec @winner.Score points</p>
                                }
                                <a href="/games" class="btn btn-primary mt-3">Nouvelle partie</a>
                            </div>
                        }

                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string GameId { get; set; } = string.Empty;

    private readonly GamePlayViewModel _vm = new();
    private string? _myPlayerId;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _pollingCts;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var parsed = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _myPlayerId = parsed.TryGetValue("playerId", out var pid)
            ? pid.ToString()
            : Auth.CurrentUser?.PlayerId;

        _vm.Initialize(GameId, _myPlayerId);
        await _vm.LoadAsync(Api);

        // Redirection vers lobby si la partie n'a pas encore démarré
        if (_vm.Snapshot is { UsesLobby: true, HasStarted: false })
        {
            var pidParam = _myPlayerId is not null ? $"?playerId={Uri.EscapeDataString(_myPlayerId)}" : string.Empty;
            Navigation.NavigateTo($"/games/{GameId}/lobby{pidParam}");
            return;
        }

        StartPolling();
    }

    private void StartPolling()
    {
        _pollingCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = Task.Run(async () =>
        {
            while (await _timer.WaitForNextTickAsync(_pollingCts.Token))
                await InvokeAsync(async () =>
                {
                    await _vm.LoadAsync(Api);
                    StateHasChanged();
                });
        }, _pollingCts.Token);
    }

    private async Task RefreshAsync()
    {
        await _vm.LoadAsync(Api);
    }

    private async Task PlayAsync()
    {
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }
        await _vm.PlayAsync(Api, token);
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollingCts is not null) { await _pollingCts.CancelAsync(); _pollingCts.Dispose(); }
        _timer?.Dispose();
    }
}

