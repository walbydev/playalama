    private async Task AbandonAsync()
    {
        _confirmAbandon = false;
        _abandonError = null;
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }

        try
        {
            var isGameOver = await _vm.AbandonAsync(Api, token);
            if (isGameOver)
            {
                Navigation.NavigateTo("/games");
                return;
            }
        }
        catch (UnauthorizedAccessException)
        {
            // Token expiré → déconnexion et redirection
            await Auth.LogoutAsync();
            Navigation.NavigateTo("/login");
            return;
        }

        // En cas d'erreur ou de mode spectateur : forcer un re-render
        if (!string.IsNullOrWhiteSpace(_vm.Error))
        {
            _abandonError = _vm.Error;
        }
        StateHasChanged();
    }

    // ── Export debug (dev seulement) ─────────────────────────────────────────

    private async Task ExportBoardAsync()
    {
        if (_vm.Snapshot is null) return;

        var s = _vm.Snapshot;
        var lines = new System.Text.StringBuilder();

        // ── Ligne 1 : métadonnées ─────────────────────────────────────────
        var meta = new
        {
            type     = "meta",
            gameId   = s.Id,
            gameName = s.GameName,
            turn     = s.TurnNumber,
            lang     = s.Language,
            bag      = s.BagCount,
            isOver   = s.IsGameOver,
            players  = s.Players.Select(p => new { p.PlayerName, p.Score, p.IsBot }),
            current  = s.Players.ElementAtOrDefault(s.CurrentPlayerIndex)?.PlayerName,
            exportedAt = DateTimeOffset.UtcNow.ToString("o")
        };
        lines.AppendLine(System.Text.Json.JsonSerializer.Serialize(meta));

        // ── Construire la grille ──────────────────────────────────────────
        var grid = new char?[15, 15];
        foreach (var t in s.Board)
            grid[t.Row, t.Column] = t.Letter;

        // ── Mots horizontaux ─────────────────────────────────────────────
        for (var row = 0; row < 15; row++)
        {
            var col = 0;
            while (col < 15)
            {
                if (grid[row, col] is not null)
                {
                    var start = col;
                    while (col < 15 && grid[row, col] is not null) col++;
                    if (col - start >= 2)
                    {
                        var word = new string(Enumerable.Range(start, col - start)
                            .Select(c => grid[row, c]!.Value).ToArray());
                        lines.AppendLine(System.Text.Json.JsonSerializer.Serialize(
                            new { type = "word", word, row, col = start, dir = "H" }));
                    }
                }
                else col++;
            }
        }

        // ── Mots verticaux ────────────────────────────────────────────────
        for (var col = 0; col < 15; col++)
        {
            var row = 0;
            while (row < 15)
            {
                if (grid[row, col] is not null)
                {
                    var start = row;
                    while (row < 15 && grid[row, col] is not null) row++;
                    if (row - start >= 2)
                    {
                        var word = new string(Enumerable.Range(start, row - start)
                            .Select(r => grid[r, col]!.Value).ToArray());
                        lines.AppendLine(System.Text.Json.JsonSerializer.Serialize(
                            new { type = "word", word, row = start, col, dir = "V" }));
                    }
                }
                else row++;
            }
        }

        await JS.InvokeVoidAsync("playalamaDebug.copyToClipboard", lines.ToString());

        _exportCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _exportCopied = false;
        StateHasChanged();
    }

    private async Task LoadPlayerLevelsAsync()
    {
        try
        {
            var players = _vm.Snapshot?.Players;
            if (players is null || players.Count == 0) return;

            var labels = new Dictionary<string, string>();
            foreach (var p in players)
            {
                if (p.IsBot || string.IsNullOrWhiteSpace(p.PlayerId)) continue;
                var rating = await Api.GetPlayerRatingAsync(p.PlayerId);
                if (rating is not null)
                    labels[p.PlayerId] = rating.LevelName;
            }

            if (labels.Count > 0)
            {
                _playerLevelLabels = labels;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Best-effort : pas critique si la requête échoue
        }
    }

    public async ValueTask DisposeAsync()
    {
        Layout.Changed -= HandleLayoutChanged;
        if (_pollingCts is not null) { await _pollingCts.CancelAsync(); _pollingCts.Dispose(); }
        if (_uiCts is not null) { await _uiCts.CancelAsync(); _uiCts.Dispose(); }
        _timer?.Dispose();
        _uiTimer?.Dispose();
    }
