@page "/games/{GameId}"
@layout MainLayout
@implements IAsyncDisposable
@inject LamaApiClient Api
@inject AuthService Auth
@inject NavigationManager Navigation
@inject GameLayoutService Layout
@inject DensityService Density
@inject IStringLocalizer<SharedResource> L
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IJSRuntime JS
@inject ScreenReaderAnnouncer Announcer

<PageTitle>@L["Game.PageTitle", GameId]</PageTitle>

@if (_vm.Snapshot is null && _vm.IsLoading)
{
    <div class="page-hero">
        <p class="text-muted" aria-live="polite">@L["Game.Loading"]</p>
    </div>
}
else if (_vm.Snapshot is null && !string.IsNullOrWhiteSpace(_vm.Error))
{
    <div class="page-hero">
        <div class="card text-center" style="max-width:420px; margin:2rem auto">
            <h3 class="mb-2">🔌 @L["Game.End.NotFoundTitle"]</h3>
            <p class="text-dim mb-3" style="font-size:.9rem">@L["Game.End.NotFoundMessage"]</p>
            <a href="/games" class="btn btn-primary">@L["Game.NewGame"]</a>
        </div>
    </div>
}
else if (_vm.Snapshot is { UsesLobby: true, HasStarted: false })
{
    @* Redirige vers le lobby si la partie n'a pas encore démarré *@
    <div class="page-hero">
        <p class="text-muted">@L["Game.RedirectLobby"]</p>
    </div>
}
else
{
    <div class="section game-page" style="padding-top: calc(var(--nav-h) + 1rem)">
        <div class="container">

            @if (_vm.Snapshot is not null)
            {
                @* ── En-tête principal : titre + sac + actions ── *@
                <div class="game-header mb-3">
                    <div class="game-header-left">
                        <div class="game-title">@(_vm.Snapshot.GameName ?? GameId[..Math.Min(8, GameId.Length)] + "…")</div>
                        <div class="game-subtitle flex items-center gap-2 flex-wrap">
                            <span>@L["Game.Turn", _vm.Snapshot.TurnNumber]</span>
                            @if (_vm.Snapshot.IsGameOver)
                            {
                                <span class="chip chip-muted">@L["Game.Status.Finished"]</span>
                            }
                            else if (_vm.IsObserver)
                            {
                                <span class="chip" style="background:rgba(120,120,120,.18); color:var(--text-dim)">@L["Game.Status.Observer"]</span>
                            }
                            else if (_vm.IsMyTurn)
                            {
                                <span class="chip chip-accent">@L["Game.Status.YourTurn"]</span>
                            }
                        </div>
                    </div>

                    <div class="letter-bag-display" title="@L["Game.BagTitle"]">
                        <span class="letter-bag-icon">🎒</span>
                        <span class="letter-bag-count">@_vm.Snapshot.BagCount</span>
                        <span class="letter-bag-label">@(_vm.Snapshot.BagCount > 1 ? L["Game.Letters.Plural"] : L["Game.Letters.Singular"])</span>
                        <span class="letter-bag-langs">
                            @foreach (var l in GetGameLanguages())
                            {
                                <span class="lang-tag">@LanguageFlag(l)</span>
                            }
                        </span>
                    </div>

                    <div class="game-header-right">
                        <button class="btn btn-ghost btn-sm" @onclick="RefreshAsync" disabled="@_vm.IsLoading">
                            @L["Game.Refresh"]
                        </button>
                        @if (_vm.IsObserver || _vm.Snapshot!.IsGameOver)
                        {
                            <a href="/games" class="btn btn-ghost btn-sm">← @L["Game.Leave"]</a>
                        }
                        else if (_vm.Snapshot.HasStarted)
                        {
                            @if (_confirmAbandon)
                            {
                                <span class="text-dim" style="font-size:.85rem">@L["Game.Confirm"]</span>
                                <button class="btn btn-danger btn-sm" @onclick="AbandonAsync" disabled="@_vm.IsLoading">
                                    ✔ @L["Game.AbandonConfirmYes"]
                                </button>
                                <button class="btn btn-ghost btn-sm" @onclick="() => _confirmAbandon = false">
                                    @L["Game.Cancel"]
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-ghost btn-sm" style="color:var(--danger,#e55)" @onclick="() => _confirmAbandon = true">
                                    🏳 @L["Game.Abandon"]
                                </button>
                            }
                        }
                        @* ── Groupe info (Tour · Nom · Export) — poussé à droite ── *@
                        <div class="game-header-info">
                            <span class="game-turn-label">@L["Game.Turn", _vm.Snapshot.TurnNumber]</span>
                            <span class="game-name-label" title="@L["Game.GameName"]">
                                @(_vm.Snapshot.GameName ?? GameId[..Math.Min(8, GameId.Length)] + "…")
                            </span>
                            <button class="btn btn-ghost btn-sm debug-export-btn"
                                    title="@(_exportCopied ? "✓ Copié !" : "Copier le plateau (JSONL)")"
                                    @onclick="ExportBoardAsync">
                                @(_exportCopied ? "✓" : "📋")
                            </button>
                        </div>
                    </div>
                </div>

                @* ── Actions compactes (mode focus / auto) ── *@
                <div class="card game-focus-actions">
                    <button class="btn btn-ghost btn-sm" @onclick="RefreshAsync" disabled="@_vm.IsLoading">
                        @L["Game.Refresh"]
                    </button>
                    <div class="letter-bag-display letter-bag-display--compact" title="@L["Game.BagTitle"]">
                        <span class="letter-bag-icon">🎒</span>
                        <span class="letter-bag-count">@_vm.Snapshot.BagCount</span>
                        <span class="letter-bag-langs">
                            @foreach (var l in GetGameLanguages())
                            {
                                <span class="lang-tag">@LanguageFlag(l)</span>
                            }
                        </span>
                    </div>

                    @if (_vm.IsObserver || _vm.Snapshot!.IsGameOver)
                    {
                        <a href="/games" class="btn btn-ghost btn-sm">← @L["Game.Leave"]</a>
                    }
                    else if (_vm.Snapshot.HasStarted)
                    {
                        @if (_confirmAbandon)
                        {
                            <span class="text-dim" style="font-size:.85rem">@L["Game.Confirm"]</span>
                            <button class="btn btn-danger btn-sm" @onclick="AbandonAsync" disabled="@_vm.IsLoading">
                                ✔ @L["Game.AbandonConfirmYes"]
                            </button>
                            <button class="btn btn-ghost btn-sm" @onclick="() => _confirmAbandon = false">
                                @L["Game.Cancel"]
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-ghost btn-sm" style="color:var(--danger,#e55)" @onclick="() => _confirmAbandon = true">
                                🏳 @L["Game.Abandon"]
                            </button>
                        }
                    }

                    <div class="game-header-info">
                        <span class="game-focus-title">@L["Game.Turn", _vm.Snapshot.TurnNumber] — @(_vm.Snapshot.GameName ?? GameId[..Math.Min(8, GameId.Length)] + "…")</span>
                        <button class="btn btn-ghost btn-sm debug-export-btn"
                                title="@(_exportCopied ? "✓ Copié !" : "Copier le plateau (JSONL)")"
                                @onclick="ExportBoardAsync">
                            @(_exportCopied ? "✓" : "📋")
                        </button>
                    </div>
                </div>

                @* ── Bandeau spectateur ── *@
                @if (_vm.IsObserver)
                {
                    <div class="spectator-banner" role="status" aria-live="polite">
                        🔍 @L["Game.SpectatorBanner"] <a href="/games">@L["Game.Leave"] →</a>
                    </div>
                }

                <div class="game-layout"
                     style="--board-scale:@Layout.ScaleCss;"
                     data-variant="@Layout.Variant"
                     data-help-open="@(_vm.SuggestPanelOpen ? "true" : "false")">

                    @* ── Zone plateau (+ rack selon variante D) ── *@
                    <div class="game-board-area @(_vm.KeyboardModeActive ? "kbd-active" : "")"
                         tabindex="@(_vm.IsMyTurn ? "0" : null)"
                         role="application"
                         aria-label="@L["Board.Aria"]"
                         @ref="_boardAreaRef"
                         @onkeydown="HandleBoardKeyDown"
                         @onfocus="OnBoardFocus">

                        @if (_vm.IsMyTurn && !_vm.IsAbandoned)
                        {
                            <HowToPlayStrip />
                            @if (ShowFirstMoveHint)
                            {
                                <div class="first-move-hint" role="status">
                                    <span class="first-move-arrow" aria-hidden="true">↓</span>
                                    <span>@L["Game.FirstMoveHint"]</span>
                                </div>
                            }
                        }

                        <BoardDisplay Board="_vm.Snapshot.Board"
                                      GetBonus="_vm.GetCellBonus"
                                      Pending="_vm.PendingPlacements"
                                      CanDrop="@(_vm.IsMyTurn && (_draggingRackIndex >= 0 || _draggingPendingPos.HasValue || _selectedRackIndex >= 0))"
                                      CanDragPending="_vm.IsMyTurn"
                                      CanActivateKeyboard="@_vm.IsMyTurn"
                                      DraggingFromBoard="_draggingPendingPos.HasValue"
                                      KeyboardModeActive="_vm.KeyboardModeActive"
                                      KeyboardCursorRow="_vm.KeyboardCursorRow"
                                      KeyboardCursorCol="_vm.KeyboardCursorCol"
                                      KeyboardIsHorizontal="_vm.KeyboardIsHorizontal"
                                      HasSelectedRackTile="@(_selectedRackIndex >= 0)"
                                      OnDrop="HandleDrop"
                                      OnRecall="HandleRecall"
                                      OnTileClick="HandleTileClick"
                                      OnKeyboardActivate="HandleKeyboardActivate"
                                      OnPendingDragStart="HandlePendingDragStart"
                                      OnWordSelected="HandleWordSelected" />
                    </div>

                    @* ── Zone rack (positionnée selon la variante) ── *@
                    <div class="game-rack-area">
                        @* Rack — ligne unique *@
                        @if (_vm.MyRack.Count > 0 && !_vm.IsAbandoned && !_vm.Snapshot!.IsGameOver)
                        {
                            <div class="card rack-below-board">
                                <div class="rack-below-header">
                                    <div class="rack-title-row">
                                        <h3>@L["Game.MyTiles"] <InfoTooltip Text="@L["Tooltip.RackTile"].Value" Icon="ℹ" Position="right" /></h3>
                                        @if (_vm.IsMyTurn && _vm.PendingPlacements.Count == 0 && ShowFirstMoveHint)
                                        {
                                            <span class="rack-hint-text">@L["Game.RackHint"]</span>
                                        }
                                        @if (_vm.IsMyTurn && _vm.PendingPlacements.Count > 0)
                                        {
                                            <button class="btn btn-ghost btn-sm rack-recall-btn"
                                                    @onclick="() => { _vm.RecallAll(); StateHasChanged(); }"
                                                    title="@L["Game.RecallAll.Title"]">
                                                ↩ @L["Game.RecallAll"]
                                            </button>
                                        }
                                    </div>
                                    @if (_vm.PendingPlacements.Count > 0)
                                    {
                                        <div style="display:flex; gap:.5rem; flex-wrap:wrap; align-items:center">
                                            <button class="btn btn-ghost btn-sm"
                                                    @onclick="CheckMoveAsync"
                                                    disabled="@(_vm.IsCheckLoading || _vm.IsLoading)"
                                                    title="@L["Game.Check.Title"]">
                                                @(_vm.IsCheckLoading ? "…" : $"🔍 {L["Game.Check"]}")
                                            </button>
                                            <button class="btn btn-primary btn-sm" @onclick="PlayDragMoveAsync"
                                                    disabled="@(_vm.IsLoading || _vm.PendingPlacements.Any(p => p.IsJoker && p.Letter == '*'))">
                                                ✔ @L["Game.Validate"] (@_vm.PendingPlacements.Count @(_vm.PendingPlacements.Count > 1 ? L["Game.Tiles.Plural"] : L["Game.Tiles.Singular"]))
                                            </button>
                                        </div>
                                    }
                                </div>
                                <RackDisplay Rack="_vm.MyRack"
                                             DisplayOrder="@_rackOrder"
                                             IsMyTurn="_vm.IsMyTurn"
                                             UsedIndices="@(_vm.PendingPlacements.Count > 0 ? GetUsedIndices() : [])"
                                             SelectedRackIndex="_selectedRackIndex"
                                             OnDragStart="HandleDragStart"
                                             OnTileClick="HandleRackTileClick"
                                             OnRackReorder="HandleRackReorder" />
                                @if (_vm.PendingPlacements.Any(p => p.IsJoker && p.Letter == '*'))
                                {
                                    <p class="form-error mt-1" style="font-size:.8rem">@L["Game.JokerAssignHint"]</p>
                                }
                            </div>
                        }
                    </div>

                    @* ── Colonne droite : sidebar (scores + actions) ── *@
                    <div class="game-sidebar" data-active-tab="@Layout.ActiveTab">

                        @* Rack latéral (thème compact uniquement) — au-dessus des scores *@
                        @if (_vm.MyRack.Count > 0 && !_vm.IsAbandoned && !_vm.Snapshot!.IsGameOver)
                        {
                            <div class="card game-sidebar-rack">
                                <div class="rack-side-header">
                                    <h3>@L["Game.MyTiles"] <InfoTooltip Text="@L["Tooltip.RackTile"].Value" Icon="ℹ" Position="right" /></h3>
                                    @if (_vm.IsMyTurn && _vm.PendingPlacements.Count > 0)
                                    {
                                        <button class="btn btn-ghost btn-sm rack-recall-btn"
                                                @onclick="() => { _vm.RecallAll(); StateHasChanged(); }"
                                                title="@L["Game.RecallAll.Title"]">
                                            ↩
                                        </button>
                                    }
                                </div>
                                <RackDisplay Rack="_vm.MyRack"
                                             DisplayOrder="@_rackOrder"
                                             IsMyTurn="_vm.IsMyTurn"
                                             UsedIndices="@(_vm.PendingPlacements.Count > 0 ? GetUsedIndices() : [])"
                                             SelectedRackIndex="_selectedRackIndex"
                                             OnDragStart="HandleDragStart"
                                             OnTileClick="HandleRackTileClick"
                                             OnRackReorder="HandleRackReorder" />
                                @if (_vm.PendingPlacements.Count > 0)
                                {
                                    <div class="rack-side-actions">
                                        <button class="btn btn-ghost btn-sm"
                                                @onclick="CheckMoveAsync"
                                                disabled="@(_vm.IsCheckLoading || _vm.IsLoading)"
                                                title="@L["Game.Check.Title"]">
                                            @(_vm.IsCheckLoading ? "…" : $"🔍 {L["Game.Check"]}")
                                        </button>
                                        <button class="btn btn-primary rack-side-validate" @onclick="PlayDragMoveAsync"
                                                disabled="@(_vm.IsLoading || _vm.PendingPlacements.Any(p => p.IsJoker && p.Letter == '*'))">
                                            ✔ @L["Game.Validate"] (@_vm.PendingPlacements.Count)
                                        </button>
                                    </div>
                                }
                                @if (_vm.PendingPlacements.Any(p => p.IsJoker && p.Letter == '*'))
                                {
                                    <p class="form-error mt-1" style="font-size:.8rem">@L["Game.JokerAssignHint"]</p>
                                }
                            </div>
                        }

                        @* Scores *@
                        <div class="card sidebar-panel" data-tab="scores">
                            <h3 class="mb-2">@L["Game.Scores"]</h3>
                            <ScoreBoard Players="_vm.Snapshot.Players"
                                        CurrentPlayerIndex="_vm.Snapshot.CurrentPlayerIndex"
                                        MyPlayerId="@_myPlayerId"
                                        TimePerPlayerSeconds="_vm.Snapshot.TimePerPlayerSeconds"
                                        TurnStartAt="_vm.Snapshot.TurnStartAt"
                                        AbandonedPlayerIds="_vm.Snapshot.AbandonedPlayerIds"
                                        PlayerLevelLabels="_playerLevelLabels" />
                        </div>

                        <div class="card game-messages-panel sidebar-panel" data-tab="messages">
                            <h3 class="mb-2">@L["Game.Messages"]</h3>
                            @if (_turnNotice is not null)
                            {
                                <div class="abandon-notice" role="status" aria-live="polite">
                                    🔔 @_turnNotice
                                    <button class="abandon-notice-close" @onclick="() => _turnNotice = null" aria-label="@L["Common.Close"]">✕</button>
                                </div>
                            }
                            @if (_abandonNotice is not null)
                            {
                                <div class="abandon-notice" role="alert" aria-live="polite">
                                    ⚠️ @_abandonNotice
                                    <button class="abandon-notice-close" @onclick="() => _abandonNotice = null" aria-label="@L["Common.Close"]">✕</button>
                                </div>
                            }
                            @if (_vm.CheckScore.HasValue)
                            {
                                <div class="move-check-inline" role="status" aria-live="polite">
                                    ✅ @_vm.CheckMessage
                                    <button class="btn-icon-close" @onclick="() => { _vm.ClearCheck(); StateHasChanged(); }" aria-label="@L["Common.Close"]">✕</button>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_vm.Error))
                            {
                                <div class="move-error-inline" role="alert" aria-live="assertive">
                                    ⚠️ @_vm.Error
                                    <button class="btn-icon-close" @onclick="() => { _vm.ClearError(); StateHasChanged(); }" aria-label="@L["Common.Close"]">✕</button>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_abandonError))
                            {
                                <div class="move-error-inline" role="alert" aria-live="assertive">
                                    ⚠️ @_abandonError
                                    <button class="btn-icon-close" @onclick="() => _abandonError = null" aria-label="@L["Common.Close"]">✕</button>
                                </div>
                            }
                            @if (_vm.SuggestionsUsed)
                            {
                                <div class="abandon-notice" role="status" aria-live="polite">
                                    ⚠️ @L["Game.SuggestionsUsedNotice"]
                                </div>
                            }
                            @if (!HasAnyUiMessages)
                            {
                                <p class="text-dim" style="font-size:.85rem; margin:0">@L["Game.NoMessages"]</p>
                            }
                        </div>

                        @* Panneau d'action (masqué en mode spectateur) *@
                        @if (!_vm.Snapshot.IsGameOver && _vm.IsMyTurn && !_vm.IsAbandoned)
                        {
                            <div class="card action-panel sidebar-panel" data-tab="play">
                                <h3 class="mb-2">@L["Game.OtherActions"]</h3>
                                <div class="action-buttons">
                                    <button class="btn btn-primary btn-sm"
                                            @onclick="PlayPendingAsync"
                                            disabled="@(_vm.IsLoading || _vm.PendingPlacements.Count == 0 || _vm.PendingPlacements.Any(p => p.IsJoker && p.Letter == '*'))">
                                        ✔ @L["Game.Play"]
                                    </button>
                                    <button class="btn btn-ghost btn-sm"
                                            @onclick="PassTurnAsync"
                                            disabled="@_vm.IsLoading">
                                        ⏭ @L["Game.Command.Pass"]
                                    </button>
                                </div>
                                <div class="action-swap">
                                    <label style="display:flex; align-items:center; gap:.5rem; cursor:pointer">
                                        <input type="checkbox" @bind="_swapAll" style="width:1rem;height:1rem" />
                                        <span>@L["Game.SwapAll"]</span>
                                    </label>
                                    @if (!_swapAll)
                                    {
                                        <InputText @bind-Value="_swapLetters" placeholder="ABC" />
                                    }
                                    <button class="btn btn-outline btn-sm"
                                            @onclick="SwapLettersAsync"
                                            disabled="@(_vm.IsLoading || (!_swapAll && string.IsNullOrWhiteSpace(_swapLetters)))">
                                        🔄 @L["Game.Command.Swap"]
                                    </button>
                                </div>
                            </div>

                            @* ── Suggestions (Aide-moi) ── *@
                            <div class="card suggest-panel sidebar-panel" data-tab="play">
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:.5rem">
                                    <h3 style="margin:0">💡 @L["Game.HelpMe"]</h3>
                                    @if (_vm.SuggestPanelOpen)
                                    {
                                        <button class="btn-icon-close" @onclick="() => { _vm.CloseSuggestPanel(); StateHasChanged(); }" aria-label="@L["Common.Close"]">✕</button>
                                    }
                                </div>

                                @if (!_vm.SuggestPanelOpen)
                                {
                                    <button class="btn btn-ghost btn-sm" @onclick="SuggestMovesAsync"
                                            disabled="@_vm.IsSuggestLoading" style="width:100%">
                                        @(_vm.IsSuggestLoading ? $"⏳ {L["Game.Suggest.Calculating"]}" : $"🔍 {L["Game.Suggest.Button"]}")
                                    </button>
                                }
                                else if (_vm.IsSuggestLoading)
                                {
                                    <p class="text-dim text-center" style="font-size:.85rem">⏳ @L["Game.Suggest.Searching"]</p>
                                }
                                else if (!string.IsNullOrWhiteSpace(_vm.SuggestError))
                                {
                                    <p class="form-error" role="alert">⚠️ @_vm.SuggestError</p>
                                    <button class="btn btn-ghost btn-sm" @onclick="SuggestMovesAsync" style="width:100%">↺ @L["Game.Retry"]</button>
                                }
                                else if (_vm.Suggestions.Count == 0)
                                {
                                    <p class="text-dim text-center" style="font-size:.85rem">@L["Game.Suggest.None"]</p>
                                    <button class="btn btn-ghost btn-sm" @onclick="SuggestMovesAsync" style="width:100%">↺ @L["Game.Retry"]</button>
                                }
                                else
                                {
                                    var scoreList = _vm.Suggestions.Where(s => s.Category == "score").ToList();
                                    var lengthList = _vm.Suggestions.Where(s => s.Category == "length").ToList();

                                    @if (scoreList.Count > 0)
                                    {
                                        <div class="suggest-section">
                                            <p class="suggest-section-title">📊 @L["Game.Suggest.BestScores"]</p>
                                            @foreach (var s in scoreList)
                                            {
                                                <div class="suggest-item">
                                                    <div class="suggest-item-info">
                                                        <span class="suggest-word">@s.Word</span>
                                                        <span class="suggest-meta">@L["Game.Suggest.Meta", s.Position, (s.Direction == "H" ? "→" : "↓"), s.Score, s.Length]</span>
                                                    </div>
                                                    <button class="btn btn-ghost btn-sm suggest-use-btn"
                                                            @onclick="() => ApplySuggestionToBoard(s)"
                                                            title="@L["Game.Suggest.Use.Title"]">
                                                        ▶ @L["Game.Suggest.Use"]
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (lengthList.Count > 0)
                                    {
                                        <div class="suggest-section">
                                            <p class="suggest-section-title">📏 @L["Game.Suggest.LongestWords"]</p>
                                            @foreach (var s in lengthList)
                                            {
                                                <div class="suggest-item">
                                                    <div class="suggest-item-info">
                                                        <span class="suggest-word">@s.Word</span>
                                                        <span class="suggest-meta">@L["Game.Suggest.Meta", s.Position, (s.Direction == "H" ? "→" : "↓"), s.Score, s.Length]</span>
                                                    </div>
                                                    <button class="btn btn-ghost btn-sm suggest-use-btn"
                                                            @onclick="() => ApplySuggestionToBoard(s)"
                                                            title="@L["Game.Suggest.Use.Title"]">
                                                        ▶ @L["Game.Suggest.Use"]
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }

                                     <button class="btn btn-ghost btn-sm" @onclick="SuggestMovesAsync" style="width:100%; margin-top:.5rem; font-size:.8rem">
                                        ↺ @L["Game.Suggest.Refresh"]
                                    </button>
                                }

                            </div>
                        }
                        else if (!_vm.Snapshot.IsGameOver && !_vm.IsAbandoned)
                        {
                            <div class="card sidebar-panel" data-tab="play">
                                <p class="text-muted text-center" aria-live="polite">
                                    ⏳ @L["Game.WaitingTurn", (_vm.Snapshot.Players.ElementAtOrDefault(_vm.Snapshot.CurrentPlayerIndex)?.PlayerName ?? "…")]
                                </p>
                            </div>
                        }
                        else if (_vm.Snapshot.IsGameOver)
                        {
                            @* ── Écran de fin de partie ── *@
                            <div class="card text-center sidebar-panel" data-tab="play">
                                @if (string.Equals(_vm.Snapshot.EndReason, "server_restart", StringComparison.Ordinal))
                                {
                                    <h3 class="mb-1">🔌 @L["Game.End.ServerRestartTitle"]</h3>
                                    <p class="text-dim mb-3" style="font-size:.9rem">@L["Game.End.ServerRestartMessage"]</p>
                                    @if (_abandonRedirectCountdown > 0)
                                    {
                                        <p class="text-dim" style="font-size:.85rem">@L["Game.End.RedirectIn", _abandonRedirectCountdown]</p>
                                    }
                                }
                                else if (string.Equals(_vm.Snapshot.EndReason, "abandoned", StringComparison.Ordinal))
                                {
                                    <h3 class="mb-1">🏳 @L["Game.End.AbandonedTitle"]</h3>
                                    <p class="text-dim mb-3" style="font-size:.9rem">@L["Game.End.AbandonedBy", _vm.Snapshot.AbandonedByName ?? L["Game.UnknownPlayer"].Value]</p>
                                    @if (_abandonRedirectCountdown > 0)
                                    {
                                        <p class="text-dim" style="font-size:.85rem">@L["Game.End.RedirectIn", _abandonRedirectCountdown]</p>
                                    }
                                }
                                else
                                {
                                    <h3 class="mb-3">🏆 @L["Game.End.FinishedTitle"]</h3>
                                }
                                @{
                                    var ranked = _vm.Snapshot.Players.OrderByDescending(p => p.Score).ToList();
                                    var medals = new[] { "🥇", "🥈", "🥉" };
                                }
                                <table style="width:100%; border-collapse:collapse; margin-bottom:1rem">
                                    <thead>
                                        <tr style="border-bottom:1px solid var(--border); color:var(--text-dim); font-size:.8rem">
                                            <th style="padding:.4rem; text-align:left">@L["Game.Rank"]</th>
                                            <th style="padding:.4rem; text-align:left">@L["Game.Player"]</th>
                                            <th style="padding:.4rem; text-align:right">@L["Game.Score"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < ranked.Count; i++)
                                        {
                                            var p = ranked[i];
                                            var medal = i < medals.Length ? medals[i] : $"{i + 1}.";
                                            var isMe = string.Equals(p.PlayerId, _vm.MyPlayerId, StringComparison.Ordinal);
                                            <tr style="border-bottom:1px solid var(--border); @(isMe ? "background:var(--bg2); font-weight:600" : "")">
                                                <td style="padding:.5rem">@medal</td>
                                                <td style="padding:.5rem; text-align:left">@p.PlayerName @(isMe ? $"({L["Game.You"]})" : "")</td>
                                                <td style="padding:.5rem; text-align:right; font-variant-numeric:tabular-nums">@L["Game.Points", p.Score]</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <a href="/games" class="btn btn-primary">@L["Game.NewGame"]</a>
                            </div>
                        }

                        @* ── Dictionnaire (toujours disponible : observateur, partie terminée, en attente, mon tour) ── *@
                        <div class="card suggest-panel sidebar-panel" data-tab="play">
                            <div class="suggest-section dictionary-search">
                                <p class="suggest-section-title">📚 @L["Game.Dictionary.Title"]</p>
                                @{
                                    var dictLangsAlways = GetGameLanguages();
                                }
                                @if (dictLangsAlways.Count > 1)
                                {
                                    <div class="dict-lang-selector">
                                        @foreach (var l in dictLangsAlways)
                                        {
                                            <button type="button"
                                                    class="lang-choice-btn @(_dictLang == l ? "is-selected" : "")"
                                                    @onclick="() => _dictLang = l">
                                                <span class="lang-choice-mark">@LanguageFlag(l)</span>
                                                @l.ToUpperInvariant()
                                            </button>
                                        }
                                    </div>
                                }
                                <form class="dictionary-search-form" @onsubmit="SearchDictionaryAsync" @onsubmit:preventDefault="true">
                                    <InputText @bind-Value="_dictionaryQuery"
                                               placeholder="@L["Game.Dictionary.Placeholder"]"
                                               class="dictionary-search-input" />
                                    <button type="submit" class="btn btn-ghost btn-sm" disabled="@_dictionarySearchLoading">
                                        @(_dictionarySearchLoading ? "…" : L["Game.Dictionary.Search"])
                                    </button>
                                </form>

                                @if (!string.IsNullOrWhiteSpace(_dictionarySearchError))
                                {
                                    <p class="form-error" role="alert">⚠️ @_dictionarySearchError</p>
                                }
                                else if (_dictionarySearchDone && _dictionaryResults.Count == 0)
                                {
                                    <p class="text-dim" style="font-size:.8rem">@L["Game.Dictionary.None"]</p>
                                }
                                else if (_dictionaryResults.Count > 0)
                                {
                                    <div class="dictionary-search-results">
                                        @foreach (var word in _dictionaryResults)
                                        {
                                            <button type="button"
                                                    class="btn btn-ghost btn-sm dictionary-word-btn"
                                                    @onclick="() => ShowWordInfoAsync(word)">
                                                @word
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                    </div>

                    @* ── Popup définition (overlay modal) ── *@
                    @if (_wordInfo is not null)
                    {
                        <div class="word-info-overlay" role="dialog" aria-label="@L["WordInfo.DialogLabel"]" @onclick="() => _wordInfo = null">
                            <div class="word-info-modal" @onclick:stopPropagation>
                                <div class="word-info-header">
                                    <strong>@_wordInfo.Word</strong>
                                    @if (!string.IsNullOrWhiteSpace(_wordInfo.WiktionaryUrl))
                                    {
                                        <a href="@_wordInfo.WiktionaryUrl" target="_blank" rel="noopener" class="word-info-link">@L["WordInfo.Wiktionary"]</a>
                                    }
                                    <button class="btn btn-ghost btn-sm" @onclick="() => _wordInfo = null">✕</button>
                                </div>
                                @if (_wordInfo.Definitions.Count > 0)
                                {
                                    <ol class="word-info-defs">
                                        @foreach (var d in _wordInfo.Definitions.Take(5))
                                        {
                                            <li>@(string.IsNullOrWhiteSpace(d.PartOfSpeech) ? "" : $"({d.PartOfSpeech}) ")@d.Text</li>
                                        }
                                    </ol>
                                }
                                @if (_wordInfo.Synonyms.Count > 0)
                                {
                                    <p class="word-info-syns"><em>@L["WordInfo.Synonyms"]</em> @string.Join(", ", _wordInfo.Synonyms.Take(10))</p>
                                }
                            </div>
                        </div>
                    }
                    else if (_wordInfoNotFound is not null)
                    {
                        <div class="word-info-overlay" role="dialog" @onclick="() => _wordInfoNotFound = null">
                            <div class="word-info-modal" @onclick:stopPropagation>
                                <span>@L["WordInfo.NotFoundSentence", _wordInfoNotFound]</span>
                                <button class="btn btn-ghost btn-sm" @onclick="() => _wordInfoNotFound = null">✕</button>
                            </div>
                        </div>
                    }
                </div>
                <GameTabBar />
            }
        </div>
    </div>
}

@* ── Modal joker : assignation de la lettre ── *@
@if (_jokerRow >= 0)
{
    <div class="joker-overlay" role="dialog" aria-modal="true" aria-label="@L["Game.Joker.DialogLabel"]">
        <div class="joker-picker">
            <h4 class="mb-2">★ @L["Game.Joker.Title"]</h4>
            <div class="joker-grid">
                @foreach (var ch in "ABCDEFGHIJKLMNOPQRSTUVWXYZ")
                {
                    var letter = ch;
                    <button class="joker-btn" @onclick="() => AssignJoker(letter)" aria-label="@letter">@letter</button>
                }
            </div>
            <button class="btn btn-ghost btn-sm mt-2" @onclick="CancelJoker">@L["Game.Cancel"]</button>
        </div>
    </div>
}

@code {
    [Parameter] public string GameId { get; set; } = string.Empty;

    private readonly GamePlayViewModel _vm = new();
    private string? _myPlayerId;
    private PeriodicTimer? _timer;
    private PeriodicTimer? _uiTimer;
    private CancellationTokenSource? _pollingCts;
    private CancellationTokenSource? _uiCts;
    private ElementReference _boardAreaRef;
    private bool _boardKeyListenerAttached;

    // Drag state (rack → board)
    private int _draggingRackIndex = -1;
    private char _draggingLetter = '\0';

    // Click-to-place state (rack tile selected → click board cell)
    private int _selectedRackIndex = -1;
    private char _selectedLetter = '\0';

    // Drag state (board pending → board)
    private (int Row, int Col)? _draggingPendingPos;

    // Joker picker state
    private int _jokerRow = -1;
    private int _jokerCol = -1;

    // Rack display order (visual reorder, persists until rack changes)
    private List<int> _rackOrder = [];
    private int _previousRackSize = -1;

    // Swap options
    private bool _swapAll = true;
    private string _swapLetters = string.Empty;

    // Abandon state
    private bool _confirmAbandon;
    private string? _abandonNotice;
    private int _abandonRedirectCountdown;
    private int _previousAbandonedCount;
    private string? _abandonError; // erreur d'abandon persistante (non effacée par le polling)
    private string? _turnNotice;
    private DateTimeOffset _turnNoticeUntilUtc;
    private string? _lastAnnouncedMoveId;
    private bool _exportCopied;
    private IReadOnlyDictionary<string, string>? _playerLevelLabels;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Density.InitializeAsync();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var parsed = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _myPlayerId = parsed.TryGetValue("playerId", out var pid)
            ? pid.ToString()
            : Auth.CurrentUser?.PlayerId;

        _vm.Initialize(GameId, _myPlayerId);
        await _vm.LoadAsync(Api);
        _dictLang = GetLexiconLanguage();
        SyncRackOrder();

        // Charger les niveaux des joueurs (best-effort, ne bloque pas si le serveur ne répond pas)
        _ = LoadPlayerLevelsAsync();

        // Redirection vers lobby si la partie n'a pas encore démarré
        if (_vm.Snapshot is { UsesLobby: true, HasStarted: false })
        {
            var pidParam = _myPlayerId is not null ? $"?playerId={Uri.EscapeDataString(_myPlayerId)}" : string.Empty;
            Navigation.NavigateTo($"/games/{GameId}/lobby{pidParam}");
            return;
        }

        // Ne pas démarrer le polling si la partie est introuvable
        if (_vm.Snapshot is null)
            return;

        StartPolling();
        Layout.Changed += HandleLayoutChanged;
    }

    private void HandleLayoutChanged() => InvokeAsync(StateHasChanged);

    /// <summary>Réinitialise l'ordre du rack uniquement quand la taille change (nouveau tirage).
    /// Détecte aussi les nouveaux abandons pour notifier les autres joueurs.</summary>
    private void SyncRackOrder()
    {
        if (_turnNotice is not null && DateTimeOffset.UtcNow >= _turnNoticeUntilUtc)
            _turnNotice = null;

        var size = _vm.MyRack.Count;
        if (size != _previousRackSize)
        {
            _rackOrder = Enumerable.Range(0, size).ToList();
            _previousRackSize = size;
        }

        if (_vm.Snapshot is not null)
        {
            if (_lastAnnouncedMoveId is null)
            {
                _lastAnnouncedMoveId = _vm.Snapshot.LastMoveId;
            }
            else if (!string.IsNullOrWhiteSpace(_vm.Snapshot.LastMoveId)
                     && !string.Equals(_vm.Snapshot.LastMoveId, _lastAnnouncedMoveId, StringComparison.Ordinal)
                     && !_vm.Snapshot.IsGameOver)
            {
                var justPlayed = _vm.Snapshot.LastMovePlayerName;
                var nextPlayer = GetPlayerName(_vm.Snapshot.Players, _vm.Snapshot.CurrentPlayerIndex);
                if (!string.IsNullOrWhiteSpace(justPlayed) && !string.IsNullOrWhiteSpace(nextPlayer))
                {
                    var turnLabel = _vm.Snapshot.LastMoveTurnNumber is { } n ? L["Game.TurnLabel", n].Value : string.Empty;
                    var actionKey = _vm.Snapshot.LastMoveCommand?.ToLowerInvariant() switch
                    {
                        "play.pass" => "Game.TurnNotice.Pass",
                        "play.swap" => "Game.TurnNotice.Swap",
                        "play.challenge" => "Game.TurnNotice.Challenge",
                        _ => "Game.TurnNotice.Move"
                    };
                    var isReplay = string.Equals(justPlayed, nextPlayer, StringComparison.Ordinal);
                    var suffixKey = isReplay ? "Game.TurnNotice.ReplaySuffix" : "Game.TurnNotice.NextSuffix";
                    var scoreSuffix = _vm.Snapshot.LastMoveScore is > 0 and var sc
                        ? $" ({sc} {L["Game.PointsShort"]})"
                        : string.Empty;
                    ShowTurnNotice(
                        $"{turnLabel}{L[actionKey, justPlayed, scoreSuffix]} {L[suffixKey, nextPlayer]}");
                }

                _lastAnnouncedMoveId = _vm.Snapshot.LastMoveId;
            }
        }

        // Détecter un nouvel abandon → notification pour les autres joueurs
        var abandonedCount = _vm.Snapshot?.AbandonedPlayerIds.Count ?? 0;
        if (abandonedCount > _previousAbandonedCount && _vm.Snapshot is not null)
        {
            // Identifier le dernier joueur qui vient d'abandonner
            var newlyAbandonedNames = _vm.AbandonedPlayerNames
                .Where(n => !string.Equals(n, _vm.Snapshot.AbandonedByName, StringComparison.Ordinal) || _previousAbandonedCount == 0)
                .ToList();
            if (newlyAbandonedNames.Count > 0 && !_vm.IsAbandoned)
                _abandonNotice = L["Game.AbandonNotice", newlyAbandonedNames[^1]];
            _previousAbandonedCount = abandonedCount;
        }

        // Détecter fin de partie par abandon (hôte) ou redémarrage serveur → lancer countdown auto-redirection
        if (_vm.Snapshot is { IsGameOver: true } &&
            _abandonRedirectCountdown == 0 &&
            (string.Equals(_vm.Snapshot.EndReason, "server_restart", StringComparison.Ordinal) ||
             (string.Equals(_vm.Snapshot.EndReason, "abandoned", StringComparison.Ordinal) && !_vm.IsAbandoned)))
        {
            _ = StartAbandonRedirectCountdownAsync();
        }
    }

    private void ShowTurnNotice(string message)
    {
        _turnNotice = message;
        _turnNoticeUntilUtc = DateTimeOffset.UtcNow.AddSeconds(5);
    }

    private bool HasAnyUiMessages =>
        _turnNotice is not null
        || _abandonNotice is not null
        || _vm.CheckScore.HasValue
        || !string.IsNullOrWhiteSpace(_vm.Error)
        || !string.IsNullOrWhiteSpace(_abandonError)
        || _vm.SuggestionsUsed;

    private bool ShowFirstMoveHint =>
        _vm.IsMyTurn
        && _vm.Snapshot is { Board.Count: 0 }
        && _vm.PendingPlacements.Count == 0;

    private static string? GetPlayerName(IReadOnlyList<WebSnapshotPlayer> players, int index) =>
        index >= 0 && index < players.Count ? players[index].PlayerName : null;

    private async Task StartAbandonRedirectCountdownAsync()
    {
        _abandonRedirectCountdown = 5;
        while (_abandonRedirectCountdown > 0)
        {
            StateHasChanged();
            await Task.Delay(1000);
            _abandonRedirectCountdown--;
        }
        Navigation.NavigateTo("/games");
    }

    private void StartPolling()
    {
        _pollingCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = Task.Run(async () =>
        {
            while (await _timer.WaitForNextTickAsync(_pollingCts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await _vm.LoadAsync(Api);
                    SyncRackOrder();
                    StateHasChanged();
                });

                if (_vm.Snapshot is null && !string.IsNullOrWhiteSpace(_vm.Error))
                {
                    _pollingCts.Cancel();
                    break;
                }
            }
        }, _pollingCts.Token);

        // Timer UI 1-seconde : rafraîchit le chrono du joueur courant sans polling serveur
        _uiCts = new CancellationTokenSource();
        _uiTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = Task.Run(async () =>
        {
            while (await _uiTimer.WaitForNextTickAsync(_uiCts.Token))
            {
                await InvokeAsync(() => StateHasChanged());
            }
        }, _uiCts.Token);
    }

    private async Task RefreshAsync()
    {
        await _vm.LoadAsync(Api);
        SyncRackOrder();
    }

    // ── Drag-and-drop ────────────────────────────────────────────────────────

    private void HandleDragStart((int Index, char Letter) args)
    {
        _draggingRackIndex = args.Index;
        _draggingLetter = args.Letter;
        _draggingPendingPos = null;
    }

    private void HandleRackTileClick((int Index, char Letter) args)
    {
        if (_selectedRackIndex == args.Index)
        {
            _selectedRackIndex = -1;
            _selectedLetter = '\0';
        }
        else
        {
            _selectedRackIndex = args.Index;
            _selectedLetter = args.Letter;
        }
    }

    private void HandlePendingDragStart((int Row, int Col) pos)
    {
        _draggingPendingPos = pos;
        _draggingRackIndex = -1;
    }

    private void HandleDrop((int Row, int Col) cell)
    {
        var rackIndex = _draggingRackIndex >= 0 ? _draggingRackIndex : _selectedRackIndex;
        var letter = _draggingRackIndex >= 0 ? _draggingLetter : _selectedLetter;
        var fromClick = _selectedRackIndex >= 0 && _draggingRackIndex < 0;

        if (_draggingPendingPos.HasValue)
        {
            var from = _draggingPendingPos.Value;
            if (from != cell)
                _vm.MovePendingTile(from.Row, from.Col, cell.Row, cell.Col);
            _draggingPendingPos = null;
        }
        else if (rackIndex >= 0)
        {
            if (letter == '*')
            {
                _vm.PlaceTile(rackIndex, '*', cell.Row, cell.Col);
                _jokerRow = cell.Row;
                _jokerCol = cell.Col;
            }
            else
            {
                _vm.PlaceTile(rackIndex, letter, cell.Row, cell.Col);
            }
            _draggingRackIndex = -1;
            _draggingLetter = '\0';
            _selectedRackIndex = -1;
            _selectedLetter = '\0';
        }
        StateHasChanged();
    }

    private void HandleRecall((int Row, int Col) cell)
    {
        _vm.RecallTile(cell.Row, cell.Col);
        StateHasChanged();
    }

    private WebWordInfo? _wordInfo;
    private string? _wordInfoNotFound;
    private string _dictionaryQuery = string.Empty;
    private List<string> _dictionaryResults = [];
    private bool _dictionarySearchLoading;
    private bool _dictionarySearchDone;
    private string? _dictionarySearchError;
    private string _dictLang = string.Empty;

    private async Task HandleTileClick((int Row, int Col) cell)
    {
        var board = _vm.Snapshot?.Board;
        if (board is null) return;

        var word = ExtractWordAt(board, cell.Row, cell.Col);
        if (word.Length < 2) return;

        await ShowWordInfoAsync(word);
    }

    private async Task HandleWordSelected(string word)
    {
        if (word.Length < 2) return;
        await ShowWordInfoAsync(word);
    }

    private async Task SearchDictionaryAsync()
    {
        var query = _dictionaryQuery.Trim();
        _dictionarySearchError = null;
        _dictionarySearchDone = false;
        _dictionaryResults = [];

        if (query.Length < 2)
        {
            _dictionarySearchError = L["Game.Dictionary.MinChars"];
            StateHasChanged();
            return;
        }

        _dictionarySearchLoading = true;
        StateHasChanged();

        var lang = GetLexiconLanguage();
        var results = await Api.SearchWordsAsync(lang, query, limit: 20);
        _dictionaryResults = results.ToList();
        _dictionarySearchDone = true;
        _dictionarySearchLoading = false;
        StateHasChanged();
    }

    private async Task ShowWordInfoAsync(string word)
    {
        var lang = GetLexiconLanguage();
        _wordInfo = null;
        _wordInfoNotFound = null;
        var info = await Api.GetWordInfoAsync(lang, word);
        if (info is null) _wordInfoNotFound = word;
        else _wordInfo = info;
        StateHasChanged();
    }

    private string GetLexiconLanguage()
    {
        if (!string.IsNullOrEmpty(_dictLang)) return _dictLang;
        var lang = _vm.Snapshot?.Language;
        if (string.IsNullOrWhiteSpace(lang))
            return "fr";

        var normalized = lang.Trim().ToLowerInvariant();
        if (normalized is "fr" or "en" or "de")
            return normalized;

        var tokens = normalized
            .Split([',', ';', '+', '|', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var firstSupported = tokens.FirstOrDefault(t => t is "fr" or "en" or "de");
        return string.IsNullOrWhiteSpace(firstSupported) ? "fr" : firstSupported;
    }

    private IReadOnlyList<string> GetGameLanguages()
    {
        var lang = _vm.Snapshot?.Language;
        if (string.IsNullOrWhiteSpace(lang)) return ["fr"];
        var tokens = lang.Trim().ToLowerInvariant()
            .Split([',', ';', '+', '|', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(t => t is "fr" or "en" or "de")
            .ToList();
        return tokens.Count > 0 ? tokens : (IReadOnlyList<string>)["fr"];
    }

    private static string LanguageFlag(string code) => code switch
    {
        "fr" => "🇫🇷",
        "en" => "🇬🇧",
        "de" => "🇩🇪",
        _ => "🌐"
    };

    private static string ExtractWordAt(IReadOnlyList<WebBoardTile> board, int row, int col)
    {
        char? At(int r, int c) => board.FirstOrDefault(t => t.Row == r && t.Column == c)?.Letter;

        int hLen = 1; var c0 = col;
        while (At(row, c0 - 1) is not null) c0--;
        var hWord = ""; var cc = c0;
        while (At(row, cc) is { } ch) { hWord += char.ToUpperInvariant(ch); cc++; }
        hLen = hWord.Length;

        var r0 = row; while (At(r0 - 1, col) is not null) r0--;
        var vWord = ""; var rr = r0;
        while (At(rr, col) is { } ch) { vWord += char.ToUpperInvariant(ch); rr++; }

        return vWord.Length > hLen ? vWord : hWord;
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_vm.IsMyTurn && !_boardKeyListenerAttached)
        {
            try
            {
                await JS.InvokeVoidAsync("playalamaBoard.attachKeyListener", _boardAreaRef);
                _boardKeyListenerAttached = true;
            }
            catch { }
        }

        if (firstRender && ShowFirstMoveHint)
            Announcer.Announce(L["Game.FirstMoveHint"].Value);
    }

    private void OnBoardFocus()
    {
        if (_vm.IsMyTurn && !_vm.Snapshot!.IsGameOver && !_vm.KeyboardModeActive)
        {
            var row = _vm.KeyboardCursorRow >= 0 && _vm.KeyboardCursorRow < 15 ? _vm.KeyboardCursorRow : 7;
            var col = _vm.KeyboardCursorCol >= 0 && _vm.KeyboardCursorCol < 15 ? _vm.KeyboardCursorCol : 7;
            _vm.StartKeyboardMode(row, col);
            StateHasChanged();
        }
    }

    private Task HandleBoardKeyDown(KeyboardEventArgs e)
    {
        if (!_vm.IsMyTurn || _vm.Snapshot?.IsGameOver == true) return Task.CompletedTask;

        if (!_vm.KeyboardModeActive)
        {
            var row = _vm.KeyboardCursorRow is >= 0 and < 15 ? _vm.KeyboardCursorRow : 7;
            var col = _vm.KeyboardCursorCol is >= 0 and < 15 ? _vm.KeyboardCursorCol : 7;
            _vm.StartKeyboardMode(row, col);
        }

        switch (e.Key)
        {
            case "ArrowUp":    _vm.MoveCursor(-1, 0); break;
            case "ArrowDown":  _vm.MoveCursor(1, 0); break;
            case "ArrowLeft":  _vm.MoveCursor(0, -1); break;
            case "ArrowRight": _vm.MoveCursor(0, 1); break;
            case "Delete":     _vm.HandleKeyboardDelete(); break;
            case "Insert":     _vm.HandleKeyboardInsert(); break;
            case "Backspace":  _vm.HandleKeyboardBackspace(); break;
            case "Tab":       _vm.ToggleKeyboardDirection(); break;
            case "Escape":
                _vm.RecallAll();
                break;
            default:
                if (e.Key.Length == 1 && char.IsLetter(e.Key[0]))
                    _vm.HandleKeyboardLetter(e.Key[0]);
                else
                    return Task.CompletedTask;
                break;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleKeyboardActivate((int Row, int Col) cell)
    {
        if (_vm.IsMyTurn && !_vm.Snapshot!.IsGameOver)
            _vm.StartKeyboardMode(cell.Row, cell.Col);
        return Task.CompletedTask;
    }

    private void HandleRackReorder((int FromDisplayPos, int ToDisplayPos) args)
    {
        if (args.FromDisplayPos < 0 || args.ToDisplayPos < 0) return;
        if (args.FromDisplayPos >= _rackOrder.Count || args.ToDisplayPos >= _rackOrder.Count) return;
        (_rackOrder[args.FromDisplayPos], _rackOrder[args.ToDisplayPos]) =
            (_rackOrder[args.ToDisplayPos], _rackOrder[args.FromDisplayPos]);
        StateHasChanged();
    }

    private void AssignJoker(char letter)
    {
        if (_jokerRow >= 0)
            _vm.AssignJokerLetter(_jokerRow, _jokerCol, letter);
        _jokerRow = -1;
        _jokerCol = -1;
        StateHasChanged();
    }

    private void CancelJoker()
    {
        if (_jokerRow >= 0)
            _vm.RecallTile(_jokerRow, _jokerCol);
        _jokerRow = -1;
        _jokerCol = -1;
        StateHasChanged();
    }

    private HashSet<int> GetUsedIndices() => [.._vm.PendingPlacements
        .Select((_, i) => _vm.GetUsedRackIndex(i))
        .Where(x => x >= 0)];

    // ── Soumission ──────────────────────────────────────────────────────────

    private async Task PlayDragMoveAsync()
    {
        await PlayPendingAsync();
    }

    private async Task CheckMoveAsync()
    {
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }
        await _vm.CheckAsync(Api, token);
        StateHasChanged();
    }

    private async Task SuggestMovesAsync()
    {
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }
        await _vm.SuggestAsync(Api, token);
        StateHasChanged();
    }

    private async Task PlayPendingAsync()
    {
        _vm.Command = "play.move";
        _vm.SwapAll = false;
