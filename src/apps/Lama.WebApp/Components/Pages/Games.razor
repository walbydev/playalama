@page "/games"
@layout MainLayout
@inject LamaApiClient Api
@inject AuthService Auth
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@implements IAsyncDisposable

<PageTitle>@L["Games.PageTitle"]</PageTitle>

<div class="page-hero">
    <div class="eyebrow">@L["CreateGame.Multiplayer"]</div>
    <h1>🎮 @L["Games.Title"]</h1>
    <p class="text-muted mt-2">@L["Games.Subtitle"]</p>
</div>

<div class="section">
    <div class="container">
        <div style="display:grid; grid-template-columns:1fr 2fr; gap:2rem; align-items:start">

            <!-- Créer une partie -->
            <div class="card">
                <h2 class="mb-3">@L["CreateGame.Title"]</h2>
                <EditForm Model="_createForm" OnValidSubmit="CreateGameAsync">
                    <DataAnnotationsValidator />

                    <div class="form-field">
                        <label for="game-mode">@L["CreateGame.Mode"]</label>
                        <InputSelect id="game-mode" class="ui-control ui-control-lg" @bind-Value="_createForm.Mode" @bind-Value:after="OnModeChanged">
                            <option value="multi">@L["CreateGame.Multiplayer"]</option>
                            <option value="solo">@L["CreateGame.Solo"]</option>
                            @if (_isAdmin)
                            {
                                <option value="ai-only">@L["CreateGame.AiOnly"]</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-field">
                        <label for="game-name">@L["CreateGame.Name"] <small class="text-dim">@L["Common.Optional"]</small></label>
                        <InputText id="game-name" class="ui-control" @bind-Value="_createForm.GameName" placeholder="@L["Games.GameNamePlaceholder"]" />
                    </div>
                    @if (_isSolo)
                    {
                        <div class="form-field">
                            <label for="bot-slot-solo">@L["CreateGame.AiSlot", 1]</label>
                            @if (_bots.Count == 0)
                            {
                                <p class="text-muted" style="font-size:.85rem">@L["Games.LoadingBots"]</p>
                            }
                            else
                            {
                                <select id="bot-slot-solo" class="ui-control"
                                        value="@(_createForm.AiBotIds[0] ?? string.Empty)"
                                        @onchange="e => OnAiBotSlotChanged(0, e.Value?.ToString())">
                                    <option value="">@L["CreateGame.AiChooseBot"]</option>
                                    @foreach (var bot in GetAvailableBotsForSlot(0, 1))
                                    {
                                        <option value="@bot.BotId">@bot.LevelEmoji @bot.Name — @bot.LevelLabel (Elo @bot.InitialElo)</option>
                                    }
                                </select>
                            }
                        </div>
                    }
                    else if (_isAiOnly)
                    {
                        <div class="form-field">
                            <label>@L["CreateGame.AiOnlySlots"]</label>
                            <small class="text-dim">@L["CreateGame.AiOnlyHint"]</small>
                        </div>
                        @for (var i = 0; i < 4; i++)
                        {
                            var slot = i;
                            <div class="form-field">
                                <label for="bot-slot-@slot">@L["CreateGame.AiSlot", slot + 1]</label>
                                @if (_bots.Count == 0)
                                {
                                    <p class="text-muted" style="font-size:.85rem">@L["Games.LoadingBots"]</p>
                                }
                                else
                                {
                                    <select id="bot-slot-@slot" class="ui-control"
                                            value="@(_createForm.AiBotIds[slot] ?? string.Empty)"
                                            @onchange="e => OnAiBotSlotChanged(slot, e.Value?.ToString())">
                                        <option value="">@L["CreateGame.AiChooseBot"]</option>
                                        @foreach (var bot in GetAvailableBotsForSlot(slot, 4))
                                        {
                                            <option value="@bot.BotId">@bot.LevelEmoji @bot.Name — @bot.LevelLabel (Elo @bot.InitialElo)</option>
                                        }
                                    </select>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="form-field">
                            <label for="game-max">@L["CreateGame.MaxPlayers"]</label>
                            <InputNumber id="game-max" class="ui-control" @bind-Value="_createForm.MaxPlayers" @bind-Value:after="OnMaxPlayersChanged" min="2" max="4" />
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_createError))
                    {
                        <p class="form-error mb-2" role="alert">@_createError</p>
                    }

                    <div class="form-field">
                        <label>@L["CreateGame.GameLanguages"]</label>
                        <div class="lang-choices">
                            @foreach (var (code, label) in _gameLanguages)
                            {
                                var selected = _createForm.Languages.Contains(code);
                                var lockLast = _createForm.Languages.Count == 1 && selected;
                                <button type="button"
                                        class="lang-choice-btn @(selected ? "is-selected" : string.Empty)"
                                        aria-pressed="@selected"
                                        disabled="@lockLast"
                                        @onclick="() => ToggleLanguage(code)">
                                    <span class="lang-choice-mark" aria-hidden="true">@((selected) ? "☑" : "☐")</span>
                                    <span>@label</span>
                                </button>
                            }
                        </div>
                    </div>

                    <button class="btn btn-primary" type="submit" style="width:100%" disabled="@_busy">
                        @(_busy ? L["CreateGame.Creating"].Value : (_isAiOnly ? L["CreateGame.LaunchAiMatch"].Value : (_isSolo ? L["CreateGame.PlayAi"].Value : L["CreateGame.Create"].Value)))
                    </button>
                </EditForm>
            </div>

            <!-- Liste des parties -->
            <div>
                <div class="flex justify-between items-center mb-3 flex-wrap gap-2">
                    <h2>@L["Games.AvailableGames"]</h2>
                    <div class="flex items-center gap-2">
                        <span class="text-dim" style="font-size:.8rem">↻ @L["Games.Auto"]</span>
                        <button class="btn btn-ghost btn-sm" @onclick="RefreshAsync" disabled="@_listBusy">
                            @L["Game.Refresh"]
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_listError))
                {
                    <div class="form-error mb-3" role="alert" style="display:flex;align-items:center;gap:.5rem">
                        ⚠️ @_listError
                        <button style="margin-left:auto;background:none;border:none;cursor:pointer;font-size:1rem" @onclick="() => _listError = null" aria-label="@L["Common.Close"]">✕</button>
                    </div>
                }

                @if (_listBusy && _games.Count == 0)
                {
                    <p class="text-muted" aria-live="polite">@L["Common.Loading"]</p>
                }
                else if (_games.Count == 0)
                {
                    <div class="empty-state">
                        <span class="empty-state-icon" aria-hidden="true">🃏</span>
                        <p>@L["Games.Empty"]</p>
                    </div>
                }
                else
                {
                    <div style="overflow-x:auto">
                        <table class="lb-table" aria-label="@L["Games.TableAria"]">
                            <thead>
                                <tr>
                                    <th scope="col">@L["CreateGame.Name"]</th>
                                    <th scope="col">@L["MyGames.Status"]</th>
                                    <th scope="col">@L["Games.Players"]</th>
                                    <th scope="col">@L["CreateGame.Mode"]</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var game in _games)
                                {
                                    <tr>
                                        <td>@(string.IsNullOrWhiteSpace(game.GameName) ? game.Id[..8] + "…" : game.GameName)</td>
                                        <td>
                                            @{
                                                var (chipClass, label) = game.Status switch
                                                {
                                                    "waiting" => ("chip chip-accent", $"⏳ {L["MyGames.Waiting"]}"),
                                                    "active"  => ("chip chip-success", $"▶ {L["MyGames.Active"]}"),
                                                    _         => ("chip chip-muted", game.Status)
                                                };
                                            }
                                            <span class="@chipClass">@label</span>
                                        </td>
                                        <td>@game.Players / @game.MaxPlayers</td>
                                        <td>@game.Queue</td>
                                        <td>
                                            @if (game.IsJoinable)
                                            {
                                                <button class="btn btn-primary btn-sm" @onclick="() => JoinGameAsync(game.Id)">
                                                    @L["Games.Join"]
                                                </button>
                                            }
                                            else
                                            {
                                                <a href="/games/@game.Id" class="btn btn-ghost btn-sm">@L["MyGames.View"]</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly CreateGameForm _createForm = new();
    private readonly List<WebGameListItem> _games = [];
    private readonly List<WebBotDto> _bots = [];
    private bool _busy;
    private bool _listBusy;
    private bool _isSolo;
    private bool _isAiOnly;
    private bool _isAdmin;
    private string? _createError;
    private string? _listError;

    private static readonly (string Code, string Label)[] _gameLanguages =
    {
        ("fr", "Français"), ("en", "English"), ("de", "Deutsch")
    };

    private void ToggleLanguage(string code)
    {
        if (_createForm.Languages.Contains(code))
        {
            if (_createForm.Languages.Count > 1)
                _createForm.Languages.Remove(code);
        }
        else
        {
            _createForm.Languages.Add(code);
        }
    }

    private PeriodicTimer? _refreshTimer;
    private CancellationTokenSource? _timerCts;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        _isAdmin = Auth.IsAdmin;
        OnModeChanged();
        await Task.WhenAll(LoadGamesAsync(), LoadBotsAsync());
        StartAutoRefresh();
    }

    private async Task LoadBotsAsync()
    {
        try
        {
            var bots = await Api.GetBotsAsync();
            _bots.Clear();
            _bots.AddRange(bots.OrderBy(b => b.Level));
            EnsureAiSlotSelections(_isAiOnly ? 4 : (_isSolo ? 1 : 0));
        }
        catch (Exception ex)
        {
            _createError = $"{L["Games.LoadBotsFailed"]} {ex.Message}";
        }
    }

    private void OnModeChanged()
    {
        _isSolo = string.Equals(_createForm.Mode, "solo", StringComparison.OrdinalIgnoreCase);
        _isAiOnly = string.Equals(_createForm.Mode, "ai-only", StringComparison.OrdinalIgnoreCase);
        if (!_isAdmin && _isAiOnly)
        {
            _createForm.Mode = "multi";
            _isAiOnly = false;
        }
        OnMaxPlayersChanged();
        EnsureAiSlotSelections(_isAiOnly ? 4 : (_isSolo ? 1 : 0));
    }

    private void OnMaxPlayersChanged()
    {
        _createForm.MaxPlayers = Math.Clamp(_createForm.MaxPlayers, 2, 4);
    }

    private void OnAiBotSlotChanged(int slot, string? botId)
    {
        if (slot < 0 || slot >= _createForm.AiBotIds.Count)
            return;
        _createForm.AiBotIds[slot] = string.IsNullOrWhiteSpace(botId) ? null : botId;
        EnsureAiSlotSelections(_isAiOnly ? 4 : (_isSolo ? 1 : 0));
    }

    private IReadOnlyList<WebBotDto> GetAvailableBotsForSlot(int slot, int activeSlots)
    {
        var selectedOthers = _createForm.AiBotIds
            .Select((id, idx) => new { id, idx })
            .Where(x => x.idx != slot && x.idx < activeSlots && !string.IsNullOrWhiteSpace(x.id))
            .Select(x => x.id!)
            .ToHashSet(StringComparer.Ordinal);

        return _bots
            .Where(b => !selectedOthers.Contains(b.BotId) || string.Equals(_createForm.AiBotIds[slot], b.BotId, StringComparison.Ordinal))
            .ToList();
    }

    private void EnsureAiSlotSelections(int activeSlots)
    {
        while (_createForm.AiBotIds.Count < 4) _createForm.AiBotIds.Add(null);
        for (var i = activeSlots; i < _createForm.AiBotIds.Count; i++)
            _createForm.AiBotIds[i] = null;

        var used = new HashSet<string>(StringComparer.Ordinal);
        for (var i = 0; i < activeSlots; i++)
        {
            var id = _createForm.AiBotIds[i];
            if (string.IsNullOrWhiteSpace(id) || !used.Add(id))
                _createForm.AiBotIds[i] = null;
        }
    }

    private void StartAutoRefresh()
    {
        _timerCts = new CancellationTokenSource();
        _refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = Task.Run(async () =>
        {
            while (await _refreshTimer.WaitForNextTickAsync(_timerCts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await LoadGamesAsync();
                    StateHasChanged();
                });
            }
        }, _timerCts.Token);
    }

    private async Task RefreshAsync()
    {
        await LoadGamesAsync();
    }

    private async Task CreateGameAsync()
    {
        _busy = true;
        _createError = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }
            var user = Auth.CurrentUser;
            if (user is null) { Navigation.NavigateTo("/login"); return; }

            var selectedAi = _createForm.AiBotIds
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Select(x => x!)
                .Distinct(StringComparer.Ordinal)
                .ToList();
            if (_isSolo && selectedAi.Count < 1)
            {
                _createError = L["CreateGame.AiSoloRequired"];
                return;
            }
            if (_isAiOnly && selectedAi.Count < 2)
            {
                _createError = L["CreateGame.AiOnlyMinTwo"];
                return;
            }
            if (_isAiOnly)
                _createForm.MaxPlayers = selectedAi.Count;

            if (_createForm.Languages.Count == 0)
            {
                _createError = L["CreateGame.LanguageRequired"];
                return;
            }

            var created = await Api.CreateGameAsync(_createForm, user.Username, token);
            var dest = _isAiOnly
                ? $"/games/{created.GameId}"
                : _isSolo
                    ? $"/games/{created.GameId}?playerId={Uri.EscapeDataString(created.HostPlayerId)}"
                    : $"/games/{created.GameId}/lobby?playerId={Uri.EscapeDataString(created.HostPlayerId)}";
            Navigation.NavigateTo(dest);
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("server_in_maintenance"))
                _createError = L["CreateGame.ServerMaintenance"].Value;
            else
                _createError = ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task JoinGameAsync(string gameId)
    {
        _busy = true;
        _createError = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }
            var playerName = Auth.CurrentUser?.Username;
            if (string.IsNullOrWhiteSpace(playerName)) { Navigation.NavigateTo("/login"); return; }

            var joined = await Api.JoinGameAsync(gameId, playerName, password: null, token);
            Navigation.NavigateTo($"/games/{joined.GameId}/lobby?playerId={Uri.EscapeDataString(joined.PlayerId)}");
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("server_in_maintenance"))
                _createError = L["CreateGame.ServerMaintenance"].Value;
            else
                _createError = ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task LoadGamesAsync()
    {
        _listBusy = true;
        try
        {
            var all = await Api.ListGamesAsync();
            // Afficher uniquement les parties actives (pas closed/ended)
            _games.Clear();
            _games.AddRange(all.Where(g => !string.Equals(g.Status, "closed", StringComparison.OrdinalIgnoreCase)
                                        && !string.Equals(g.Status, "ended", StringComparison.OrdinalIgnoreCase)
                                        && !string.Equals(g.Status, "abandoned", StringComparison.OrdinalIgnoreCase)));
        }
        catch (Exception ex) { _listError = ex.Message; }
        finally { _listBusy = false; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_timerCts is not null) { await _timerCts.CancelAsync(); _timerCts.Dispose(); }
        _refreshTimer?.Dispose();
    }
}
