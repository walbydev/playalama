@page "/downloads"
@layout MainLayout
@inject DownloadsViewModel VM
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Downloads.PageTitle"]</PageTitle>

<div class="page-hero">
    <div class="eyebrow">@L["Downloads.Eyebrow"]</div>
    <h1>⬇ @L["Downloads.Title"]</h1>
    <p class="text-muted mt-2">
        @L["Downloads.Subtitle"]
    </p>
</div>

<div class="section">
    <div class="container">

        <!-- Présentation du mode CLI -->
        <div class="card mb-4" style="max-width:780px; margin:0 auto 2.5rem">
            <h2 class="mb-2">@L["Downloads.WhyCli"]</h2>
            <ul style="list-style:none; display:flex; flex-direction:column; gap:.75rem">
                <li style="display:flex; gap:.75rem"><span aria-hidden="true" style="color:var(--accent2)">⚡</span><span>@L["Downloads.Why.Fast"]</span></li>
                <li style="display:flex; gap:.75rem"><span aria-hidden="true" style="color:var(--accent2)">🔒</span><span>@L["Downloads.Why.Offline"]</span></li>
                <li style="display:flex; gap:.75rem"><span aria-hidden="true" style="color:var(--accent2)">🌐</span><span>@L["Downloads.Why.Online"] <code>LAMA_RUNTIME_MODE=online</code>.</span></li>
                <li style="display:flex; gap:.75rem"><span aria-hidden="true" style="color:var(--accent2)">🔧</span><span>@L["Downloads.Why.Scriptable"]</span></li>
                <li style="display:flex; gap:.75rem"><span aria-hidden="true" style="color:var(--accent2)">🖥️</span><span>@L["Downloads.Why.CrossPlatform"]</span></li>
            </ul>
        </div>

        <!-- Blocs téléchargements -->
        <h2 class="mb-3">@L["Nav.Downloads"]</h2>
        <div class="dl-grid">
            @foreach (var platform in VM.Platforms)
            {
                <div class="dl-platform">
                    <div class="dl-platform-head">
                        <span style="font-size:1.5rem" aria-hidden="true">@platform.Os.Split(' ')[0]</span>
                        <div>
                            <h3>@platform.Os.Substring(platform.Os.IndexOf(' ') + 1)</h3>
                            <span class="dl-arch">@platform.Arch</span>
                        </div>
                    </div>
                    @foreach (var item in platform.Items)
                    {
                        <div class="dl-item">
                            <span class="dl-label">@item.Label</span>
                            @if (!string.IsNullOrEmpty(item.InstallCmd))
                            {
                                <div class="dl-cmd-wrap">
                                    <code class="dl-cmd" title="@item.InstallCmd">@item.InstallCmd</code>
                                    <button class="dl-copy"
                                            type="button"
                                            @onclick="() => CopyAsync(item.Label, item.InstallCmd)"
                                            aria-label="@L["Downloads.CopyCommandAria", item.Label]"
                                            title="@L["Downloads.Copy"]">
                                        @(VM.IsCopied(item.Label) ? "✓" : "📋")
                                    </button>
                                </div>
                            }
                            <a href="@item.ZipUrl" class="btn btn-ghost btn-sm" download aria-label="@L["Downloads.ZipAria", item.Label]">ZIP</a>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Commandes CLI complètes -->
        <div class="cli-commands mt-4">
            <h2>@L["Downloads.MainCommands"]</h2>
            <p class="text-muted mt-1 mb-3">@L["Downloads.MainCommandsSubtitle"]</p>
            @foreach (var group in VM.CommandGroups)
            {
                <h3 class="cli-group-title" style="margin-top:1.5rem;margin-bottom:.5rem">@group.Name <span class="text-muted" style="font-size:.85rem;font-weight:400">— @group.Description</span></h3>
                <div class="cli-cmd-list" role="list">
                    @foreach (var cmd in group.Commands)
                    {
                        <div class="cli-cmd-row" role="listitem">
                            <span class="cli-cmd-desc">@cmd.Description</span>
                            <code class="cli-cmd-code">@cmd.Command</code>
                            <button class="dl-copy"
                                    type="button"
                                    @onclick="() => CopyAsync(cmd.Command, cmd.Command)"
                                    aria-label="@L["Downloads.CopyAria", cmd.Command]"
                                    title="@L["Downloads.Copy"]">
                                @(VM.IsCopied(cmd.Command) ? "✓" : "📋")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private async Task CopyAsync(string key, string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            VM.MarkCopied(key);
            StateHasChanged();
            await Task.Delay(1500);
            VM.ClearCopied(key);
            StateHasChanged();
        }
        catch { /* clipboard non disponible */ }
    }
}
