@page "/games/{GameId}/lobby"
@layout MainLayout
@implements IAsyncDisposable
@inject LamaApiClient Api
@inject AuthService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Lobby.PageTitle"]</PageTitle>

<div class="lobby-page">

    <div class="eyebrow">@L["CreateGame.Multiplayer"]</div>
    <h1 class="mb-1">@(_vm.GameName ?? L["Lobby.PreparingGame"])</h1>
    <p class="text-muted mb-3">@L["Lobby.ShareCode"]</p>

    @* Code de la partie *@
    <div class="lobby-code" aria-label="@L["Lobby.GameCode"]">
        <span class="lobby-code-value" id="lobby-code-val">@GameId</span>
        <button class="btn btn-ghost btn-sm" @onclick="CopyCodeAsync" aria-label="@L["Lobby.CopyCodeAria"]">
            @(_codeCopied ? $"✓ {L["Lobby.Copied"]}" : $"📋 {L["Downloads.Copy"]}")
        </button>
        <button class="btn btn-ghost btn-sm" @onclick="CopyLinkAsync" aria-label="@L["Lobby.CopyInviteAria"]"
                title="@L["Lobby.CopyInviteTitle"]">
            @(_linkCopied ? $"✓ {L["Lobby.LinkCopied"]}" : $"🔗 {L["Lobby.Share"]}")
        </button>
    </div>

    @* Slots *@
    @if (_vm.Snapshot is not null)
    {
        <p class="lobby-slots">
            @L["Lobby.SlotsLine", _vm.Snapshot.Players.Count, _vm.MaxPlayers, (_vm.MaxPlayers - _vm.Snapshot.Players.Count)]
        </p>

        @* Liste des joueurs *@
        <div class="lobby-player-list" role="list" aria-label="@L["Lobby.PlayersPresent"]">
            @foreach (var player in _vm.Snapshot.Players)
            {
                <div class="lobby-player-row" role="listitem">
                    <div class="lobby-player-avatar" aria-hidden="true">@player.PlayerName[0]</div>
                    <div style="flex:1">
                        <span class="fw-600">@player.PlayerName</span>
                        @if (player.IsHost) { <span aria-label="@L["Game.Host"]" title="@L["Game.Host"]"> 👑</span> }
                    </div>
                    <span class="chip chip-success">@L["Lobby.Connected"]</span>
                </div>
            }
            @* Slots vides *@
            @for (var i = _vm.Snapshot.Players.Count; i < _vm.MaxPlayers; i++)
            {
                <div class="lobby-player-row" role="listitem" style="opacity:.4">
                    <div class="lobby-player-avatar" style="background:var(--bg3); color:var(--text-dim)" aria-hidden="true">?</div>
                    <span class="text-dim">@L["Lobby.WaitingPlayer"]</span>
                </div>
            }
        </div>
    }
    else if (_vm.IsLoading)
    {
        <p class="text-muted" aria-live="polite">@L["Common.Loading"]</p>
    }

    @if (!string.IsNullOrWhiteSpace(_vm.Error))
    {
        <p class="form-error mb-3" role="alert">@_vm.Error</p>
    }

    @* Section rejoindre — visible si le joueur courant n'est pas encore participant *@
    @if (_vm.Snapshot is not null && !_vm.IsParticipant && !_vm.HasStarted)
    {
        <div class="card mt-3" style="border-color:var(--accent); background:var(--bg2)">
            <h3 class="mb-2" style="font-size:1.1rem">🎮 @L["Lobby.JoinThisGame"]</h3>
            <p class="text-muted mb-2" style="font-size:.9rem">@L["Lobby.NotJoined"]</p>
            <div class="form-field mb-2">
                <label for="join-name">@L["Auth.Username"]</label>
                <input id="join-name" class="ui-control" type="text" @bind="_joinName" @bind:event="oninput"
                       placeholder="@L["Lobby.JoinNamePlaceholder"]" />
            </div>
            @if (!string.IsNullOrWhiteSpace(_joinError))
            {
                <p class="form-error mb-2" role="alert">@_joinError</p>
            }
            <button class="btn btn-primary" style="width:100%"
                    @onclick="JoinFromLobbyAsync"
                    disabled="@(_busy || string.IsNullOrWhiteSpace(_joinName))">
                @(_busy ? L["Lobby.Joining"] : $"▶ {L["Lobby.JoinGame"]}")
            </button>
        </div>
    }

    @* Actions (hôte uniquement) *@
    @if (_vm.IsHost)
    {
        <div class="flex flex-col gap-2 mt-3">
            <button class="btn btn-primary"
                    @onclick="StartAsync"
                    disabled="@(!_vm.CanStart || _busy)"
                    aria-disabled="@(!_vm.CanStart)">
                @(_busy ? L["Lobby.Starting"] : $"▶ {L["Lobby.StartGame"]}")
            </button>

            @if (!_vm.HasStarted)
            {
                @if (_confirmCancel)
                {
                    <div style="display:flex; align-items:center; gap:.75rem; flex-wrap:wrap; margin-top:.25rem">
                        <span class="text-dim" style="font-size:.85rem">@L["Lobby.CancelConfirm"]</span>
                        <button class="btn btn-danger btn-sm" @onclick="CancelGameAsync" disabled="@_busy">
                            ✔ @L["Game.AbandonConfirmYes"]
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => _confirmCancel = false" disabled="@_busy">
                            @L["Game.Cancel"]
                        </button>
                    </div>
                }
                else
                {
                    <button class="btn btn-ghost btn-sm" style="color:var(--danger,#e55)"
                            @onclick="() => _confirmCancel = true" disabled="@_busy"
                            title="@L["Lobby.CancelTitle"]">
                        🏳 @L["Lobby.AbandonCreation"]
                    </button>
                }
            }
        </div>
    }
    else if (_vm.IsParticipant && !_vm.IsHost)
    {
        <p class="text-muted mt-3">@L["Lobby.WaitHostStart"]</p>
    }

</div>

@code {
    [Parameter] public string GameId { get; set; } = string.Empty;

    private readonly LobbyViewModel _vm = new();
    private bool _busy;
    private bool _codeCopied;
    private bool _linkCopied;
    private bool _confirmCancel;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _pollingCts;
    private string? _myPlayerId;
    private string _joinName = string.Empty;
    private string? _joinError;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var parsed = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _myPlayerId = parsed.TryGetValue("playerId", out var pid)
            ? pid.ToString()
            : Auth.CurrentUser?.PlayerId;

        // Pré-remplir le nom pour rejoindre depuis l'utilisateur connecté
        _joinName = Auth.CurrentUser?.Username ?? string.Empty;

        _vm.Initialize(GameId, _myPlayerId);
        await _vm.LoadAsync(Api);
        StartPolling();
    }

    private void StartPolling()
    {
        _pollingCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = Task.Run(async () =>
        {
            while (await _timer.WaitForNextTickAsync(_pollingCts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await _vm.LoadAsync(Api);
                    StateHasChanged();

                    if (_vm.HasStarted)
                    {
                        await (_pollingCts?.CancelAsync() ?? Task.CompletedTask);
                        var playerId = _myPlayerId is not null
                            ? $"?playerId={Uri.EscapeDataString(_myPlayerId)}"
                            : string.Empty;
                        Navigation.NavigateTo($"/games/{GameId}{playerId}");
                    }
                });
            }
        }, _pollingCts.Token);
    }

    private async Task StartAsync()
    {
        _busy = true;
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }
        await _vm.StartAsync(Api, token);
        if (_vm.HasStarted)
        {
            var pid = _myPlayerId is not null ? $"?playerId={Uri.EscapeDataString(_myPlayerId)}" : string.Empty;
            Navigation.NavigateTo($"/games/{GameId}{pid}");
        }
        _busy = false;
    }

    private async Task CancelGameAsync()
    {
        _busy = true;
        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) { Navigation.NavigateTo("/login"); return; }

        var cancelled = await _vm.CancelGameAsync(Api, token);
        if (cancelled)
        {
            await (_pollingCts?.CancelAsync() ?? Task.CompletedTask);
            Navigation.NavigateTo("/games");
            return;
        }

        _confirmCancel = false;
        _busy = false;
    }

    private async Task CopyCodeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", GameId);
            _codeCopied = true;
            await Task.Delay(2000);
            _codeCopied = false;
            StateHasChanged();
        }
        catch { /* pas de clipboard API */ }
    }

    private async Task CopyLinkAsync()
    {
        try
        {
            var lobbyUrl = Navigation.ToAbsoluteUri($"/games/{GameId}/lobby").ToString();
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", lobbyUrl);
            _linkCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _linkCopied = false;
            StateHasChanged();
        }
        catch { /* pas de clipboard API */ }
    }

    private async Task JoinFromLobbyAsync()
    {
        if (string.IsNullOrWhiteSpace(_joinName)) return;
        _busy = true;
        _joinError = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                var returnUrl = $"/games/{GameId}/lobby";
                Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}");
                return;
            }

            var joined = await Api.JoinGameAsync(GameId, _joinName.Trim(), password: null, token);
            _myPlayerId = joined.PlayerId;
            _vm.Initialize(GameId, _myPlayerId);
            await _vm.LoadAsync(Api);
            // Recharger la page avec le nouveau playerId dans l'URL
            Navigation.NavigateTo($"/games/{GameId}/lobby?playerId={Uri.EscapeDataString(_myPlayerId)}", forceLoad: false);
        }
        catch (Exception ex) { _joinError = ex.Message; }
        finally { _busy = false; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollingCts is not null)
        {
            await _pollingCts.CancelAsync();
            _pollingCts.Dispose();
        }
        _timer?.Dispose();
    }
}
