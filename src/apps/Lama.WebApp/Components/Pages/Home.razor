@page "/"
@layout MainLayout
@using Lama.WebApp.Components.Sections
@inject HomeViewModel VM

<PageTitle>Playalama — Le jeu de mots tactique</PageTitle>

<HeroSection />

<GameModesSection />

<WhyPlayalamaSection />

<LeaderboardPreviewSection />

<!-- CTA final -->
<section class="section text-center" aria-labelledby="cta-title">
    <div class="container">
        <h2 id="cta-title">Prêt à poser ta première tuile ?</h2>
        <p class="text-muted mt-2">Gratuit (Sauf si tu es prêt à effectuer une donation), sans publicité et sans tracking. Lance une partie en moins de 10 secondes.</p>
        <div class="hero-btns mt-3">
            <a href="/games"     class="btn btn-primary btn-lg">🎮 Jouer maintenant — c'est gratuit</a>
            <a href="/downloads" class="btn btn-outline btn-lg">⬇ Télécharger le client</a>
        </div>
        <p class="text-dim mt-2" style="font-size:.9rem">
            ✓ Gratuit &nbsp;·&nbsp; ✓ Sans pub &nbsp;·&nbsp; ✓ Open source &nbsp;·&nbsp; ✓ Multiplateforme
        </p>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await VM.InitializeAsync();
            StateHasChanged();
        }
    }
}
