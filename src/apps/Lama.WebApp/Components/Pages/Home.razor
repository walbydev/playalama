@page "/"
@layout MainLayout
@using Lama.WebApp.Components.Sections
@inject HomeViewModel VM
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Home.PageTitle"]</PageTitle>

<HeroSection />

<GameModesSection />

<WhyPlayalamaSection />

<LeaderboardPreviewSection />

<!-- CTA final -->
<section class="section text-center" aria-labelledby="cta-title">
    <div class="container">
        <h2 id="cta-title">@L["Home.Cta.Title"]</h2>
        <p class="text-muted mt-2">@L["Home.Cta.Subtitle"]</p>
        <div class="hero-btns mt-3">
            <a href="/games"     class="btn btn-primary btn-lg">🎮 @L["Home.Cta.PlayNow"]</a>
            <a href="/downloads" class="btn btn-outline btn-lg">⬇ @L["Home.Cta.Download"]</a>
        </div>
        <p class="text-dim mt-2" style="font-size:.9rem">
            @L["Home.Cta.Badges"]
        </p>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await VM.InitializeAsync();
            StateHasChanged();
        }
    }
}
