@page "/rules"
@layout MainLayout
@inject RulesViewModel VM
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Rules.PageTitle"]</PageTitle>

<div class="page-hero">
    <div class="eyebrow">@L["Nav.Rules"]</div>
    <h1>📖 @L["Rules.Title"]</h1>
    <p class="text-muted mt-2">@L["Rules.Subtitle"]</p>
</div>

<div class="section">
    <div class="container">
        <div class="rules-layout">

            <!-- Navigation sticky -->
            <nav class="rules-nav" aria-label="@L["Rules.NavAria"]">
                @foreach (var ruleSection in VM.Sections)
                {
                    <a href="#@ruleSection.Id"
                       class="@(VM.ActiveSectionId == ruleSection.Id ? "active" : "")"
                       @onclick="() => VM.SetActiveSection(ruleSection.Id)">
                        @ruleSection.Title
                    </a>
                }
            </nav>

            <!-- Contenu -->
            <div>
                @foreach (var ruleSection in VM.Sections)
                {
                    <div class="rules-section"
                         id="@ruleSection.Id"
                         aria-labelledby="rules-h2-@ruleSection.Id">
                        <h2 id="rules-h2-@ruleSection.Id">@ruleSection.Title</h2>
                        <p class="rules-section-intro">@ruleSection.Intro</p>

                        @foreach (var rule in ruleSection.Rules)
                        {
                            <div class="rules-rule">
                                <h4>@rule.Title</h4>
                                <p>@rule.Text</p>
                            </div>
                        }

                        @if (ruleSection.Id != "common")
                        {
                            <div class="mt-3">
                                <a href="/modes/@ruleSection.Id" class="btn btn-outline btn-sm">
                                    @L["Rules.PlayMode", ruleSection.Title.Split(' ').Last()] →
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
</div>
