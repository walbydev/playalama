@page "/my-games"
@layout MainLayout
@implements IDisposable
@inject AuthService Auth
@inject LamaApiClient Api
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["MyGames.PageTitle"]</PageTitle>

@if (!Auth.IsInitialized)
{
    <div class="auth-page">
        <div class="auth-card text-center">
            <h1>@L["MyGames.Title"]</h1>
            <p class="text-muted mt-2" aria-live="polite">@L["Profile.LoadingSession"]</p>
        </div>
    </div>
}
else if (!Auth.IsLoggedIn)
{
    <div class="auth-page">
        <div class="auth-card text-center">
            <h1>@L["MyGames.Title"]</h1>
            <p class="text-muted mt-2">@L["MyGames.LoginRequired"]</p>
            <a href="/login" class="btn btn-primary mt-3">@L["Login.Submit"]</a>
        </div>
    </div>
}
else
{
    <div class="page-hero">
        <div class="eyebrow">@L["MyGames.History"]</div>
        <div class="flex items-center justify-between flex-wrap gap-2">
            <h1>@L["MyGames.Title"]</h1>
            <button class="btn btn-ghost btn-sm" type="button" @onclick="LoadAsync" disabled="@_busy">@L["Game.Refresh"]</button>
        </div>
    </div>

    <div class="section">
        <div class="container">

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <p class="form-error mb-3" role="alert">@_error</p>
            }

            @if (_busy)
            {
                <p class="text-muted text-center" aria-live="polite">@L["Common.Loading"]</p>
            }
            else if (_games.Count == 0)
            {
                <div class="empty-state">
                    <span class="empty-state-icon" aria-hidden="true">🎮</span>
                    <p>@L["MyGames.Empty"]</p>
                    <a href="/games" class="btn btn-primary mt-2">@L["MyGames.JoinGame"]</a>
                </div>
            }
            else
            {
                <div class="flex gap-3 mb-4 flex-wrap">
                    <div class="card" style="text-align:center; min-width:120px">
                        <div style="font-size:1.5rem; font-weight:900; color:var(--accent2)">@_games.Count</div>
                        <div class="text-dim" style="font-size:.8rem; text-transform:uppercase; letter-spacing:1px">@L["Leaderboard.Games"]</div>
                    </div>
                    <div class="card" style="text-align:center; min-width:120px">
                        <div style="font-size:1.5rem; font-weight:900; color:var(--accent2)">@_games.Count(g => IsActiveStatus(g.Status))</div>
                        <div class="text-dim" style="font-size:.8rem; text-transform:uppercase; letter-spacing:1px">@L["MyGames.Active"]</div>
                    </div>
                    <div class="card" style="text-align:center; min-width:120px">
                        <div style="font-size:1.5rem; font-weight:900; color:var(--gold)">@_games.Count(g => IsAbandonedStatus(g.Status))</div>
                        <div class="text-dim" style="font-size:.8rem; text-transform:uppercase; letter-spacing:1px">@L["MyGames.Abandoned"]</div>
                    </div>
                    <div class="card" style="text-align:center; min-width:120px">
                        <div style="font-size:1.5rem; font-weight:900; color:var(--success)">@_games.Count(g => g.IsWinner)</div>
                        <div class="text-dim" style="font-size:.8rem; text-transform:uppercase; letter-spacing:1px">@L["Leaderboard.Wins"]</div>
                    </div>
                </div>

                <div style="overflow-x:auto">
                    <table class="lb-table" aria-label="@L["MyGames.TableAria"]">
                        <thead>
                            <tr>
                                <th scope="col">@L["MyGames.Date"]</th>
                                <th scope="col">@L["Leaderboard.Level"]</th>
                                <th scope="col">@L["CreateGame.Mode"]</th>
                                <th scope="col">@L["MyGames.Duration"]</th>
                                <th scope="col">@L["MyGames.Status"]</th>
                                <th scope="col">@L["MyGames.Result"]</th>
                                <th scope="col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in _games)
                            {
                                <tr class="@(g.IsWinner ? "me" : "")">
                                    <td>@g.EndedAt.ToString("dd/MM/yy HH:mm")</td>
                                    <td>@g.GameLevel</td>
                                    <td>@g.Queue</td>
                                    <td>@FormatDuration(g.DurationSeconds)</td>
                                    <td><span class="chip chip-muted">@StatusLabel(g.Status)</span></td>
                                    <td>
                                        @if (IsActiveStatus(g.Status))
                                            { <span class="chip chip-accent">@L["MyGames.Active"]</span> }
                                        else if (g.IsWinner)
                                            { <span class="chip chip-success">@L["MyGames.Victory"] 🏆</span> }
                                        else if (IsAbandonedStatus(g.Status))
                                            { <span class="chip chip-muted">@L["MyGames.AbandonedOne"]</span> }
                                        else
                                            { <span class="chip chip-muted">@L["MyGames.Defeat"]</span> }
                                    </td>
                                    <td><a href="/games/@g.GameId" class="btn btn-ghost btn-sm">@L["MyGames.View"]</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private readonly List<WebGameHistoryItem> _games = [];
    private bool _busy;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        Auth.OnAuthStateChanged += HandleAuthChanged;
        await Auth.InitializeAsync();
        if (!Auth.IsLoggedIn) { StateHasChanged(); return; }
        await LoadAsync();
        StateHasChanged();
    }

    private async void HandleAuthChanged()
    {
        if (!Auth.IsLoggedIn)
        {
            _games.Clear();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_busy) return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (token is null) { _error = L["Auth.SessionExpired"]; return; }
            _games.Clear();
            _games.AddRange(await Api.GetMyGamesAsync(token));
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; StateHasChanged(); }
    }

    private static string FormatDuration(int s) =>
        s < 60 ? $"{s}s" : s < 3600 ? $"{s / 60}m{s % 60:D2}s" : $"{s / 3600}h{(s % 3600) / 60:D2}m";

    private static bool IsActiveStatus(string status) =>
        string.Equals(status, "active", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(status, "waiting", StringComparison.OrdinalIgnoreCase);

    private static bool IsAbandonedStatus(string status) =>
        string.Equals(status, "abandoned", StringComparison.OrdinalIgnoreCase);

    private string StatusLabel(string status) => status.ToLowerInvariant() switch
    {
        "active" => L["MyGames.Active"],
        "waiting" => L["MyGames.Waiting"],
        "abandoned" => L["MyGames.AbandonedOne"],
        "ended" => L["Game.Status.Finished"],
        "finished_normal" => L["Game.Status.Finished"],
        _ => status
    };

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= HandleAuthChanged;
    }
}
