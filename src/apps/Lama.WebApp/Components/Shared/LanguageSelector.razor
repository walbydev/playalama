@inject LanguageService Lang
@using Lama.WebApp.Services
@inject IStringLocalizer<SharedResource> L

<select class="lang-selector" aria-label="@L["Language.Label"]" value="@Lang.Current"
        @onchange="OnChange" title="@L["Language.Label"]">
    @foreach (var item in LanguageService.Available)
    {
        <option value="@item.Code">@item.Label</option>
    }
</select>

@code {
    private async Task OnChange(ChangeEventArgs e)
    {
        var selected = e.Value?.ToString() ?? "fr";
        await Lang.SetAsync(selected);
    }
}
