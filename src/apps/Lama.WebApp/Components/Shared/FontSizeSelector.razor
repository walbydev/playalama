@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<div class="accessibility-control" title="@L["Accessibility.FontSize.Title"]">
    <button type="button" class="font-size-btn" @onclick="OnDecrease" aria-label="@L["Accessibility.FontSize.Decrease"]" title="@L["Accessibility.FontSize.Decrease"]">
        <span aria-hidden="true">A-</span>
    </button>
    <span class="font-size-label" aria-live="polite">@_fontSize%</span>
    <button type="button" class="font-size-btn" @onclick="OnIncrease" aria-label="@L["Accessibility.FontSize.Increase"]" title="@L["Accessibility.FontSize.Increase"]">
        <span aria-hidden="true">A+</span>
    </button>
</div>

@code {
    private string _fontSize = "100";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _fontSize = await JS.InvokeAsync<string>("playalamaAccessibility.getFontSize");
            StateHasChanged();
        }
    }

    private async Task OnIncrease()
    {
        await JS.InvokeVoidAsync("playalamaAccessibility.increaseFontSize");
        _fontSize = await JS.InvokeAsync<string>("playalamaAccessibility.getFontSize");
        StateHasChanged();
    }

    private async Task OnDecrease()
    {
        await JS.InvokeVoidAsync("playalamaAccessibility.decreaseFontSize");
        _fontSize = await JS.InvokeAsync<string>("playalamaAccessibility.getFontSize");
        StateHasChanged();
    }

    public void Dispose()
    {
    }
}
