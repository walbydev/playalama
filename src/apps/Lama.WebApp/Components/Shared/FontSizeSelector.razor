@inject IJSRuntime JS
@inject AuthService Auth
@inject LamaApiClient Api
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<div class="accessibility-control" title="@L["Accessibility.FontSizeLabel"]">
    <button type="button" class="font-size-btn" @onclick="OnDecrease" aria-label="@L["Accessibility.FontSize.Decrease"]" title="@L["Accessibility.FontSize.Decrease"]">
        <span aria-hidden="true">A-</span>
    </button>
    <span class="font-size-label" aria-live="polite">@_fontSize%</span>
    <button type="button" class="font-size-btn" @onclick="OnIncrease" aria-label="@L["Accessibility.FontSize.Increase"]" title="@L["Accessibility.FontSize.Increase"]">
        <span aria-hidden="true">A+</span>
    </button>
</div>

@code {
    private string _fontSize = "100";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _fontSize = await JS.InvokeAsync<string>("playalamaAccessibility.getFontSize");
            StateHasChanged();
        }
    }

    private async Task OnIncrease()
    {
        await JS.InvokeVoidAsync("playalamaAccessibility.increaseFontSize");
        _fontSize = await JS.InvokeAsync<string>("playalamaAccessibility.getFontSize");
        await PersistAccessibilityAsync();
        StateHasChanged();
    }

    private async Task OnDecrease()
    {
        await JS.InvokeVoidAsync("playalamaAccessibility.decreaseFontSize");
        _fontSize = await JS.InvokeAsync<string>("playalamaAccessibility.getFontSize");
        await PersistAccessibilityAsync();
        StateHasChanged();
    }

    private async Task PersistAccessibilityAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsLoggedIn)
            return;

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
            return;

        try
        {
            var theme = await JS.InvokeAsync<string>("playalamaTheme.getTheme");
            var layout = await JS.InvokeAsync<GameLayoutState?>("playalamaGameLayout.get");
            var boardScale = layout?.Density switch
            {
                "s" => 0.85,
                "l" => 1.5,
                "xl" => 1.8,
                "xxl" => 2.0,
                _ => 1.0
            };
            var fontSize = int.TryParse(_fontSize, out var parsedSize) ? parsedSize : 100;

            await Api.UpdateMyAccessibilityAsync(token, new WebAccessibilityPreferences(NormalizeTheme(theme), NormalizeFontSize(fontSize), boardScale));
        }
        catch (HttpRequestException)
        {
        }
        catch (UnauthorizedAccessException)
        {
        }
    }

    private static int NormalizeFontSize(int size) => size is 50 or 75 or 100 or 125 or 150 or 175 or 200 ? size : 100;
    private static string NormalizeTheme(string theme) => theme switch
    {
        "dark" or "light" or "blue" or "green" or "vermillion" or "highcontrast" or "deuteranopia" or "protanopia" or "tritanopia" => theme,
        _ => "dark"
    };
    private sealed record GameLayoutState(string? Density, bool Fullscreen, string[]? Collapsed, string? ActiveTab, string? Variant);

    public void Dispose()
    {
    }
}
