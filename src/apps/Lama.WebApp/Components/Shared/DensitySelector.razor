@inject GameLayoutService Layout
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<button class="navbar-action @(Layout.IsFullscreen ? "is-active" : "")"
        @onclick="ToggleFullscreenAsync"
        title="@L["BoardDensity.Fullscreen"]"
        aria-pressed="@Layout.IsFullscreen">
    <span aria-hidden="true">⛶</span>
    <span class="navbar-action-label">@L["BoardDensity.Fullscreen"]</span>
</button>

@code {
    protected override void OnInitialized() => Layout.Changed += HandleChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Layout.InitializeAsync();
        StateHasChanged();
    }

    private async Task ToggleFullscreenAsync() => await Layout.ToggleFullscreenAsync();

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Layout.Changed -= HandleChanged;
}
