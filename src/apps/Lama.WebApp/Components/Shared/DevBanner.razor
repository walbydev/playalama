@using Lama.WebApp.Services

<div class="dev-banner" role="alert" aria-label="Mode développement">
    <span>🚧 En développement</span>
    <span class="dev-banner-sep">|</span>
    <span>v@BuildInfoConstants.Version</span>
    <span class="dev-banner-sep">|</span>
    <span>#@BuildInfoConstants.BuildNumber</span>
    <span class="dev-banner-sep">|</span>
    <span>Build : @FormatTime(BuildInfoConstants.BuildTimestamp)</span>
</div>

@code {
    private static string FormatTime(string timestamp)
    {
        if (DateTime.TryParse(timestamp, out var dt))
            return dt.ToString("dd/MM/yyyy HH:mm");
        return "–";
    }
}
