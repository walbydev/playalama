@using Lama.WebApp.Services
@using Lama.WebApp.ViewModels
@inject GameLayoutService Layout
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

@* Plateau de jeu 15×15 avec cases bonus colorées, tuiles posées et placements provisoires. *@

<div class="board-container" role="region" aria-label="@L["Board.Aria"]" style="--board-scale:@Layout.ScaleCss;">
    <div class="board-grid" role="grid"
         @onpointerup="HandlePointerUp"
         @onpointerleave="HandlePointerLeave">
        @* En-tête colonnes *@
        <div class="board-header-cell" aria-hidden="true"></div>
        @for (var c = 0; c < 15; c++)
        {
            var colLabel = GamePlayViewModel.ColLabel(c);
            <div class="board-header-cell" aria-hidden="true">@colLabel</div>
        }
        <div class="board-header-cell" aria-hidden="true"></div>

        @* Lignes *@
        @for (var row = 0; row < 15; row++)
        {
            var r = row; // capture
            <div class="board-header-cell" aria-hidden="true">@GamePlayViewModel.RowLabel(r)</div>
            @for (var col = 0; col < 15; col++)
            {
                var c = col; // capture
                var tile = GetTile(r, c);
                var pending = GetPendingTile(r, c);
                var bonus = GetBonus(r, c);
                var isDropTarget = CanDrop && tile is null && (pending is null || _draggingFromBoard);
                var isKeyboardCursor = KeyboardModeActive && r == KeyboardCursorRow && c == KeyboardCursorCol;
                var isKeyboardTarget = CanActivateKeyboard && OnKeyboardActivate.HasDelegate && tile is null && pending is null;
                var isWordSelected = IsInWordSelection(r, c);
                var cellTitle = bonus == "st" ? L["Tooltip.CenterStar"].Value : null;

                string cssClass;
                string ariaLabel;

                if (tile.HasValue)
                {
                    cssClass = "board-cell board-cell--tile" + (isWordSelected ? " board-cell--word-select" : "");
                    ariaLabel = L["Board.TileAria", GamePlayViewModel.ColLabel(c), r + 1, char.ToUpperInvariant(tile.Value)].Value;
                }
                else if (pending is not null)
                {
                    cssClass = "board-cell board-cell--pending";
                    ariaLabel = L["Board.PendingTileAria", GamePlayViewModel.ColLabel(c), r + 1, char.ToUpperInvariant(pending.Letter)].Value;
                }
                else
                {
                    var cursorDir = isKeyboardCursor
                        ? " board-cell--kbd-cursor " + (KeyboardIsHorizontal ? "board-cell--kbd-dir-h" : "board-cell--kbd-dir-v")
                        : "";
                    cssClass = $"board-cell{cursorDir}{(string.IsNullOrEmpty(bonus) ? "" : $" board-cell--{bonus}")}";
                    ariaLabel = L["Board.CellAria", GamePlayViewModel.ColLabel(c), r + 1, GetBonusAriaLabel(bonus)].Value;
                }

                <div class="@cssClass"
                     role="gridcell"
                     aria-label="@ariaLabel"
                     title="@cellTitle"
                     @ondragover:preventDefault="@isDropTarget"
                     @ondrop="@(isDropTarget ? () => OnDrop.InvokeAsync((r, c)) : () => Task.CompletedTask)"
                     @onclick="@(pending is not null ? () => OnRecall.InvokeAsync((r, c)) : tile.HasValue && !_isWordSelecting ? () => OnTileClick.InvokeAsync((r, c)) : HasSelectedRackTile && tile is null ? () => OnDrop.InvokeAsync((r, c)) : () => Task.CompletedTask)"
                     @ondblclick="@(isKeyboardTarget ? () => OnKeyboardActivate.InvokeAsync((r, c)) : () => Task.CompletedTask)"
                     @ontouchend="@(isKeyboardTarget ? (e) => HandleTouchEnd(e, r, c) : (Func<TouchEventArgs,Task>)(_ => Task.CompletedTask))"
                     @onpointerdown="@(tile.HasValue ? () => HandleCellPointerDown(r, c) : () => Task.CompletedTask)"
                     @onpointerenter="@(_isWordSelecting ? () => HandleCellPointerEnter(r, c) : () => Task.CompletedTask)"
                     draggable="@(pending is not null && CanDragPending ? "true" : "false")"
                     @ondragstart="@(pending is not null ? () => OnPendingDragStart.InvokeAsync((r, c)) : () => Task.CompletedTask)"
                     @ondragstart:stopPropagation
                     data-row="@r" data-col="@c">
                    @if (tile.HasValue)
                    {
                        var upper = char.ToUpperInvariant(tile.Value);
                        var val = GamePlayViewModel.GetTileValue(tile.Value);
                        <span class="tile-letter" aria-hidden="true">@upper</span>
                        @if (val > 0)
                        {
                            <span class="tile-val" aria-hidden="true">@val</span>
                        }
                    }
                    else if (pending is not null)
                    {
                        var dispLetter = pending.IsJoker
                            ? (pending.Letter == '*' ? "?" : char.ToUpperInvariant(pending.Letter).ToString())
                            : char.ToUpperInvariant(pending.Letter).ToString();
                        var val = pending.IsJoker ? 0 : GamePlayViewModel.GetTileValue(pending.Letter);
                        <span class="tile-letter" aria-hidden="true">@dispLetter</span>
                        @if (val > 0)
                        {
                            <span class="tile-val" aria-hidden="true">@val</span>
                        }
                    }
                    else if (!string.IsNullOrEmpty(bonus))
                    {
                        <span class="board-label" aria-hidden="true">@GetBonusLabel(bonus)</span>
                    }
                    else if (r == 7 && c == 7)
                    {
                        <span aria-hidden="true">★</span>
                    }
                </div>
            }
            <div class="board-header-cell" aria-hidden="true">@GamePlayViewModel.RowLabel(r)</div>
        }

        @* Pied colonnes *@
        <div class="board-header-cell" aria-hidden="true"></div>
        @for (var c = 0; c < 15; c++)
        {
            var colLabel = GamePlayViewModel.ColLabel(c);
            <div class="board-header-cell" aria-hidden="true">@colLabel</div>
        }
        <div class="board-header-cell" aria-hidden="true"></div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<WebBoardTile> Board { get; set; } = [];
    [Parameter, EditorRequired] public Func<int, int, string> GetBonus { get; set; } = (_, _) => string.Empty;
    [Parameter] public IReadOnlyList<PendingPlacement> Pending { get; set; } = [];
    [Parameter] public bool CanDrop { get; set; }
    [Parameter] public bool DraggingFromBoard { get; set; }
    [Parameter] public bool KeyboardModeActive { get; set; }
    [Parameter] public int KeyboardCursorRow { get; set; } = -1;
    [Parameter] public int KeyboardCursorCol { get; set; } = -1;
    /// <summary>Direction du curseur clavier : true = horizontal, false = vertical.</summary>
    [Parameter] public bool KeyboardIsHorizontal { get; set; } = true;
    /// <summary>Vrai si une tuile du rack est sélectionnée (clic) — le clic sur une case vide la dépose.</summary>
    [Parameter] public bool HasSelectedRackTile { get; set; }
    /// <summary>Vrai si c'est le tour du joueur — tuiles provisoires déplaçables même sans drag actif.</summary>
    [Parameter] public bool CanDragPending { get; set; }
    /// <summary>Vrai si le double-clic/double-tap peut activer le clavier — indépendant de CanDrop.</summary>
    [Parameter] public bool CanActivateKeyboard { get; set; }
    [Parameter] public EventCallback<(int Row, int Col)> OnDrop { get; set; }
    [Parameter] public EventCallback<(int Row, int Col)> OnRecall { get; set; }
    [Parameter] public EventCallback<(int Row, int Col)> OnTileClick { get; set; }
    [Parameter] public EventCallback<(int Row, int Col)> OnPendingDragStart { get; set; }
    /// <summary>Activé par double-clic (souris) ou double-tap (tactile) sur une case vide.</summary>
    [Parameter] public EventCallback<(int Row, int Col)> OnKeyboardActivate { get; set; }
    /// <summary>Activé quand l'utilisateur sélectionne un mot par glisser sur les tuiles posées.</summary>
    [Parameter] public EventCallback<string> OnWordSelected { get; set; }

    private bool _draggingFromBoard => DraggingFromBoard;

    // ── Sélection de mot par glisser ───────────────────────────────────────────
    private bool _isWordSelecting;
    private int _wordSelectStartRow = -1;
    private int _wordSelectStartCol = -1;
    private int _wordSelectEndRow = -1;
    private int _wordSelectEndCol = -1;

    private bool IsInWordSelection(int row, int col)
    {
        if (!_isWordSelecting && _wordSelectStartRow < 0) return false;
        var (r0, r1) = (_wordSelectStartRow, _wordSelectEndRow);
        var (c0, c1) = (_wordSelectStartCol, _wordSelectEndCol);
        if (r0 > r1) (r0, r1) = (r1, r0);
        if (c0 > c1) (c0, c1) = (c1, c0);
        return row >= r0 && row <= r1 && col >= c0 && col <= c1;
    }

    private Task HandleCellPointerDown(int row, int col)
    {
        _isWordSelecting = true;
        _wordSelectStartRow = row;
        _wordSelectStartCol = col;
        _wordSelectEndRow = row;
        _wordSelectEndCol = col;
        return Task.CompletedTask;
    }

    private Task HandleCellPointerEnter(int row, int col)
    {
        if (!_isWordSelecting) return Task.CompletedTask;

        // Contraindre à la ligne ou colonne de départ
        if (row == _wordSelectStartRow)
        {
            _wordSelectEndRow = row;
            _wordSelectEndCol = col;
        }
        else if (col == _wordSelectStartCol)
        {
            _wordSelectEndRow = row;
            _wordSelectEndCol = col;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandlePointerUp(PointerEventArgs e)
    {
        if (!_isWordSelecting)
            return Task.CompletedTask;

        _isWordSelecting = false;

        var word = ExtractSelectedWord();
        var hadSelection = _wordSelectStartRow >= 0;
        _wordSelectStartRow = -1;
        _wordSelectStartCol = -1;
        _wordSelectEndRow = -1;
        _wordSelectEndCol = -1;
        StateHasChanged();

        if (hadSelection && word.Length >= 2 && OnWordSelected.HasDelegate)
            return OnWordSelected.InvokeAsync(word);

        return Task.CompletedTask;
    }

    private Task HandlePointerLeave(PointerEventArgs e)
    {
        if (!_isWordSelecting) return Task.CompletedTask;
        _isWordSelecting = false;
        _wordSelectStartRow = -1;
        _wordSelectStartCol = -1;
        _wordSelectEndRow = -1;
        _wordSelectEndCol = -1;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private string ExtractSelectedWord()
    {
        if (_wordSelectStartRow < 0) return string.Empty;

        var board = Board;
        char? At(int r, int c) => board.FirstOrDefault(t => t.Row == r && t.Column == c)?.Letter;

        var (r0, r1) = (Math.Min(_wordSelectStartRow, _wordSelectEndRow), Math.Max(_wordSelectStartRow, _wordSelectEndRow));
        var (c0, c1) = (Math.Min(_wordSelectStartCol, _wordSelectEndCol), Math.Max(_wordSelectStartCol, _wordSelectEndCol));

        var word = "";
        if (r0 == r1)
        {
            for (var c = c0; c <= c1; c++)
            {
                if (At(r0, c) is { } ch) word += char.ToUpperInvariant(ch);
            }
        }
        else if (c0 == c1)
        {
            for (var r = r0; r <= r1; r++)
            {
                if (At(r, c0) is { } ch) word += char.ToUpperInvariant(ch);
            }
        }
        return word;
    }

    protected override void OnInitialized()
    {
        Layout.Changed += HandleZoomChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Layout.InitializeAsync();
        StateHasChanged();
    }

    // ── Détection double-tap tactile ─────────────────────────────────────────

    private long _lastTapMs;
    private int  _lastTapRow = -1;
    private int  _lastTapCol = -1;
    private const int DoubleTapThresholdMs = 350;

    private Task HandleTouchEnd(TouchEventArgs e, int row, int col)
    {
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        var delta = now - _lastTapMs;

        if (delta <= DoubleTapThresholdMs && _lastTapRow == row && _lastTapCol == col)
        {
            // Double-tap détecté — réinitialiser pour éviter triple-déclenchement
            _lastTapMs  = 0;
            _lastTapRow = -1;
            _lastTapCol = -1;
            return OnKeyboardActivate.InvokeAsync((row, col));
        }

        _lastTapMs  = now;
        _lastTapRow = row;
        _lastTapCol = col;
        return Task.CompletedTask;
    }

    private char? GetTile(int row, int col)
    {
        var tile = Board.FirstOrDefault(x => x.Row == row && x.Column == col);
        return tile?.Letter;
    }

    private PendingPlacement? GetPendingTile(int row, int col) =>
        Pending.FirstOrDefault(p => p.Row == row && p.Col == col);

    private string GetBonusLabel(string bonus) => bonus switch
    {
        "tw" => L["Board.TripleWord.Short"].Value,
        "dw" => L["Board.DoubleWord.Short"].Value,
        "tl" => "TL",
        "dl" => "DL",
        "st" => "★",
        _ => string.Empty
    };

    private string GetBonusAriaLabel(string bonus) => bonus switch
    {
        "tw" => " — " + L["Board.Bonus.TripleWord"].Value,
        "dw" => " — " + L["Board.Bonus.DoubleWord"].Value,
        "tl" => " — " + L["Board.Bonus.TripleLetter"].Value,
        "dl" => " — " + L["Board.Bonus.DoubleLetter"].Value,
        "st" => " — " + L["Board.Bonus.Start"].Value,
        _ => string.Empty
    };

    private void HandleZoomChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Layout.Changed -= HandleZoomChanged;
    }
}
