@inject ThemeService Theme
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<div class="theme-select-control" title="@L["Theme.Title"]">
    <span class="theme-select-icon" aria-hidden="true">🎨</span>
    <label class="sr-only" for="theme-select">@L["Theme.Choose"]</label>
    <select id="theme-select"
            class="theme-select"
            value="@Theme.Theme"
            @onchange="OnThemeChanged"
            aria-label="@L["Theme.Choose"]">
        <option value="light">@L["Theme.Light"]</option>
        <option value="dark">@L["Theme.Dark"]</option>
        <option value="blue">@L["Theme.Blue"]</option>
        <option value="green">@L["Theme.Green"]</option>
        <option value="vermillion">@L["Theme.Vermillion"]</option>
        <option value="highcontrast">@L["Theme.HighContrast"]</option>
        <option value="deuteranopia">@L["Theme.Deuteranopia"]</option>
        <option value="protanopia">@L["Theme.Protanopia"]</option>
        <option value="tritanopia">@L["Theme.Tritanopia"]</option>
    </select>
</div>

@code {
    protected override void OnInitialized()
    {
        Theme.ThemeChanged += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Theme.InitializeAsync();
        StateHasChanged();
    }

    private async Task OnThemeChanged(ChangeEventArgs args)
    {
        if (args.Value is null) return;
        await Theme.SetAsync(args.Value.ToString() ?? "dark");
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Theme.ThemeChanged -= HandleThemeChanged;
    }
}
