@inject GameLayoutService Layout
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

@* Sélecteur position du plateau *@
<button type="button"
        class="btn btn-ghost btn-sm layout-btn @(IsBoardLeft ? "is-active" : "")"
        @onclick="() => SetBoardSideAsync(true)"
        title="@L["Layout.BoardLeft"]">
    <span aria-hidden="true">◀</span> @L["Layout.BoardLeft"]
</button>
<button type="button"
        class="btn btn-ghost btn-sm layout-btn @(!IsBoardLeft ? "is-active" : "")"
        @onclick="() => SetBoardSideAsync(false)"
        title="@L["Layout.BoardRight"]">
    <span aria-hidden="true">▶</span> @L["Layout.BoardRight"]
</button>

@* Sélecteur position du rack — caché en thème compact *@
<span class="layout-rack-controls">
<button type="button"
        class="btn btn-ghost btn-sm layout-btn @(IsRackBelow ? "is-active" : "")"
        @onclick="() => SetRackPositionAsync(true)"
        title="@L["Layout.RackBottom"]">
    <span aria-hidden="true">⬇</span> @L["Layout.RackBottom"]
</button>
<button type="button"
        class="btn btn-ghost btn-sm layout-btn @(!IsRackBelow ? "is-active" : "")"
        @onclick="() => SetRackPositionAsync(false)"
        title="@L["Layout.RackTop"]">
    <span aria-hidden="true">⬆</span> @L["Layout.RackTop"]
</button>
</span>

@code {
    private bool IsBoardLeft => Layout.Variant is GameLayoutService.VariantA or GameLayoutService.VariantC;
    private bool IsRackBelow => Layout.Variant is GameLayoutService.VariantA or GameLayoutService.VariantB;

    protected override void OnInitialized() => Layout.Changed += HandleChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Layout.InitializeAsync();
        StateHasChanged();
    }

    private async Task SetBoardSideAsync(bool left)
    {
        var v = (left, IsRackBelow) switch
        {
            (true,  true)  => GameLayoutService.VariantA,
            (false, true)  => GameLayoutService.VariantB,
            (true,  false) => GameLayoutService.VariantC,
            _              => GameLayoutService.VariantD,
        };
        await Layout.SetVariantAsync(v);
    }

    /// <param name="below">true = rack en bas, false = rack en haut.</param>
    private async Task SetRackPositionAsync(bool below)
    {
        var v = (IsBoardLeft, below) switch
        {
            (true,  true)  => GameLayoutService.VariantA,
            (false, true)  => GameLayoutService.VariantB,
            (true,  false) => GameLayoutService.VariantC,
            _              => GameLayoutService.VariantD,
        };
        await Layout.SetVariantAsync(v);
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Layout.Changed -= HandleChanged;
}
