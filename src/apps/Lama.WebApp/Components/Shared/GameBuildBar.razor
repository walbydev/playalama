@using Lama.WebApp.Services
@inject IStringLocalizer<SharedResource> L

<div class="build-info-sticky" role="status" aria-label="@L["DevBanner.Aria"]">
    <span>🚧 @L["DevBanner.InDevelopment"]</span>
    <span class="dev-banner-sep">|</span>
    <span>v&nbsp;@BuildInfoConstants.Version</span>
    <span class="dev-banner-sep">|</span>
    <span>#@BuildInfoConstants.BuildNumber</span>
    <span class="dev-banner-sep">|</span>
    <span>@L["DevBanner.Build"] @FormatTime(BuildInfoConstants.BuildTimestamp)</span>
</div>

@code {
    private static string FormatTime(string timestamp)
    {
        if (DateTime.TryParse(timestamp, out var dt))
            return dt.ToString("dd/MM/yyyy HH:mm");
        return "–";
    }
}
