@inject AuthService Auth
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<nav class="navbar @(CompactMode ? "navbar--compact" : "")" role="navigation" aria-label="@L["Nav.Aria"]">
    <a href="/" class="navbar-logo" aria-label="@L["Nav.LogoAria"]">
        PLAYALAMA
    </a>

    @if (!CompactMode)
    {
        <ul class="navbar-links @(_menuOpen ? "open" : "")" id="nav-links">
            <li><a href="/" class="@ActiveClass("/")" @onclick="CloseMenu">@L["Nav.Home"]</a></li>
            <li><a href="/leaderboard" class="@ActiveClass("/leaderboard")" @onclick="CloseMenu">@L["Nav.Leaderboard"]</a></li>
            <li><a href="/rules" class="@ActiveClass("/rules")" @onclick="CloseMenu">@L["Nav.Rules"]</a></li>
            <li><a href="/accessibility" class="@ActiveClass("/accessibility")" @onclick="CloseMenu">@L["Nav.Accessibility"]</a></li>
            @if (Auth.IsLoggedIn)
            {
                <li><a href="/games" class="@ActiveClass("/games")" @onclick="CloseMenu">@L["Nav.Games"]</a></li>
                <li><a href="/my-games" class="@ActiveClass("/my-games")" @onclick="CloseMenu">@L["Nav.MyGames"]</a></li>
            }
            @if (Auth.IsAdmin)
            {
                <li><a href="/admin" class="@ActiveClass("/admin")" @onclick="CloseMenu">🔧 @L["Nav.Admin"]</a></li>
            }
            <li class="navbar-mobile-auth">
                @if (!Auth.IsInitialized)
                {
                    <span class="text-muted" aria-live="polite">@L["Common.Loading"]</span>
                }
                else if (Auth.IsLoggedIn)
                {
                    <a href="/profile" @onclick="CloseMenu" class="navbar-mobile-user">
                        @Auth.CurrentUser!.Username
                        @if (Auth.CurrentRating is { } r)
                        {
                            <span class="lb-level" title="@r.LevelName | ELO @r.EloOpen">@r.LevelEmoji</span>
                        }
                    </a>
                    <button class="btn btn-outline" type="button" @onclick="LogoutAsync">@L["Nav.Logout"]</button>
                }
                else
                {
                    <a href="/login" @onclick="CloseMenu" class="btn btn-ghost">@L["Nav.Login"]</a>
                    <a href="/register" @onclick="CloseMenu" class="btn btn-primary">@L["Nav.PlayNow"] →</a>
                }
            </li>
        </ul>
    }

    <div class="navbar-actions">
        <DensitySelector />
        <QuickSettingsPanel />
        <div class="navbar-auth-desktop">
            @if (!Auth.IsInitialized)
            {
                <span class="text-muted" style="font-size:.85rem;display:inline-flex;align-items:center;min-height:2.5rem" aria-live="polite">@L["Common.Loading"]</span>
            }
            else if (Auth.IsLoggedIn)
            {
                <a href="/profile" class="navbar-action">
                    <span aria-hidden="true">👤</span>
                    <span class="navbar-action-label">@Auth.CurrentUser!.Username</span>
                    @if (Auth.CurrentRating is { } r)
                    {
                        <span class="lb-level" title="@r.LevelName | ELO @r.EloOpen">@r.LevelEmoji</span>
                    }
                </a>
                @if (!CompactMode)
                {
                    <button class="navbar-action" type="button" @onclick="LogoutAsync">
                        <span class="navbar-action-label">@L["Nav.Logout"]</span>
                    </button>
                }
            }
            else
            {
                <a href="/login" class="navbar-action">
                    <span class="navbar-action-label">@L["Nav.Login"]</span>
                </a>
                @if (!CompactMode)
                {
                    <a href="/register" class="navbar-action navbar-action--primary">
                        <span class="navbar-action-label">@L["Nav.PlayNow"]</span>
                        <span aria-hidden="true">→</span>
                    </a>
                }
            }
        </div>
        @if (!CompactMode)
        {
            <button class="navbar-action navbar-burger" type="button" @onclick="ToggleMenu"
                    aria-expanded="@_menuOpen" aria-controls="nav-links"
                    aria-label="@L["Nav.Menu"]">
                @(_menuOpen ? "✕" : "☰")
            </button>
        }
    </div>
</nav>

@if (!CompactMode && _menuOpen)
{
    <div class="navbar-backdrop" @onclick="CloseMenu" aria-hidden="true"></div>
}

<!-- Spacer pour compenser la navbar fixe -->
<div style="height: @SpacerHeight" aria-hidden="true"></div>

@code {
    [Parameter] public bool CompactMode { get; set; }

    private bool _menuOpen;
    private string SpacerHeight => CompactMode ? "56px" : "var(--nav-h)";

    protected override void OnInitialized()
    {
        Auth.OnAuthStateChanged += HandleAuthChanged;
    }

    private void HandleAuthChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= HandleAuthChanged;
    }

    private string ActiveClass(string path)
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        var rel     = path.TrimStart('/');
        return (rel == "" ? current == "" : current.StartsWith(rel, StringComparison.OrdinalIgnoreCase))
            ? "active" : "";
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu()  => _menuOpen = false;

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/");
    }
}
