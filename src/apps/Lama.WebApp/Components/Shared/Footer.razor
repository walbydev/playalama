@inject IStringLocalizer<SharedResource> L

<footer role="contentinfo">
    <div class="footer-grid">
        <div class="footer-brand">
            <div class="navbar-logo" style="font-size:2rem" aria-label="Playalama">PLAYALAMA</div>
            <p>@L["Footer.Tagline"]</p>
        </div>
        <div class="footer-col">
            <h4>@L["Footer.Game"]</h4>
            <ul>
                <li><a href="/games">@L["Footer.PlayOnline"]</a></li>
                <li><a href="/downloads">@L["Footer.Download"]</a></li>
                <li><a href="/#modes">@L["Footer.GameModes"]</a></li>
                <li><a href="/leaderboard">@L["Footer.Leaderboards"]</a></li>
            </ul>
        </div>
        <div class="footer-col">
            <h4>@L["Nav.Rules"]</h4>
            <ul>
                <li><a href="/rules">@L["Footer.CommonRules"]</a></li>
                <li><a href="/rules#classique">@L["Footer.ModeClassic"]</a></li>
                <li><a href="/rules#solo-ia">@L["Footer.ModeSoloAI"]</a></li>
            </ul>
        </div>
        <div class="footer-col">
            <h4>@L["Footer.Project"]</h4>
            <ul>
                <li><a href="https://github.com/walbydev/playalama" target="_blank" rel="noopener noreferrer">
                    <img src="https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png" alt="GitHub" style="width: 14px; height: 14px; display: inline; margin-right: 4px; filter: invert(1);" />
                    GitHub
                </a></li>
                <li><a href="/documentation">@L["Footer.Documentation"]</a></li>
                <li><a href="/contact">@L["Footer.Contact"]</a></li>
                <li><a href="/license">@L["Footer.License"]</a></li>
                <li><a href="/status" style="opacity:.7;font-size:.95rem">@L["Footer.Admin"]</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <span>@L["Footer.Copyright"]</span>
        <div class="footer-socials" aria-label="@L["Footer.Social"]">
            <a href="https://discord.gg/6ZRWrcjzbB" 
               target="_blank" 
               rel="noopener noreferrer"
               title="Discord"
               aria-label="Discord"
               style="
                 background-color: #5865F2;
                 color: white;
                 padding: 8px 16px;
                 border-radius: 6px;
                 text-decoration: none;
                 font-weight: bold;
                 font-size: 0.9rem;
                 display: inline-flex;
                 align-items: center;
                gap: 8px;
                 transition: background-color 0.2s ease;
               "
               onmouseover="this.style.backgroundColor='#4752C4'"
               onmouseout="this.style.backgroundColor='#5865F2'">
             <img src="https://assets-global.ssl.fastly.net/pages/discord-icon.svg" alt="Discord" style="width: 18px; height: 18px;" />
             @L["Footer.JoinDiscord"]
            </a>
        </div>
    </div>
</footer>
