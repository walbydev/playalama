@inject HomeViewModel VM

<section id="modes" class="section bg2" aria-labelledby="modes-title">
    <div class="container">
        <div class="section-header">
            <div class="eyebrow">Modes de jeu</div>
            <h2 id="modes-title">Un jeu, mille façons de jouer</h2>
            <p>Du classique épuré aux variantes les plus folles — chaque partie est unique.</p>
        </div>

        <div class="modes-grid" role="list" aria-label="Modes de jeu disponibles">
            @foreach (var mode in VM.Modes)
            {
                <div role="listitem">
                    <GameModeCard Mode="mode" />
                </div>
            }
        </div>
    </div>
</section>
