@inject HomeViewModel VM
@inject IStringLocalizer<SharedResource> L
@inject AuthService Auth

<section id="modes" class="section bg2" aria-labelledby="modes-title">
    <div class="container">
        <div class="section-header">
            <div class="eyebrow">@L["Home.Modes.Eyebrow"]</div>
            <h2 id="modes-title">@L["Home.Modes.Title"]</h2>
            <p>@L["Home.Modes.Subtitle"]</p>
        </div>

        <div class="modes-grid" role="list" aria-label="@L["Home.Modes.Aria"]">
            @foreach (var mode in VM.Modes.Where(m => !m.IsAdminOnly || Auth.IsAdmin))
            {
                <div role="listitem">
                    <GameModeCard Mode="mode" />
                </div>
            }
        </div>
    </div>
</section>
