@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AuthService Auth
@inject ThemeService Theme
@inject BoardZoomService BoardZoom
@implements IDisposable

<div class="page-wrapper @(IsGameFocusMode ? "page-wrapper--game-focus" : "")">
    @if (!IsGameFocusMode)
    {
        <DevBanner />
    }
    <NavBar CompactMode="@IsGameFocusMode" ShowDevBanner="@(!IsGameFocusMode)" />

    <main id="main-content" class="@(IsGameFocusMode ? "main-content--game-focus" : null)">
        @Body
    </main>

    @if (!IsGameFocusMode)
    {
        <Footer />
    }
</div>

@code {
    private bool IsGameFocusMode =>
        BoardZoom.IsAutoFit && IsInGamePage();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Nav.LocationChanged += HandleLocationChanged;
            BoardZoom.ZoomChanged += HandleZoomChanged;
            await Auth.InitializeAsync();
            await Theme.InitializeAsync();
            await BoardZoom.InitializeAsync();
            StateHasChanged();
        }
    }

    private bool IsInGamePage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var path = relative.Split('?', 2)[0].Trim('/');
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
        return segments.Length == 2
               && string.Equals(segments[0], "games", StringComparison.OrdinalIgnoreCase)
               && !string.IsNullOrWhiteSpace(segments[1]);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void HandleZoomChanged() =>
        InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        BoardZoom.ZoomChanged -= HandleZoomChanged;
    }
}
