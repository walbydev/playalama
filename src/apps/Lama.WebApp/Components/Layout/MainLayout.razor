@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AuthService Auth
@inject ThemeService Theme
@inject GameLayoutService Layout
@inject LamaApiClient Api
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<div class="page-wrapper @(IsGameFocusMode ? "page-wrapper--game-focus" : "") @(IsGameFocusMode && Layout.IsFullscreen ? "page-wrapper--fullscreen" : "")">
    <DevBanner />
    
    @* ── SKIP LINKS (Accessibilité) ─────────────────────────────────────── *@
    <a href="#main-content" class="skip-link" @onclick="FocusMainContent">
        @L["Accessibility.SkipToMain"]
    </a>
    <a href="#nav-links" class="skip-link skip-link-secondary" @onclick="FocusNav">
        @L["Accessibility.SkipToNav"]
    </a>
    
    <NavBar CompactMode="@IsGameFocusMode" ShowDevBanner="true" />

    <main id="main-content" class="@(IsGameFocusMode ? "main-content--game-focus" : null)" tabindex="-1">
        @Body
    </main>

    @if (!IsGameFocusMode)
    {
        <Footer />
    }

    <div class="llamo-watermark" aria-hidden="true"></div>
    
    @* ── ANNONCES SCREEN READER ────────────────────────────────────────── *@
    <LiveAnnouncer />
</div>

@code {
    private bool IsGameFocusMode => IsInGamePage();
    private string? _syncedAccessibilityPlayerId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Nav.LocationChanged += HandleLocationChanged;
            Layout.Changed += HandleZoomChanged;
        }

        // Retry tant que JS n'est pas encore disponible (prerender/interactivité)
        if (!Auth.IsInitialized)
            await Auth.InitializeAsync();

        await Theme.InitializeAsync();
        await Layout.InitializeAsync();
        await SyncAccessibilityFromProfileAsync();

        if (firstRender || !Auth.IsInitialized)
            StateHasChanged();
    }

    private async Task SyncAccessibilityFromProfileAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            _syncedAccessibilityPlayerId = null;
            return;
        }

        var currentPlayerId = Auth.CurrentUser?.PlayerId;
        if (string.IsNullOrWhiteSpace(currentPlayerId) || currentPlayerId == _syncedAccessibilityPlayerId)
            return;

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
            return;

        try
        {
            var profile = await Api.GetMyProfileAsync(token);
            var accessibility = profile?.Accessibility;
            if (accessibility is null)
                return;

            await Theme.SetAsync(accessibility.Theme);
            await JS.InvokeVoidAsync("playalamaAccessibility.setFontSize", NormalizeFontSize(accessibility.FontSize).ToString(System.Globalization.CultureInfo.InvariantCulture));
            await Layout.SetDensityAsync(ScaleToDensity(accessibility.BoardScale));
            _syncedAccessibilityPlayerId = currentPlayerId;
        }
        catch (HttpRequestException)
        {
        }
        catch (UnauthorizedAccessException)
        {
        }
    }

    private async Task FocusMainContent()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('main-content')?.focus()");
        }
        catch { /* JSInterop pas encore dispo */ }
    }

    private async Task FocusNav()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.getElementById('nav-links')?.focus()");
        }
        catch { /* JSInterop pas encore dispo */ }
    }

    private bool IsInGamePage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var path = relative.Split('?', 2)[0].Trim('/');
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
        return segments.Length == 2
               && string.Equals(segments[0], "games", StringComparison.OrdinalIgnoreCase)
               && !string.IsNullOrWhiteSpace(segments[1]);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) =>
        InvokeAsync(StateHasChanged);

    private void HandleZoomChanged() =>
        InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        Layout.Changed -= HandleZoomChanged;
    }

    private static int NormalizeFontSize(int size) => size is 100 or 125 or 150 or 200 ? size : 100;

    private static string ScaleToDensity(double scale)
    {
        var normalized = Math.Round(Math.Clamp(scale, 0.8, 2.0), 1);
        if (normalized <= 0.9) return "s";
        if (normalized <= 1.2) return "m";
        if (normalized <= 1.6) return "l";
        if (normalized <= 1.9) return "xl";
        return "xxl";
    }
}
