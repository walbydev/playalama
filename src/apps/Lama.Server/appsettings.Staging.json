{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "Console": {
      "IncludeScopes": false
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://127.0.0.1:5301",
  "LAMA_AI_SERVER_URL": "http://127.0.0.1:5303",
  "ConnectionStrings": {
    "LamaServerDb": "Host=localhost;Port=5432;Database=lama_staging;Username=lama_staging;Password=change_me_staging;Ssl Mode=Require;Application Name=LamaServer.Staging;"
  },
  "Database": {
    "Provider": "PostgreSQL",
    "AutoMigrate": false,
    "LogSql": false,
    "CommandTimeout": 60,
    "ConnectionPoolSize": 20
  },
  "GameServer": {
    "MaxConcurrentGames": 50,
    "SessionIdleTimeoutMinutes": 240,
    "CleanupIntervalMinutes": 60
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 10485760,
      "RequestHeadersTimeout": "00:00:30",
      "MaxConnections": 500
    }
  }
}
