@page "/"
@layout MainLayout

<PageTitle>Playalama | Accueil</PageTitle>

<section class="card hero">
    <div class="eyebrow">LAMA Portal</div>
    <h1>Le portail officiel de Playalama.</h1>
    <p>
        Retrouvez les regles, les telechargements CLI et l'acces direct
        a l'espace de jeu live.
    </p>
    <div class="actions" style="margin-top:18px;">
        <a class="button" href="/live/">Entrer dans l'espace jeu</a>
        <a class="button-secondary" href="/downloads">Telechargements console</a>
    </div>
</section>

<section class="card section">
    <h2>Ce que propose le portail</h2>
    <div class="grid">
        <article class="tile">
            <h3>Vitrine</h3>
            <p>Presentation du jeu, regles, et liens de telechargement.</p>
        </article>
        <article class="tile">
            <h3>Live</h3>
            <p>Le jeu en ligne est accessible via le chemin dedie /live.</p>
        </article>
        <article class="tile">
            <h3>CLI</h3>
            <p>Archives Linux/Windows/macOS pour jouer en mode console local ou online.</p>
        </article>
    </div>
</section>

