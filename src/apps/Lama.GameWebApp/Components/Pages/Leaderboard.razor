@page "/leaderboard"
@layout MainLayout

<PageTitle>Classements — Playalama</PageTitle>

<div class="card hero">
    <div class="eyebrow">🏆 Classements</div>
    <h1>Classements complets</h1>
    <p>Retrouvez le palmarès de tous les joueurs sur l'ensemble des parties jouées.</p>
</div>

<div class="card section">
    <div class="section-head">
        <h2>Classement global</h2>
        <span class="chip chip-muted">À venir</span>
    </div>

    <div class="empty-state">
        <span class="empty-icon">🏅</span>
        <p>Les classements détaillés seront disponibles prochainement.</p>
        <a class="button-secondary" href="">← Retour à l'accueil</a>
    </div>
</div>
