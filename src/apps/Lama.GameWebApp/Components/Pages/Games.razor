@page "/games"
@layout MainLayout
@inject LamaApiClient Api
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Playalama | Jouer</PageTitle>

<section class="card section">
    <h1>Zone de jeu</h1>
    <p>V1 simple: creer une partie, rejoindre une partie existante, puis jouer depuis l'ecran partie.</p>

    <EditForm Model="createForm" OnValidSubmit="CreateGameAsync" class="stack">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label>Mode
                <InputSelect class="input" @bind-Value="createForm.Mode">
                    <option value="multi">Multi</option>
                    <option value="solo">Solo</option>
                </InputSelect>
            </label>
            <label>Nom de partie
                <InputText class="input" @bind-Value="createForm.GameName" />
            </label>
            <label>Max joueurs
                <InputNumber class="input" @bind-Value="createForm.MaxPlayers" />
            </label>
        </div>
        <button class="button" type="submit" disabled="@busy">Creer une partie</button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <p class="error">@error</p>
    }
</section>

<section class="card section">
    <div class="section-head">
        <h2>Parties disponibles</h2>
        <button class="button-secondary" @onclick="LoadGamesAsync" disabled="@busy">Rafraichir</button>
    </div>

    @if (games.Count == 0)
    {
        <p>Aucune partie trouvee pour le moment.</p>
    }
    else
    {
        <table class="game-table">
            <thead>
            <tr>
                <th>Nom</th>
                <th>Statut</th>
                <th>Joueurs</th>
                <th>Queue</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var game in games)
            {
                <tr>
                    <td>@(string.IsNullOrWhiteSpace(game.GameName) ? game.Id : game.GameName)</td>
                    <td>@game.Status</td>
                    <td>@game.Players / @game.MaxPlayers</td>
                    <td>@game.Queue</td>
                    <td>
                        @if (game.IsJoinable)
                        {
                            <button class="button-secondary" @onclick="() => JoinGameAsync(game.Id)">Rejoindre</button>
                        }
                        else
                        {
                            <a class="button-secondary" href="games/@game.Id">Voir</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

@code {
    private readonly CreateGameForm createForm = new();
    private readonly List<WebGameListItem> games = [];
    private bool busy;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await LoadGamesAsync();
    }

    private async Task CreateGameAsync()
    {
        busy = true;
        error = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Session expirée. Reconnectez-vous pour créer une partie.";
                Navigation.NavigateTo("/login");
                return;
            }

            var currentUser = Auth.CurrentUser;
            if (currentUser is null)
            {
                error = "Aucun utilisateur connecté. Reconnectez-vous.";
                Navigation.NavigateTo("/login");
                return;
            }

            var created = await Api.CreateGameAsync(createForm, currentUser.Username, token);
            Navigation.NavigateTo($"/games/{created.GameId}?playerId={Uri.EscapeDataString(created.HostPlayerId)}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task JoinGameAsync(string gameId)
    {
        busy = true;
        error = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Session expirée. Reconnectez-vous pour rejoindre une partie.";
                Navigation.NavigateTo("/login");
                return;
            }

            var playerName = Auth.CurrentUser?.Username;
            if (string.IsNullOrWhiteSpace(playerName))
            {
                error = "Aucun utilisateur connecté. Reconnectez-vous.";
                Navigation.NavigateTo("/login");
                return;
            }

            var joined = await Api.JoinGameAsync(gameId, playerName, password: null, token);
            Navigation.NavigateTo($"/games/{joined.GameId}?playerId={Uri.EscapeDataString(joined.PlayerId)}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task LoadGamesAsync()
    {
        busy = true;
        error = null;
        try
        {
            games.Clear();
            games.AddRange(await Api.ListGamesAsync());
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}

