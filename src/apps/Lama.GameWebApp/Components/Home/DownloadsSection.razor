<div class="card section downloads-section">
    <div class="section-head">
        <h2>⬇️ Télécharger LAMA CLI</h2>
        <span class="chip chip-muted">v@Version</span>
    </div>
    <p>Jouez en local depuis votre terminal — gratuit, sans compte requis.</p>

    <div class="download-grid">
        @foreach (var release in Releases)
        {
            <a class="download-card tile" href="@release.Url" download>
                <span class="download-icon">@release.Icon</span>
                <span class="download-platform">@release.Platform</span>
                <span class="download-arch chip chip-muted">@release.Arch</span>
                <span class="download-hint">ZIP · CLI</span>
            </a>
        }
    </div>
</div>

@code {
    public sealed record DownloadRelease(string Icon, string Platform, string Arch, string Url);

    [Parameter] public string Version { get; set; } = "1.1.0";
    [Parameter] public string BaseUrl { get; set; } = "https://get.playalama.online";

    [Parameter]
    public IReadOnlyList<DownloadRelease> Releases { get; set; } = default!;

    protected override void OnParametersSet()
    {
        Releases ??= [
            new("🪟", "Windows", "x64",   $"https://get.playalama.online/lama-win-x64.zip"),
            new("🪟", "Windows", "ARM64", $"https://get.playalama.online/lama-win-arm64.zip"),
            new("🍎", "macOS",   "x64",   $"https://get.playalama.online/lama-osx-x64.zip"),
            new("🍎", "macOS",   "ARM64", $"https://get.playalama.online/lama-osx-arm64.zip"),
            new("🐧", "Linux",   "x64",   $"https://get.playalama.online/lama-linux-x64.zip"),
            new("🐧", "Linux",   "ARM64", $"https://get.playalama.online/lama-linux-arm64.zip"),
        ];
    }
}
