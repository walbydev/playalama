<div class="stats-counters">
    @foreach (var stat in Stats)
    {
        <div class="stat-counter tile">
            <span class="stat-icon">@stat.Icon</span>
            <strong class="stat-number">@stat.Value</strong>
            <span class="stat-label">@stat.Label</span>
        </div>
    }
</div>

@code {
    public sealed record StatEntry(string Icon, string Value, string Label);

    [Parameter]
    public IReadOnlyList<StatEntry> Stats { get; set; } = [
        new("👥", "42", "Joueurs actifs"),
        new("🎲", "1 337", "Parties jouées"),
        new("🌐", "2", "Langues disponibles"),
    ];
}
