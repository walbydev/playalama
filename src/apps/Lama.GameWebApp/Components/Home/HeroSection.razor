<div class="hero-section card hero">
    <div class="eyebrow">🦙 LAMA — Jeu de mots</div>
    <h1 class="hero-title">Jouez en ligne, partout.</h1>
    <p class="hero-tagline">
        Affrontez d'autres joueurs en temps réel, posez des mots, gagnez des points.<br />
        Disponible en ligne et en console sur toutes les plateformes.
    </p>
    <div class="cta-strip">
        <a class="button" href="@GameAppUrl" target="_blank" rel="noopener">
            🎮 Jouer maintenant
        </a>
        <a class="button-secondary" href="@RulesUrl">
            📖 Voir les règles
        </a>
    </div>
</div>

@code {
    [Parameter] public string GameAppUrl { get; set; } = "https://game.playalama.online";
    [Parameter] public string RulesUrl { get; set; } = "/rules";
}
