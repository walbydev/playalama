<div class="card section live-board-widget">
    <div class="section-head">
        <h2>🔴 Plateau en direct</h2>
        @if (!string.IsNullOrWhiteSpace(GameUrl))
        {
            <a class="button-secondary" href="@GameUrl">Voir la partie →</a>
        }
        else
        {
            <span class="chip chip-muted">Aucune partie en cours</span>
        }
    </div>

    <div class="live-board">
        @for (int row = 0; row < Rows; row++)
        {
            <div class="board-row">
                @for (int col = 0; col < Cols; col++)
                {
                    var letter = GetLetter(row, col);
                    <div class="board-cell @(letter != ' ' ? "board-cell--filled" : "")">
                        @(letter != ' ' ? letter.ToString() : "")
                    </div>
                }
            </div>
        }
    </div>

    @if (Players.Count > 0)
    {
        <div class="live-players">
            @foreach (var p in Players)
            {
                <span class="chip @(p.IsCurrent ? "chip-accent" : "chip-muted")">
                    @p.Name <strong>@p.Score</strong>
                </span>
            }
        </div>
    }
</div>

@code {
    public sealed record LivePlayer(string Name, int Score, bool IsCurrent);

    [Parameter] public int Rows { get; set; } = 10;
    [Parameter] public int Cols { get; set; } = 15;
    [Parameter] public string? GameUrl { get; set; }

    [Parameter]
    public IReadOnlyList<(int Row, int Col, char Letter)> PlacedTiles { get; set; } = [
        (2, 3, 'L'), (2, 4, 'A'), (2, 5, 'M'), (2, 6, 'A'),
        (2, 3, 'L'), (3, 3, 'I'), (4, 3, 'V'), (5, 3, 'E'),
        (4, 3, 'V'), (4, 4, 'O'), (4, 5, 'T'), (4, 6, 'E'),
        (6, 5, 'J'), (7, 5, 'E'), (8, 5, 'U'),
    ];

    [Parameter]
    public IReadOnlyList<LivePlayer> Players { get; set; } = [
        new("Alice", 87, true),
        new("Bob", 64, false),
    ];

    private char GetLetter(int row, int col)
    {
        foreach (var (r, c, l) in PlacedTiles)
            if (r == row && c == col) return l;
        return ' ';
    }
}
