{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning"
    },
    "Console": {
      "IncludeScopes": false
    }
  },
  "AllowedHosts": "playalama.online,www.playalama.online,localhost",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://[::]:5000",
        "Protocols": "Http1AndHttp2"
      }
    },
    "Limits": {
      "MaxRequestBodySize": 10485760,
      "RequestHeadersTimeout": "00:00:30"
    }
  }
}

