{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "Console": {
      "IncludeScopes": false
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "LamaServerDb": "Server=${POSTGRES_HOST};Port=${POSTGRES_PORT:-5432};Database=${POSTGRES_DB};User Id=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};SslMode=Require;Application Name=LamaServer.Prod;"
  },
  "Database": {
    "Provider": "PostgreSQL",
    "AutoMigrate": false,
    "LogSql": false,
    "CommandTimeout": 60,
    "ConnectionPoolSize": 20,
    "Replication": {
      "Enabled": true,
      "ReadReplicas": []
    }
  },
  "GameServer": {
    "MaxConcurrentGames": 5000,
    "SessionIdleTimeoutMinutes": 240,
    "CleanupIntervalMinutes": 60,
    "ArchiveCompletedGamesDaily": true,
    "GenerateLeaderboardSnapshotsWeekly": true
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://[::]:8080",
        "Protocols": "Http1AndHttp2"
      }
    },
    "Limits": {
      "MaxRequestBodySize": 10485760,
      "RequestHeadersTimeout": "00:00:30",
      "MaxConnections": 500
    }
  }
}

