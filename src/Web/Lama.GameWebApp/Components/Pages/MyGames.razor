@page "/my-games"
@layout MainLayout
@inject AuthService Auth
@inject LamaApiClient Api
@inject NavigationManager Navigation

<PageTitle>Playalama | Mes parties</PageTitle>

@if (!Auth.IsLoggedIn)
{
    <section class="card section">
        <h1>Mes parties</h1>
        <p>Vous devez être connecté pour voir votre historique.</p>
        <a class="button" href="login">Se connecter</a>
    </section>
}
else
{
    <section class="card section">
        <div class="section-head">
            <h1>Mes parties</h1>
            <button class="button-secondary" @onclick="LoadAsync" disabled="@busy">Rafraîchir</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <p class="alert-error">@error</p>
        }

        @if (busy)
        {
            <div class="skeleton-list">
                @for (var i = 0; i < 5; i++) { <div class="skeleton-row"></div> }
            </div>
        }
        else if (games.Count == 0)
        {
            <div class="empty-state">
                <span class="empty-icon">🎮</span>
                <p>Aucune partie terminée pour le moment.</p>
                <a class="button" href="games">Rejoindre une partie</a>
            </div>
        }
        else
        {
            <div class="stats-row">
                <div class="stat-pill">
                    <span>Parties jouées</span>
                    <strong>@games.Count</strong>
                </div>
                <div class="stat-pill">
                    <span>Victoires</span>
                    <strong class="ok">@games.Count(g => g.IsWinner)</strong>
                </div>
                <div class="stat-pill">
                    <span>Ratio V/D</span>
                    <strong>@WinRate()</strong>
                </div>
            </div>

            <table class="game-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Niveau</th>
                        <th>Queue</th>
                        <th>Durée</th>
                        <th>Résultat</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in games)
                    {
                        <tr class="@(g.IsWinner ? "row-win" : "")">
                            <td>@g.EndedAt.ToString("dd/MM/yy HH:mm")</td>
                            <td>@g.GameLevel</td>
                            <td>@g.Queue</td>
                            <td>@FormatDuration(g.DurationSeconds)</td>
                            <td>
                                @if (g.IsWinner)
                                {
                                    <span class="chip chip-ok">Victoire 🏆</span>
                                }
                                else
                                {
                                    <span class="chip chip-muted">@g.Status</span>
                                }
                            </td>
                            <td><a class="button-ghost" href="games/@g.GameId">Voir</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private readonly List<WebGameHistoryItem> games = [];
    private bool busy;
    private string? error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.InitializeAsync();
        if (!Auth.IsLoggedIn) { StateHasChanged(); return; }
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        busy = true;
        error = null;
        try
        {
            var token = await Auth.GetTokenAsync();
            if (token is null) { error = "Session expirée."; return; }
            games.Clear();
            games.AddRange(await Api.GetMyGamesAsync(token));
        }
        catch (Exception ex) { error = ex.Message; }
        finally { busy = false; StateHasChanged(); }
    }

    private string WinRate()
    {
        if (games.Count == 0) return "—";
        var pct = (double)games.Count(g => g.IsWinner) / games.Count * 100;
        return $"{pct:F0}%";
    }

    private static string FormatDuration(int seconds)
    {
        if (seconds < 60) return $"{seconds}s";
        if (seconds < 3600) return $"{seconds / 60}m{seconds % 60:D2}s";
        return $"{seconds / 3600}h{(seconds % 3600) / 60:D2}m";
    }
}

