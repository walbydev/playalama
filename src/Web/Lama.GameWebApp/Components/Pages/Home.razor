@page "/"
@layout MainLayout

<PageTitle>Playalama Live | Accueil</PageTitle>

<section class="card hero">
    <div class="eyebrow">LAMA Game WebApp</div>
    <h1>Bienvenue sur l'espace de jeu live.</h1>
    <p>
        Cette application est dediee aux parties en ligne: salon, connexion, profil joueur,
        et plateau en direct.
    </p>
    <div class="actions" style="margin-top:18px;">
        <a class="button" href="games">Entrer dans le lobby</a>
        <a class="button-secondary" href="/">Voir le portail</a>
    </div>
</section>

<section class="card section">
    <h2>Ce que contient Live</h2>
    <div class="grid">
        <article class="tile">
            <h3>Lobby en ligne</h3>
            <p>Creation et rejoindre des parties avec rafraichissement rapide.</p>
        </article>
        <article class="tile">
            <h3>Partie en direct</h3>
            <p>Plateau, coups, score et historique de tour dans un seul flux.</p>
        </article>
        <article class="tile">
            <h3>Compte joueur</h3>
            <p>Connexion, inscription et gestion du profil depuis l'app live.</p>
        </article>
    </div>
</section>

