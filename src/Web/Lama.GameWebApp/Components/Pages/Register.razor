@page "/register"
@layout MainLayout
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Playalama | Inscription</PageTitle>

<section class="card section auth-card">
    <div class="auth-header">
        <span class="brand-big">🦙</span>
        <h1>Créer un compte</h1>
        <p>L'email est optionnel — il ne sert pas à se connecter.</p>
    </div>

    <EditForm Model="form" OnValidSubmit="SubmitAsync" class="stack">
        <DataAnnotationsValidator />

        <label class="field-label">Pseudo (min. 2 caractères)
            <InputText class="input" @bind-Value="form.Username" autocomplete="username" placeholder="VotreAlias" />
            <ValidationMessage For="() => form.Username" />
        </label>

        <label class="field-label">Email (optionnel)
            <InputText class="input" type="email" @bind-Value="form.Email" autocomplete="email" placeholder="vous@exemple.fr" />
        </label>

        <label class="field-label">Mot de passe (min. 6 caractères)
            <InputText class="input" type="password" @bind-Value="form.Password" autocomplete="new-password" placeholder="••••••" />
            <ValidationMessage For="() => form.Password" />
        </label>

        <label class="field-label">Confirmer le mot de passe
            <InputText class="input" type="password" @bind-Value="form.PasswordConfirm" autocomplete="new-password" placeholder="••••••" />
            <ValidationMessage For="() => form.PasswordConfirm" />
        </label>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <p class="alert-error">@error</p>
        }

        <div class="actions">
            <button class="button" type="submit" disabled="@busy">
                @(busy ? "Inscription…" : "Créer mon compte")
            </button>
        </div>
    </EditForm>

    <p class="auth-footer">Déjà un compte ? <a href="/login">Se connecter</a></p>
</section>

@code {
    private readonly RegisterForm form = new();
    private bool busy;
    private string? error;

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Navigation.NavigateTo("/games");
    }

    private async Task SubmitAsync()
    {
        busy = true;
        error = null;

        var (success, err) = await Auth.RegisterAsync(form.Username, form.Password, form.Email);

        if (success)
            Navigation.NavigateTo("/games");
        else
            error = err ?? "Inscription échouée.";

        busy = false;
    }
}

