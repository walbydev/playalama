@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject AuthService Auth

<div class="shell">
    <header class="topbar">
        <a class="brand" href="/">Playalama</a>
        <nav class="actions">
            <a class="nav-link" href="/">Accueil</a>
            <a class="nav-link" href="/rules">Règles</a>
            <a class="nav-link" href="/downloads">Téléchargements</a>
            <a class="nav-link" href="/games">Jouer</a>
            @if (Auth.IsLoggedIn)
            {
                <a class="nav-link" href="/my-games">Mes parties</a>
                <a class="nav-link" href="/profile">
                    <span class="chip chip-accent">@Auth.CurrentUser!.Username</span>
                </a>
                <button class="button-ghost" type="button" @onclick="LogoutAsync">Déconnexion</button>
            }
            else
            {
                <a class="button-secondary" href="/login">Connexion</a>
                <a class="button" href="/register">S'inscrire</a>
            }
            <button class="theme-toggle" type="button" @onclick="ToggleTheme" title="Changer le thème">☾</button>
            <button class="theme-toggle" type="button" @onclick="ToggleDensity" title="Densité">⊡</button>
        </nav>
    </header>

    @if (!string.IsNullOrWhiteSpace(_toast))
    {
        <div class="toast @(_toastType)">@_toast</div>
    }

    <main>
        @Body
    </main>

    <footer class="footer">
        <span>© LAMA 1.1.0</span>
        <a href="/rules">Règles</a>
        <a href="/downloads">Console CLI</a>
    </footer>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private string? _toast;
    private string _toastType = "toast-ok";
    private System.Threading.Timer? _toastTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }

    private async Task ToggleTheme() => await JS.InvokeVoidAsync("playalamaTheme.toggleTheme");
    private async Task ToggleDensity() => await JS.InvokeVoidAsync("playalamaTheme.toggleDensity");
}
