@page "/"
@layout MainLayout

<PageTitle>Playalama | Accueil</PageTitle>

<section class="card hero">
    <div class="eyebrow">LAMA WebApp v1.1.0</div>
    <h1>Jeu de mots en ligne, interface simple et solide.</h1>
    <p>
        Cette v1 se concentre sur deux choses: une vitrine claire et une experience de jeu robuste.
        Les options avancees (tournoi, reglages expert) arriveront dans les lots suivants.
    </p>
    <div class="actions" style="margin-top:18px;">
        <a class="button" href="/games">Entrer dans l'espace jeu</a>
        <a class="button-secondary" href="/downloads">Telechargements console</a>
    </div>
</section>

<section class="card section">
    <h2>Ce que contient la V1</h2>
    <div class="grid">
        <article class="tile">
            <h3>Vitrine</h3>
            <p>Presentation du jeu, regles, et liens de telechargement.</p>
        </article>
        <article class="tile">
            <h3>Jeu online</h3>
            <p>Creation/rejoindre partie, vue plateau, et actions de tour de base.</p>
        </article>
        <article class="tile">
            <h3>Gestion simple</h3>
            <p>Profil local navigateur avec pseudo/email optionnel et mot de passe.</p>
        </article>
    </div>
</section>

