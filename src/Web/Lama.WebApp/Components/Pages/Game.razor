@page "/games/{GameId}"
@layout MainLayout
@implements IAsyncDisposable
@inject LamaApiClient Api
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Playalama | Partie</PageTitle>

<section class="card section">
    <div class="section-head">
        <h1>Partie @GameId</h1>
        <button class="button-secondary" @onclick="LoadSnapshotAsync" disabled="@busy">Rafraichir</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <p class="error">@error</p>
    }

    @if (snapshot is null)
    {
        <p>Chargement de la partie...</p>
    }
    else
    {
        <div class="grid two-col">
            <article class="tile">
                <h3>Joueurs</h3>
                <ul class="hero-list">
                    @for (var i = 0; i < snapshot.Players.Count; i++)
                    {
                        var player = snapshot.Players[i];
                        <li>
                            <strong>@player.PlayerName</strong> - @player.Score pts
                            @if (i == snapshot.CurrentPlayerIndex)
                            {
                                <span class="chip">tour actif</span>
                            }
                        </li>
                    }
                </ul>
            </article>

            <article class="tile">
                <h3>Mon action</h3>
                @if (snapshot.UsesLobby && !snapshot.HasStarted)
                {
                    <p>Partie en attente de démarrage.</p>
                    @if (CanCurrentUserStartGame)
                    {
                        <button class="button" @onclick="StartGameAsync" disabled="@busy">Démarrer la partie (hôte)</button>
                    }
                    else
                    {
                        <p>Seul l'hôte peut démarrer la partie.</p>
                    }
                }
                <EditForm Model="playForm" OnValidSubmit="PlayAsync" class="stack">
                    <DataAnnotationsValidator />
                    <label>PlayerId
                        <InputText class="input" @bind-Value="playForm.PlayerId" />
                    </label>
                    <label>Commande
                        <InputSelect class="input" @bind-Value="playForm.Command">
                            <option value="play.pass">play.pass</option>
                            <option value="play.move">play.move</option>
                            <option value="play.swap">play.swap</option>
                        </InputSelect>
                    </label>
                    <label>Position (ex: H8)
                        <InputText class="input" @bind-Value="playForm.Position" />
                    </label>
                    <label>Mot/Lettres
                        <InputText class="input" @bind-Value="playForm.Word" />
                    </label>
                    <label>Direction (H/V)
                        <InputText class="input" @bind-Value="playForm.Direction" />
                    </label>
                    <button class="button" type="submit" disabled="@(busy || (snapshot.UsesLobby && !snapshot.HasStarted))">Jouer</button>
                </EditForm>
            </article>
        </div>

        <article class="tile board-tile">
            <h3>Plateau</h3>
            <div class="board">
                @for (var row = 0; row < 15; row++)
                {
                    <div class="board-row">
                        @for (var col = 0; col < 15; col++)
                        {
                            var letter = ResolveLetter(row, col);
                            <span class="board-cell">@(letter is null ? "·" : letter)</span>
                        }
                    </div>
                }
            </div>
        </article>
    }
</section>

@code {
    [Parameter] public string GameId { get; set; } = string.Empty;

    private WebGameSnapshot? snapshot;
    private readonly PlayForm playForm = new() { Command = "play.pass" };
    private bool busy;
    private string? error;
    private PeriodicTimer? timer;
    private CancellationTokenSource? pollingCts;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var parsed = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        playForm.PlayerId = parsed.TryGetValue("playerId", out var playerId)
            ? playerId.ToString()
            : Auth.CurrentUser?.PlayerId ?? string.Empty;

        await LoadSnapshotAsync();
        StartPolling();
    }

    private void StartPolling()
    {
        pollingCts = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(2));

        _ = Task.Run(async () =>
        {
            while (await timer.WaitForNextTickAsync(pollingCts.Token))
            {
                await InvokeAsync(LoadSnapshotAsync);
            }
        }, pollingCts.Token);
    }

    private async Task LoadSnapshotAsync()
    {
        busy = true;
        error = null;
        try
        {
            snapshot = await Api.GetGameAsync(GameId);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task PlayAsync()
    {
        if (string.IsNullOrWhiteSpace(playForm.PlayerId))
        {
            error = "PlayerId requis.";
            return;
        }

        busy = true;
        error = null;

        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Session expirée. Reconnectez-vous pour jouer.";
                Navigation.NavigateTo("/login");
                return;
            }

            await Api.PlayAsync(GameId, playForm, token);
            await LoadSnapshotAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task StartGameAsync()
    {
        busy = true;
        error = null;

        try
        {
            var token = await Auth.GetTokenAsync();
            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Session expirée. Reconnectez-vous pour démarrer la partie.";
                Navigation.NavigateTo("/login");
                return;
            }

            await Api.StartGameAsync(GameId, token);
            await LoadSnapshotAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private bool CanCurrentUserStartGame =>
        snapshot is not null
        && snapshot.UsesLobby
        && !snapshot.HasStarted
        && snapshot.Players.Any(p => p.IsHost && string.Equals(p.PlayerId, Auth.CurrentUser?.PlayerId, StringComparison.Ordinal));

    private string? ResolveLetter(int row, int col)
    {
        var tile = snapshot?.Board.FirstOrDefault(x => x.Row == row && x.Column == col);
        return tile is null ? null : tile.Letter.ToString();
    }

    public async ValueTask DisposeAsync()
    {
        if (pollingCts is not null)
        {
            await pollingCts.CancelAsync();
            pollingCts.Dispose();
        }

        timer?.Dispose();
    }
}

