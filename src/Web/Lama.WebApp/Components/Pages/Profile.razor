@page "/profile"
@layout MainLayout
@inject IJSRuntime JS

<PageTitle>Playalama | Profil</PageTitle>

<section class="card section">
    <h1>Gestion du profil</h1>
    <p>V1 stocke le profil localement dans votre navigateur. L'email est optionnel.</p>

    <EditForm Model="profile" OnValidSubmit="SaveAsync" class="stack">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label>Pseudo / Username
                <InputText class="input" @bind-Value="profile.Username" />
            </label>
            <label>Email (optionnel)
                <InputText class="input" @bind-Value="profile.Email" />
            </label>
            <label>Mot de passe
                <InputText class="input" @bind-Value="profile.Password" type="password" />
            </label>
        </div>
        <div class="actions">
            <button class="button" type="submit">Sauvegarder</button>
            <button class="button-secondary" type="button" @onclick="LoadAsync">Recharger</button>
        </div>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="success">@message</p>
    }
</section>

@code {
    private ProfileForm profile = new();
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task SaveAsync()
    {
        await JS.InvokeVoidAsync("playalamaProfile.save", profile);
        message = "Profil sauvegarde localement.";
    }

    private async Task LoadAsync()
    {
        var loaded = await JS.InvokeAsync<ProfileForm?>("playalamaProfile.load");
        if (loaded is not null)
            profile = loaded;
    }
}

